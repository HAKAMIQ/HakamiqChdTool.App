    <sys:String x:Key="LocAdv_CompressionPresetDefaultLabel">MAME default (recommended)</sys:String>
    <sys:String x:Key="LocAdv_CompressionPresetDefaultDescription">Lets MAME choose by media type. For CD, this usually already uses CD LZMA, matching the LZMA option.</sys:String>

    <sys:String x:Key="LocAdv_CompressionPresetFastLabel">Fast – lighter compression</sys:String>
    <sys:String x:Key="LocAdv_CompressionPresetFastDescription">Faster. CD uses cdzs,cdfl and DVD uses zstd,flac; output may be larger.</sys:String>

    <sys:String x:Key="LocAdv_CompressionPresetBalancedLabel">Balanced – Zstandard with fallbacks</sys:String>
    <sys:String x:Key="LocAdv_CompressionPresetBalancedDescription">Middle option. CD uses cdzs,cdzl,cdfl and DVD uses zstd,zlib,huff,flac.</sys:String>

    <sys:String x:Key="LocAdv_CompressionPresetMaxLabel">LZMA – slower; CD may not shrink more</sys:String>
    <sys:String x:Key="LocAdv_CompressionPresetMaxDescription">CD uses cdlz,cdzl,cdfl, which usually matches MAME default. DVD uses lzma,zlib,huff,flac and may be slower.</sys:String>

    <sys:String x:Key="LocAdv_PerformanceModeSafeLabel">Safe</sys:String>
    <sys:String x:Key="LocAdv_PerformanceModeSafeDescription">Keeps the system responsive by leaving enough resources for Windows and other apps. This is the default mode.</sys:String>

    <sys:String x:Key="LocAdv_PerformanceModeBalancedLabel">Balanced</sys:String>
    <sys:String x:Key="LocAdv_PerformanceModeBalancedDescription">Automatically adjusts compression threads based on available resources while keeping the system stable.</sys:String>

    <sys:String x:Key="LocAdv_PerformanceModeFastLabel">Fast</sys:String>
    <sys:String x:Key="LocAdv_PerformanceModeFastDescription">Uses all available resources to speed up conversion. Best with SSD storage when no other heavy tasks are running.</sys:String>

    <sys:String x:Key="LocAdv_PerformanceModeManualLabel">Manual</sys:String>
    <sys:String x:Key="LocAdv_PerformanceModeManualDescription">Lets you set the compression thread count manually in the next option.</sys:String>

    <sys:String x:Key="LocAdv_ProcessPriorityQuietLabel">Quiet</sys:String>
    <sys:String x:Key="LocAdv_ProcessPriorityQuietDescription">Runs chdman at a lower priority so the system stays more responsive.</sys:String>

    <sys:String x:Key="LocAdv_ProcessPriorityNormalLabel">Normal</sys:String>
    <sys:String x:Key="LocAdv_ProcessPriorityNormalDescription">Runs chdman at normal priority. This may improve speed but can reduce system responsiveness during conversion.</sys:String>

    <sys:String x:Key="LocAdv_HunkPresetDefaultLabel">MAME default (recommended)</sys:String>
    <sys:String x:Key="LocAdv_HunkPresetDefaultDescription">Does not customize hunk size and lets MAME use the suitable setting.</sys:String>

    <sys:String x:Key="LocAdv_HunkPresetSmallLabel">Advanced – small</sys:String>
    <sys:String x:Key="LocAdv_HunkPresetSmallDescription">Smaller hunk size may improve random reads, but may reduce compression ratio.</sys:String>

    <sys:String x:Key="LocAdv_HunkPresetBalancedLabel">Advanced – balanced</sys:String>
    <sys:String x:Key="LocAdv_HunkPresetBalancedDescription">Medium hunk size for manual testing when needed.</sys:String>

    <sys:String x:Key="LocAdv_HunkPresetLargeLabel">Advanced – large</sys:String>
    <sys:String x:Key="LocAdv_HunkPresetLargeDescription">Larger hunk size may improve compression, but may slow small reads.</sys:String>

    <sys:String x:Key="LocAdv_IsoCreateOverrideAutoLabel">Auto by media type (recommended)</sys:String>
    <sys:String x:Key="LocAdv_IsoCreateOverrideAutoDescription">The app automatically selects the CD path for CUE/GDI, and checks ISO files to determine CD or DVD using available evidence.</sys:String>

    <sys:String x:Key="LocAdv_IsoCreateOverrideCreateCdLabel">Force CD creation</sys:String>
    <sys:String x:Key="LocAdv_IsoCreateOverrideCreateCdDescription">Uses the CD path for all files. Useful when you know the source is a CD and do not want automatic inspection.</sys:String>

    <sys:String x:Key="LocAdv_IsoCreateOverrideCreateDvdLabel">Force DVD creation</sys:String>
    <sys:String x:Key="LocAdv_IsoCreateOverrideCreateDvdDescription">Uses the DVD path for all files. Useful when you know the source is a DVD and do not want automatic inspection.</sys:String>

    <sys:String x:Key="LocAdv_ProcessorHint">Sets the maximum number of compression threads chdman may request while creating CHD files. Windows schedules the actual work based on CPU topology and current system load, so higher numbers do not always scale linearly.</sys:String>

    <sys:String x:Key="LocAdv_ProcessorSelectionAutoLimited">Auto: the app will use {0} of {1} available logical processors. This balanced value leaves room for Windows and other apps.</sys:String>
    <sys:String x:Key="LocAdv_ProcessorSelectionAutoDefault">chdman will use its default setting without a custom compression thread limit.</sys:String>
    <sys:String x:Key="LocAdv_ProcessorSelectionManual">chdman will use {0} compression threads. Review this value against the logical processors available on this device.</sys:String>

    <sys:String x:Key="LocAdv_ProcessorSelectionManualLow">Light: chdman will use {0} of {1} available logical processors. Suitable while browsing or using other apps; conversion may take longer.</sys:String>
    <sys:String x:Key="LocAdv_ProcessorSelectionManualBalanced">Balanced: uses {0} of {1} processing threads. Good balance between conversion speed and system responsiveness.</sys:String>
    <sys:String x:Key="LocAdv_ProcessorSelectionManualHigh">High: uses {0} of {1} processing threads. Speeds up conversion, but uses more system resources.</sys:String>
    <sys:String x:Key="LocAdv_ProcessorSelectionManualMaximum">Maximum: uses {0} of {1} processing threads. Intended for fast conversion while the device is not in use; CPU temperature may rise and system responsiveness may drop temporarily.</sys:String>

