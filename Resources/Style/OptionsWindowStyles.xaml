    <Style x:Key="Win11SettingsRadioButton"
           TargetType="{x:Type RadioButton}">
        <Setter Property="Width" Value="{DynamicResource Space.32}" />
        <Setter Property="Height" Value="{DynamicResource Space.32}" />
        <Setter Property="MinWidth" Value="{DynamicResource Space.32}" />
        <Setter Property="MinHeight" Value="{DynamicResource Space.32}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
        <Setter Property="Background" Value="{DynamicResource Brush.Transparent}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.CheckBox.Stroke.Rest}" />
        <Setter Property="BorderThickness" Value="{DynamicResource Inset.1.All}" />
        <Setter Property="Cursor" Value="{x:Static input:Cursors.Arrow}" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="FlowDirection" Value="{DynamicResource App.FlowDirection}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type RadioButton}">
                    <Grid x:Name="Root"
                          Width="{TemplateBinding Width}"
                          Height="{TemplateBinding Height}"
                          Background="{TemplateBinding Background}"
                          SnapsToDevicePixels="True"
                          UseLayoutRounding="True">
                        <Ellipse x:Name="Outer"
                                 Width="{DynamicResource Space.18}"
                                 Height="{DynamicResource Space.18}"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 Fill="{DynamicResource Brush.CheckBox.Fill.Rest}"
                                 Stroke="{TemplateBinding BorderBrush}"
                                 StrokeThickness="1"
                                 SnapsToDevicePixels="True" />

                        <Ellipse x:Name="Inner"
                                 Width="{DynamicResource Space.8}"
                                 Height="{DynamicResource Space.8}"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 Fill="{DynamicResource Brush.Foreground.OnAccent}"
                                 Visibility="Collapsed"
                                 SnapsToDevicePixels="True" />
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Outer" Property="Fill" Value="{DynamicResource Brush.CheckBox.Fill.Hover}" />
                            <Setter TargetName="Outer" Property="Stroke" Value="{DynamicResource Brush.CheckBox.Stroke.Hover}" />
                        </Trigger>

                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Outer" Property="Fill" Value="{DynamicResource Brush.CheckBox.Fill.Pressed}" />
                            <Setter TargetName="Outer" Property="Stroke" Value="{DynamicResource Brush.CheckBox.Stroke.Pressed}" />
                        </Trigger>

                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Outer" Property="Stroke" Value="{DynamicResource Brush.Control.Stroke.Focus}" />
                        </Trigger>

                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Outer" Property="Fill" Value="{DynamicResource Brush.CheckBox.Fill.Checked}" />
                            <Setter TargetName="Outer" Property="Stroke" Value="{DynamicResource Brush.CheckBox.Stroke.Checked}" />
                            <Setter TargetName="Inner" Property="Visibility" Value="Visible" />
                        </Trigger>

                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="True" />
                                <Condition Property="IsMouseOver" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Outer" Property="Fill" Value="{DynamicResource Brush.CheckBox.Fill.Checked.Hover}" />
                            <Setter TargetName="Outer" Property="Stroke" Value="{DynamicResource Brush.CheckBox.Stroke.Checked.Hover}" />
                        </MultiTrigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Root" Property="Opacity" Value="{DynamicResource Opacity.Disabled.Control}" />
                            <Setter TargetName="Outer" Property="Fill" Value="{DynamicResource Brush.CheckBox.Fill.Disabled}" />
                            <Setter TargetName="Outer" Property="Stroke" Value="{DynamicResource Brush.CheckBox.Stroke.Disabled}" />
                            <Setter Property="Cursor" Value="{x:Static input:Cursors.Arrow}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
