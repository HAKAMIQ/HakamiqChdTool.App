<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:input="clr-namespace:System.Windows.Input;assembly=PresentationCore">

    <Style x:Key="FluentQueueMetaPillBorder"
           TargetType="{x:Type Border}">
        <Setter Property="Padding" Value="{DynamicResource Inset.7.3}" />
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.QueuePill}" />
        <Setter Property="Background" Value="{DynamicResource NeutralBadgeBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Transparent}" />
        <Setter Property="BorderThickness" Value="{DynamicResource Inset.None}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
    </Style>

    <Style x:Key="FluentQueueMetaPillText"
           TargetType="{x:Type TextBlock}">
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="FlowDirection" Value="{DynamicResource TechnicalText.FlowDirection}" />
        <Setter Property="Language" Value="{DynamicResource TechnicalText.Language}" />
        <Setter Property="TextAlignment" Value="{DynamicResource TechnicalText.TextAlignment}" />
        <Setter Property="FontFamily" Value="{DynamicResource FontFamily.Base}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSize.CaptionSmall}" />
        <Setter Property="FontWeight" Value="{DynamicResource FontWeight.SemiBold}" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        <Setter Property="TextWrapping" Value="NoWrap" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style x:Key="FluentQueueInlineSurfaceBorder"
           TargetType="{x:Type Border}">
        <Setter Property="Padding" Value="{DynamicResource Inset.8.6}" />
        <Setter Property="Background" Value="{DynamicResource Brush.Control.Fill.Rest}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Transparent}" />
        <Setter Property="BorderThickness" Value="{DynamicResource Inset.None}" />
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.QueueSurface}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
    </Style>

    <Style x:Key="FluentQueuePrimaryFileText"
           TargetType="{x:Type TextBlock}">
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="FlowDirection" Value="{DynamicResource TechnicalText.FlowDirection}" />
        <Setter Property="Language" Value="{DynamicResource TechnicalText.Language}" />
        <Setter Property="FontFamily" Value="{DynamicResource FontFamily.Base}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSize.Body}" />
        <Setter Property="FontWeight" Value="{DynamicResource FontWeight.SemiBold}" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
        <Setter Property="TextAlignment" Value="{DynamicResource TechnicalText.TextAlignment}" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        <Setter Property="TextWrapping" Value="NoWrap" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style x:Key="FluentQueueDetailText"
           TargetType="{x:Type TextBlock}">
        <Setter Property="FlowDirection" Value="{DynamicResource App.FlowDirection}" />
        <Setter Property="Language" Value="{DynamicResource App.XmlLanguage}" />
        <Setter Property="FontFamily" Value="{DynamicResource FontFamily.Base}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSize.CaptionSmall}" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Muted}" />
        <Setter Property="TextAlignment" Value="{DynamicResource App.TextAlignment}" />
        <Setter Property="NumberSubstitution.Substitution" Value="European" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style x:Key="FluentQueueFileIconTile"
           TargetType="{x:Type Border}">
        <Setter Property="Width" Value="{DynamicResource Space.28}" />
        <Setter Property="Height" Value="{DynamicResource Space.28}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Background" Value="{DynamicResource Brush.Transparent}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Transparent}" />
        <Setter Property="BorderThickness" Value="{DynamicResource Inset.None}" />
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.Control}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
    </Style>

    <Style x:Key="FluentQueueRowIconActionButton"
           TargetType="{x:Type Button}">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Width" Value="{DynamicResource Space.32}" />
        <Setter Property="Height" Value="{DynamicResource Space.32}" />
        <Setter Property="MinWidth" Value="{DynamicResource Space.32}" />
        <Setter Property="MinHeight" Value="{DynamicResource Space.32}" />
        <Setter Property="Padding" Value="{DynamicResource Inset.6.All}" />
        <Setter Property="Background" Value="{DynamicResource Brush.Transparent}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Transparent}" />
        <Setter Property="BorderThickness" Value="{DynamicResource Inset.1.All}" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Muted}" />
        <Setter Property="Cursor" Value="{x:Static input:Cursors.Hand}" />
        <Setter Property="Opacity" Value="0" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource FluentFocusVisualStyle}" />
        <Setter Property="ToolTipService.ShowDuration" Value="{DynamicResource ToolTip.ShowDuration.Long}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="IconButtonRoot"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{DynamicResource Radius.Control}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True"
                            UseLayoutRounding="True">
                        <Viewbox Width="{DynamicResource Space.16}"
                                 Height="{DynamicResource Space.16}"
                                 FlowDirection="LeftToRight"
                                 Stretch="Uniform"
                                 SnapsToDevicePixels="True">
                            <Path Data="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"
                                  Fill="{TemplateBinding Foreground}"
                                  Stretch="Uniform" />
                        </Viewbox>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="IconButtonRoot" Property="Background" Value="{DynamicResource Brush.Control.Fill.Hover}" />
                            <Setter Property="Foreground" Value="{DynamicResource Brush.Error}" />
                        </Trigger>

                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="IconButtonRoot" Property="Background" Value="{DynamicResource Brush.Control.Fill.Pressed}" />
                            <Setter Property="Foreground" Value="{DynamicResource Brush.Error}" />
                        </Trigger>

                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="IconButtonRoot" Property="BorderBrush" Value="{DynamicResource Brush.Control.Stroke.Focus}" />
                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="IconButtonRoot" Property="Background" Value="{DynamicResource Brush.Transparent}" />
                            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Disabled}" />
                            <Setter Property="Cursor" Value="{x:Static input:Cursors.Arrow}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

        <Style.Triggers>
            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType={x:Type DataGridRow}}}" Value="True">
                <Setter Property="Opacity" Value="1" />
            </DataTrigger>

            <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType={x:Type DataGridRow}}}" Value="True">
                <Setter Property="Opacity" Value="1" />
            </DataTrigger>

            <DataTrigger Binding="{Binding IsKeyboardFocusWithin, RelativeSource={RelativeSource AncestorType={x:Type DataGridRow}}}" Value="True">
                <Setter Property="Opacity" Value="1" />
            </DataTrigger>

            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                <Setter Property="Opacity" Value="1" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="FluentQueueCollapsibleDetailText"
           TargetType="{x:Type TextBlock}"
           BasedOn="{StaticResource FluentQueueDetailText}">
        <Setter Property="Visibility" Value="Visible" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        <Setter Property="TextWrapping" Value="Wrap" />

        <Style.Triggers>
            <DataTrigger Binding="{Binding QueueRowDisplayDetailIsVisible}" Value="False">
                <Setter Property="Visibility" Value="Collapsed" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="FluentQueueRedumpShowButton"
           TargetType="{x:Type Button}"
           BasedOn="{StaticResource FluentQueueRowSubtleActionButton}">
        <Setter Property="MinHeight" Value="{DynamicResource Space.28}" />
        <Setter Property="Padding" Value="{DynamicResource Inset.8.4}" />
        <Setter Property="Background" Value="{DynamicResource Brush.Control.Fill.Rest}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
        <Setter Property="BorderThickness" Value="{DynamicResource Inset.1.All}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FlowDirection" Value="{DynamicResource App.FlowDirection}" />
        <Setter Property="Language" Value="{DynamicResource App.XmlLanguage}" />
    </Style>

    <Style x:Key="FluentQueueMetaStrip"
           TargetType="{x:Type WrapPanel}">
        <Setter Property="FlowDirection" Value="{DynamicResource App.FlowDirection}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
    </Style>

    <Style x:Key="FluentQueuePrimaryContentColumn"
           TargetType="{x:Type Grid}">
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="FlowDirection" Value="{DynamicResource App.FlowDirection}" />
        <Setter Property="Language" Value="{DynamicResource App.XmlLanguage}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
    </Style>

    <Style x:Key="FluentQueueMetaPillSpacing"
           TargetType="{x:Type Border}"
           BasedOn="{StaticResource FluentQueueMetaPillBorder}">
        <Setter Property="Margin" Value="{DynamicResource Inset.0.0.6.0}" />
    </Style>

    <Style x:Key="FluentQueueStatusPillSpacing"
           TargetType="{x:Type Border}"
           BasedOn="{StaticResource FluentQueueStatusChipBorder}">
        <Setter Property="Margin" Value="{DynamicResource Inset.0.0.6.0}" />
    </Style>

    <DataTemplate x:Key="FluentQueueRowTemplate">
        <Grid FlowDirection="{DynamicResource App.FlowDirection}"
              Language="{DynamicResource App.XmlLanguage}"
              SnapsToDevicePixels="True"
              UseLayoutRounding="True">
            <Border Style="{StaticResource FluentQueueTaskRowCard}">
                <Grid FlowDirection="{DynamicResource App.FlowDirection}"
                      Language="{DynamicResource App.XmlLanguage}"
                      SnapsToDevicePixels="True"
                      UseLayoutRounding="True">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0"
                          FlowDirection="{DynamicResource App.FlowDirection}"
                          Language="{DynamicResource App.XmlLanguage}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="{DynamicResource Grid.Space.10}" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="{DynamicResource Grid.Space.10}" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="{DynamicResource Grid.Space.8}" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Style="{StaticResource FluentQueueFileIconTile}">
                            <Grid FlowDirection="LeftToRight"
                                  SnapsToDevicePixels="True"
                                  UseLayoutRounding="True">
                                <Viewbox Width="{DynamicResource Space.18}"
                                         Height="{DynamicResource Space.18}"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"
                                         FlowDirection="LeftToRight"
                                         Stretch="Uniform"
                                         SnapsToDevicePixels="True">
                                    <Viewbox.Style>
                                        <Style TargetType="{x:Type Viewbox}">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ShowRuntimeActivitySpinner}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Viewbox.Style>
                                    <Path Data="{StaticResource Icon.Document}"
                                          Stretch="Uniform">
                                        <Path.Style>
                                            <Style TargetType="{x:Type Path}">
                                                <Setter Property="Fill" Value="{DynamicResource Brush.Text.Muted}" />

                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType={x:Type DataGridRow}}}" Value="True">
                                                        <Setter Property="Fill" Value="{DynamicResource Brush.Accent}" />
                                                    </DataTrigger>

                                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType={x:Type DataGridRow}}}" Value="True">
                                                        <Setter Property="Fill" Value="{DynamicResource Brush.Accent}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Path.Style>
                                    </Path>
                                </Viewbox>

                                <Ellipse Width="{DynamicResource Space.18}"
                                         Height="{DynamicResource Space.18}"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"
                                         Stroke="{DynamicResource Brush.Accent}"
                                         StrokeThickness="2"
                                         StrokeDashArray="2 3"
                                         RenderTransformOrigin="0.5,0.5"
                                         Visibility="{Binding ShowRuntimeActivitySpinner, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Ellipse.RenderTransform>
                                        <RotateTransform x:Name="QueueRuntimeSpinnerRotate"
                                                         Angle="0" />
                                    </Ellipse.RenderTransform>
                                    <Ellipse.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation Storyboard.TargetName="QueueRuntimeSpinnerRotate"
                                                                     Storyboard.TargetProperty="Angle"
                                                                     From="0"
                                                                     To="360"
                                                                     Duration="0:0:1.1" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Ellipse.Triggers>
                                </Ellipse>
                            </Grid>
                        </Border>

                        <Grid Grid.Column="2"
                              Style="{StaticResource FluentQueuePrimaryContentColumn}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="{DynamicResource Grid.Space.6}" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Style="{StaticResource FluentQueuePrimaryFileText}"
                                       Text="{Binding DisplayFileName, Converter={StaticResource BidiTextConverter}, ConverterParameter=FileName}"
                                       ToolTip="{Binding FullPathTooltip, Converter={StaticResource BidiTextConverter}, ConverterParameter=Path}" />

                            <WrapPanel Grid.Row="2"
                                       Style="{StaticResource FluentQueueMetaStrip}">
                                <Border Style="{StaticResource FluentQueueStatusPillSpacing}">
                                    <TextBlock MaxWidth="{DynamicResource Queue.StatusChip.MaxWidth}"
                                               Style="{StaticResource FluentQueueStatusChipText}"
                                               Text="{Binding QueueCardBadgeTextIsolated, Converter={StaticResource BidiTextConverter}, ConverterParameter=Ui}" />
                                </Border>

                                <Border Style="{StaticResource FluentQueueMetaPillSpacing}">
                                    <TextBlock Style="{StaticResource FluentQueueMetaPillText}"
                                               MaxWidth="{DynamicResource Queue.Meta.Format.MaxWidth}"
                                               Text="{Binding DisplaySourceFormat, Converter={StaticResource BidiTextConverter}, ConverterParameter=Technical}" />
                                </Border>

                                <Border Style="{StaticResource FluentQueueMetaPillSpacing}"
                                        Visibility="{Binding HasPlatformBadge, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Style="{StaticResource FluentQueueMetaPillText}"
                                               MaxWidth="{DynamicResource Queue.Meta.Platform.MaxWidth}"
                                               Text="{Binding PlatformBadgeDisplay, Converter={StaticResource BidiTextConverter}, ConverterParameter=Mixed}" />
                                </Border>

                                <Border Style="{StaticResource FluentQueueMetaPillBorder}"
                                        Visibility="{Binding HasFileSizeBadge, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Style="{StaticResource FluentQueueMetaPillText}"
                                               Text="{Binding FileSizeDisplay, Converter={StaticResource BidiTextConverter}, ConverterParameter=Technical}" />
                                </Border>
                            </WrapPanel>
                        </Grid>

                        <Button Grid.Column="4"
                                VerticalAlignment="Center"
                                Command="{Binding DataContext.ShowRedumpDetailsCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                CommandParameter="{Binding}"
                                ToolTip="{DynamicResource LocQueue_RedumpShowDetailsTooltip}">
                            <Button.Style>
                                <Style TargetType="{x:Type Button}"
                                       BasedOn="{StaticResource FluentQueueRedumpShowButton}">
                                    <Setter Property="Visibility" Value="Collapsed" />

                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding HasRedumpResult}" Value="True" />
                                                <Condition Binding="{Binding DataContext.IsRedumpFeatureVisible, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" Value="True" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible" />
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>

                            <Grid FlowDirection="{DynamicResource App.FlowDirection}"
                                  Language="{DynamicResource App.XmlLanguage}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="{DynamicResource Grid.Space.6}" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Viewbox Grid.Column="0"
                                         Width="{DynamicResource Space.12}"
                                         Height="{DynamicResource Space.12}"
                                         VerticalAlignment="Center"
                                         FlowDirection="LeftToRight"
                                         Stretch="Uniform"
                                         SnapsToDevicePixels="True">
                                    <Path Data="{StaticResource Icon.Info}"
                                          Fill="{Binding IntegrityForegroundBrush}"
                                          Stretch="Uniform" />
                                </Viewbox>

                                <TextBlock Grid.Column="2"
                                           VerticalAlignment="Center"
                                           FlowDirection="{DynamicResource App.FlowDirection}"
                                           Language="{DynamicResource App.XmlLanguage}"
                                           FontFamily="{DynamicResource FontFamily.Base}"
                                           FontSize="{DynamicResource FontSize.Caption}"
                                           FontWeight="{DynamicResource FontWeight.SemiBold}"
                                           Foreground="{DynamicResource Brush.Text.Primary}"
                                           Text="{DynamicResource LocQueue_RedumpShowDetailsButton}"
                                           TextAlignment="{DynamicResource App.TextAlignment}"
                                           TextTrimming="CharacterEllipsis"
                                           TextWrapping="NoWrap" />
                            </Grid>
                        </Button>

                        <Button Grid.Column="6"
                                VerticalAlignment="Center"
                                Command="{Binding DataContext.RemoveQueueItemCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                CommandParameter="{Binding}"
                                Style="{StaticResource FluentQueueRowIconActionButton}"
                                Tag="{StaticResource Icon.Close}"
                                ToolTip="{DynamicResource LocCtx_Remove}" />
                    </Grid>

                    <Grid Grid.Row="1"
                          Margin="{DynamicResource Inset.0.8.0.0}"
                          FlowDirection="{DynamicResource App.FlowDirection}"
                          Language="{DynamicResource App.XmlLanguage}"
                          Visibility="{Binding UiShowIdleSurface, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="{DynamicResource Grid.Space.8}" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0"
                              MinWidth="0"
                              FlowDirection="{DynamicResource App.FlowDirection}"
                              Language="{DynamicResource App.XmlLanguage}">
                            <Border Padding="{DynamicResource Inset.10.5}"
                                    Background="{DynamicResource Brush.Control.Fill.Rest}"
                                    BorderThickness="{DynamicResource Inset.None}"
                                    CornerRadius="{DynamicResource Radius.QueueSurface}"
                                    Visibility="{Binding ShowInlineFixedAction, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock VerticalAlignment="Center"
                                           FlowDirection="{DynamicResource App.FlowDirection}"
                                           Language="{DynamicResource App.XmlLanguage}"
                                           FontFamily="{DynamicResource FontFamily.Base}"
                                           FontSize="{DynamicResource FontSize.Caption}"
                                           FontWeight="{DynamicResource FontWeight.SemiBold}"
                                           Foreground="{DynamicResource Brush.Text.Primary}"
                                           Text="{Binding SelectedOperationDisplay, Converter={StaticResource BidiTextConverter}, ConverterParameter=Ui}"
                                           TextAlignment="{DynamicResource App.TextAlignment}"
                                           TextTrimming="CharacterEllipsis"
                                           TextWrapping="NoWrap"
                                           SnapsToDevicePixels="True" />
                            </Border>

                            <Grid Visibility="{Binding ShowOperationCombo, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <ComboBox Background="{DynamicResource InputBackgroundBrush}"
                                          BorderBrush="{DynamicResource InputBorderBrush}"
                                          BorderThickness="{DynamicResource Inset.1.All}"
                                          FlowDirection="{DynamicResource App.FlowDirection}"
                                          Language="{DynamicResource App.XmlLanguage}"
                                          FontFamily="{DynamicResource FontFamily.Base}"
                                          FontSize="{DynamicResource FontSize.Caption}"
                                          Foreground="{DynamicResource InputForegroundBrush}"
                                          ItemsSource="{Binding OperationChoices}"
                                          Padding="{DynamicResource Inset.10.5}"
                                          SelectedValue="{Binding SelectedOperationBinding, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          SelectedValuePath="Code"
                                          SnapsToDevicePixels="True"
                                          TextSearch.TextPath="Label">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock FlowDirection="{DynamicResource App.FlowDirection}"
                                                       Language="{DynamicResource App.XmlLanguage}"
                                                       FontFamily="{DynamicResource FontFamily.Base}"
                                                       FontSize="{DynamicResource FontSize.Caption}"
                                                       Text="{Binding Label, Converter={StaticResource BidiTextConverter}, ConverterParameter=Ui}"
                                                       TextAlignment="{DynamicResource App.TextAlignment}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>

                                <TextBlock Margin="{DynamicResource Inset.34.0}"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False"
                                           FlowDirection="{DynamicResource App.FlowDirection}"
                                           Language="{DynamicResource App.XmlLanguage}"
                                           FontFamily="{DynamicResource FontFamily.Base}"
                                           FontSize="{DynamicResource FontSize.Caption}"
                                           Foreground="{DynamicResource Brush.Text.Secondary}"
                                           Text="{DynamicResource LocQueue_Label_ChooseAction}"
                                           TextAlignment="{DynamicResource App.TextAlignment}"
                                           TextTrimming="CharacterEllipsis"
                                           Visibility="{Binding ShowActionPlaceholder, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            </Grid>
                        </Grid>

                        <Button Grid.Column="2"
                                MinHeight="{DynamicResource Space.32}"
                                Padding="{DynamicResource Inset.12.7}"
                                FlowDirection="{DynamicResource App.FlowDirection}"
                                Language="{DynamicResource App.XmlLanguage}"
                                Command="{Binding DataContext.VerifyRowRedumpCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                CommandParameter="{Binding}"
                                ToolTip="{DynamicResource LocQueue_RedumpVerifyTooltip}"
                                ToolTipService.ShowOnDisabled="True">
                            <Button.Style>
                                <Style TargetType="{x:Type Button}"
                                       BasedOn="{StaticResource FluentQueueRowSubtleActionButton}">
                                    <Setter Property="Visibility" Value="Collapsed" />

                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DataContext.IsRedumpFeatureVisible, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>

                                        <DataTrigger Binding="{Binding IntegrityState}" Value="Validating">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>

                            <Grid FlowDirection="{DynamicResource App.FlowDirection}"
                                  Language="{DynamicResource App.XmlLanguage}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="{DynamicResource Grid.Space.6}" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Viewbox Grid.Column="0"
                                         Width="{DynamicResource Space.14}"
                                         Height="{DynamicResource Space.14}"
                                         VerticalAlignment="Center"
                                         FlowDirection="LeftToRight"
                                         Stretch="Uniform"
                                         SnapsToDevicePixels="True">
                                    <Path Data="{StaticResource Icon.DatabaseSearch}"
                                          Fill="{DynamicResource Brush.Accent}"
                                          Stretch="Uniform" />
                                </Viewbox>

                                <TextBlock Grid.Column="2"
                                           VerticalAlignment="Center"
                                           FlowDirection="{DynamicResource App.FlowDirection}"
                                           Language="{DynamicResource App.XmlLanguage}"
                                           FontFamily="{DynamicResource FontFamily.Base}"
                                           FontSize="{DynamicResource FontSize.Caption}"
                                           FontWeight="{DynamicResource FontWeight.SemiBold}"
                                           Foreground="{DynamicResource Brush.Text.Primary}"
                                           Text="{DynamicResource LocQueue_RedumpVerifyButton}"
                                           TextAlignment="{DynamicResource App.TextAlignment}"
                                           TextTrimming="CharacterEllipsis"
                                           TextWrapping="NoWrap"
                                           SnapsToDevicePixels="True" />
                            </Grid>
                        </Button>
                    </Grid>

                    <Border Grid.Row="2"
                            Margin="{DynamicResource Inset.0.8.0.0}"
                            Padding="{DynamicResource Inset.None}"
                            ToolTip="{DynamicResource LocUi_QueueProgressPanelTooltip}"
                            Visibility="{Binding UiShowProgressRow, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid FlowDirection="{DynamicResource TechnicalText.FlowDirection}"
                              Language="{DynamicResource TechnicalText.Language}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="{DynamicResource Grid.Space.10}" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <ProgressBar Grid.Column="0"
                                         VerticalAlignment="Center"
                                         Maximum="{DynamicResource Progress.Maximum}"
                                         Minimum="{DynamicResource Progress.Minimum}"
                                         IsIndeterminate="{Binding IsIndeterminate}"
                                         Style="{StaticResource FluentQueueCardProgressBar}"
                                         Value="{Binding ProgressBarDisplayValue, Mode=OneWay}" />

                            <TextBlock Grid.Column="2"
                                       VerticalAlignment="Center"
                                       FlowDirection="{DynamicResource TechnicalText.FlowDirection}"
                                       Language="{DynamicResource TechnicalText.Language}"
                                       FontFamily="{DynamicResource FontFamily.Base}"
                                       FontSize="{DynamicResource FontSize.Caption}"
                                       FontWeight="{DynamicResource FontWeight.SemiBold}"
                                       Foreground="{DynamicResource Brush.Progress.Fill}"
                                       MinWidth="{DynamicResource Space.48}"
                                       Visibility="{Binding ShowProgressPercent, Converter={StaticResource BooleanToVisibilityConverter}}"
                                       Text="{Binding ProgressPercentDisplay, Converter={StaticResource BidiTextConverter}, ConverterParameter=Technical}"
                                       TextAlignment="{DynamicResource TechnicalText.TextAlignment}"
                                       TextWrapping="NoWrap"
                                       SnapsToDevicePixels="True" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="3"
                            Margin="{DynamicResource Inset.0.8.0.0}"
                            Visibility="{Binding UiShowRunningActionsRow, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid FlowDirection="{DynamicResource App.FlowDirection}"
                              Language="{DynamicResource App.XmlLanguage}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="{DynamicResource Grid.Space.10}" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0"
                                  MinWidth="0"
                                  FlowDirection="{DynamicResource App.FlowDirection}"
                                  Language="{DynamicResource App.XmlLanguage}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                                           FlowDirection="{DynamicResource App.FlowDirection}"
                                           Language="{DynamicResource App.XmlLanguage}"
                                           FontFamily="{DynamicResource FontFamily.Base}"
                                           FontSize="{DynamicResource FontSize.CaptionSmall}"
                                           FontWeight="{DynamicResource FontWeight.SemiBold}"
                                           Foreground="{DynamicResource Brush.Text.Secondary}"
                                           Text="{Binding ProgressRegionPhaseIsolated, Converter={StaticResource BidiTextConverter}, ConverterParameter=Ui}"
                                           TextAlignment="{DynamicResource App.TextAlignment}"
                                           TextTrimming="CharacterEllipsis"
                                           TextWrapping="NoWrap"
                                           ToolTip="{Binding ProgressRegionPhaseIsolated}"
                                           SnapsToDevicePixels="True" />

                                <Grid Grid.Row="1"
                                      Margin="{DynamicResource Inset.0.2.0.0}"
                                      FlowDirection="{DynamicResource App.FlowDirection}"
                                      Language="{DynamicResource App.XmlLanguage}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="{DynamicResource Grid.Space.8}" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               MaxHeight="{DynamicResource Space.48}"
                                               Style="{StaticResource FluentQueueCollapsibleDetailText}"
                                               Text="{Binding QueueRowDisplayDetailArabic, Converter={StaticResource BidiTextConverter}, ConverterParameter=Ui}"
                                               ToolTip="{Binding QueueRowExtendedTooltip}" />

                                    <TextBlock Grid.Column="2"
                                               Width="{DynamicResource Space.0}"
                                               Visibility="Collapsed"
                                               Style="{StaticResource FluentQueueActivityDotsText}"
                                               ToolTip="{Binding QueueRowExtendedTooltip}" />
                                </Grid>
                            </Grid>

                            <Grid Grid.Column="2"
                                  VerticalAlignment="Center"
                                  FlowDirection="{DynamicResource App.FlowDirection}"
                                  Language="{DynamicResource App.XmlLanguage}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="{DynamicResource Grid.Space.6}" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0"
                                        Command="{Binding DataContext.OpenFolderCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                        CommandParameter="{Binding}"
                                        Content="{DynamicResource LocUi_QueueRowOpen}"
                                        Style="{StaticResource FluentQueueRowSubtleActionButton}"
                                        ToolTip="{DynamicResource LocCtx_OpenPath}" />

                                <Button Grid.Column="2"
                                        Command="{Binding DataContext.CancelQueueJobCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                        CommandParameter="{Binding}"
                                        Content="{DynamicResource LocUi_QueueRowCancel}"
                                        Style="{StaticResource FluentQueueRowSubtleActionButton}"
                                        ToolTip="{DynamicResource LocCtx_CancelJob}" />
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Grid.Row="3"
                            Margin="{DynamicResource Inset.0.8.0.0}"
                            Visibility="{Binding UiShowTerminalActionsRow, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid FlowDirection="{DynamicResource App.FlowDirection}"
                              Language="{DynamicResource App.XmlLanguage}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="{DynamicResource Grid.Space.10}" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       VerticalAlignment="Center"
                                       MaxHeight="{DynamicResource Space.48}"
                                       Style="{StaticResource FluentQueueCollapsibleDetailText}"
                                       Text="{Binding QueueRowDisplayDetailArabic, Converter={StaticResource BidiTextConverter}, ConverterParameter=Ui}"
                                       ToolTip="{Binding QueueRowExtendedTooltip}" />

                            <Grid Grid.Row="0"
                                  Grid.RowSpan="2"
                                  Grid.Column="2"
                                  VerticalAlignment="Center"
                                  FlowDirection="{DynamicResource App.FlowDirection}"
                                  Language="{DynamicResource App.XmlLanguage}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="{DynamicResource Grid.Space.6}" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="{DynamicResource Grid.Space.6}" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="{DynamicResource Grid.Space.6}" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0"
                                        Command="{Binding DataContext.OpenFolderCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                        CommandParameter="{Binding}"
                                        Content="{DynamicResource LocUi_QueueRowOpen}"
                                        Style="{StaticResource FluentQueueRowSubtleActionButton}"
                                        ToolTip="{DynamicResource LocCtx_OpenPath}" />

                                <Border Grid.Column="2"
                                        Style="{StaticResource FluentQueueMetaPillBorder}"
                                        Visibility="{Binding HasVerificationResult, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Style="{StaticResource FluentQueueMetaPillText}"
                                               FlowDirection="{DynamicResource App.FlowDirection}"
                                               Language="{DynamicResource App.XmlLanguage}"
                                               TextAlignment="{DynamicResource AdvancedOptions.SettingsTextAlignment}"
                                               Text="{Binding VerificationResultBadgeText, Converter={StaticResource BidiTextConverter}, ConverterParameter=Ui}" />
                                </Border>

                                <Button Grid.Column="4"
                                        Command="{Binding DataContext.OpenOperationLogCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                        CommandParameter="{Binding}"
                                        Content="{DynamicResource LocQueue_VerificationResultButton}"
                                        ToolTip="{DynamicResource LocQueue_VerificationResultTooltip}">
                                    <Button.Style>
                                        <Style TargetType="{x:Type Button}"
                                               BasedOn="{StaticResource FluentQueueRowSubtleActionButton}">
                                            <Setter Property="Visibility" Value="Collapsed" />

                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasVerificationResult}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <Button Grid.Column="6"
                                        Command="{Binding DataContext.RetryQueueItemCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                        CommandParameter="{Binding}"
                                        Content="{DynamicResource LocCtx_Retry}">
                                    <Button.Style>
                                        <Style TargetType="{x:Type Button}"
                                               BasedOn="{StaticResource FluentQueueRowSubtleActionButton}">
                                            <Setter Property="Visibility" Value="Collapsed" />

                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding QueueRowDisplayState}" Value="Failed">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Grid.Row="4"
                            Margin="{DynamicResource Inset.0.8.0.0}"
                            Padding="{DynamicResource Inset.10.6}"
                            Background="{DynamicResource Brush.Accent.Subtle}"
                            BorderBrush="{DynamicResource Brush.Transparent}"
                            BorderThickness="{DynamicResource Inset.None}"
                            CornerRadius="{DynamicResource Radius.Control}"
                            ToolTip="{DynamicResource LocQueue_RedumpValidatingTooltip}">
                        <Border.Style>
                            <Style TargetType="{x:Type Border}">
                                <Setter Property="Visibility" Value="Collapsed" />

                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IntegrityState}" Value="Validating" />
                                            <Condition Binding="{Binding DataContext.IsRedumpFeatureVisible, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" Value="True" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible" />
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        <Grid FlowDirection="{DynamicResource App.FlowDirection}"
                              Language="{DynamicResource App.XmlLanguage}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0"
                                  FlowDirection="{DynamicResource App.FlowDirection}"
                                  Language="{DynamicResource App.XmlLanguage}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="{DynamicResource Grid.Space.8}" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Viewbox Grid.Column="0"
                                         Width="{DynamicResource Space.14}"
                                         Height="{DynamicResource Space.14}"
                                         VerticalAlignment="Center"
                                         FlowDirection="LeftToRight"
                                         Stretch="Uniform"
                                         SnapsToDevicePixels="True">
                                    <Path Data="{StaticResource Icon.DatabaseSearch}"
                                          Fill="{DynamicResource Brush.Accent}"
                                          Stretch="Uniform" />
                                </Viewbox>

                                <TextBlock Grid.Column="2"
                                           VerticalAlignment="Center"
                                           FlowDirection="{DynamicResource App.FlowDirection}"
                                           Language="{DynamicResource App.XmlLanguage}"
                                           FontFamily="{DynamicResource FontFamily.Base}"
                                           FontSize="{DynamicResource FontSize.Caption}"
                                           FontWeight="{DynamicResource FontWeight.SemiBold}"
                                           Foreground="{DynamicResource Brush.Accent}"
                                           Text="{DynamicResource LocQueue_RedumpValidatingTitle}"
                                           TextAlignment="{DynamicResource App.TextAlignment}"
                                           TextTrimming="CharacterEllipsis"
                                           TextWrapping="NoWrap"
                                           SnapsToDevicePixels="True" />
                            </Grid>

                            <ProgressBar Grid.Row="1"
                                         Margin="{DynamicResource Inset.0.6.0.0}"
                                         Height="{DynamicResource Space.4}"
                                         FlowDirection="LeftToRight"
                                         Background="{DynamicResource Brush.Progress.Track}"
                                         Foreground="{DynamicResource Brush.Accent}"
                                         BorderThickness="{DynamicResource Inset.None}"
                                         IsIndeterminate="True" />
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </DataTemplate>

</ResourceDictionary>