<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/Resources/Style/Queue/QueueItemBaseStyles.xaml" />
        <ResourceDictionary Source="/Resources/Style/Queue/QueueWorkspaceSharedStyles.xaml" />
        <ResourceDictionary Source="/Resources/Style/Queue/QueueItemHeaderTemplate.xaml" />
        <ResourceDictionary Source="/Resources/Style/Queue/QueueItemStatusTemplate.xaml" />
        <ResourceDictionary Source="/Resources/Style/Queue/QueueItemProgressTemplate.xaml" />
        <ResourceDictionary Source="/Resources/Style/Queue/QueueItemActionsTemplate.xaml" />
        <ResourceDictionary Source="/Resources/Style/Queue/QueueItemTechnicalFieldsTemplate.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <DataTemplate x:Key="FluentQueueRowTemplate">
        <Grid FlowDirection="{DynamicResource App.FlowDirection}"
              Language="{DynamicResource App.XmlLanguage}"
              SnapsToDevicePixels="True"
              UseLayoutRounding="True">
            <Border Style="{StaticResource FluentQueueTaskRowCard}">
                <Grid FlowDirection="{DynamicResource App.FlowDirection}"
                      Language="{DynamicResource App.XmlLanguage}"
                      SnapsToDevicePixels="True"
                      UseLayoutRounding="True">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <ContentControl Grid.Row="0"
                                    Content="{Binding}"
                                    ContentTemplate="{StaticResource QueueItemHeaderFieldsTemplate}"
                                    Focusable="False" />

                    <ContentControl Grid.Row="1"
                                    Content="{Binding}"
                                    ContentTemplate="{StaticResource QueueItemStatusFieldsTemplate}"
                                    Focusable="False" />

                    <ContentControl Grid.Row="2"
                                    Content="{Binding}"
                                    ContentTemplate="{StaticResource QueueItemProgressFieldsTemplate}"
                                    Focusable="False" />

                    <ContentControl Grid.Row="3"
                                    Content="{Binding}"
                                    ContentTemplate="{StaticResource QueueItemActionsFieldsTemplate}"
                                    Focusable="False" />

                    <ContentControl Grid.Row="4"
                                    Content="{Binding}"
                                    ContentTemplate="{StaticResource QueueItemTechnicalFieldsTemplate}"
                                    Focusable="False" />
                </Grid>
            </Border>
        </Grid>
    </DataTemplate>

</ResourceDictionary>