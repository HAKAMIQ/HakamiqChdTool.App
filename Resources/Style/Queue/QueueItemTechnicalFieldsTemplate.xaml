<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/Resources/Style/Queue/QueueItemBaseStyles.xaml" />
        <ResourceDictionary Source="/Resources/Style/Queue/QueueWorkspaceSharedStyles.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <DataTemplate x:Key="QueueItemTechnicalFieldsTemplate">
        <Border Margin="{DynamicResource Inset.0.8.0.0}"
                ToolTip="{DynamicResource LocQueue_RedumpValidatingTooltip}">
            <Border.Style>
                <Style TargetType="{x:Type Border}"
                       BasedOn="{StaticResource FluentQueueInlineSurfaceBorder}">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Setter Property="Padding" Value="{DynamicResource Inset.10.6}" />
                    <Setter Property="Background" Value="{DynamicResource Brush.Accent.Subtle}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
                    <Setter Property="BorderThickness" Value="{DynamicResource Inset.1.All}" />
                    <Setter Property="CornerRadius" Value="{DynamicResource Radius.QueueSurface}" />
                    <Setter Property="TextElement.Foreground" Value="{DynamicResource Brush.Text.Primary}" />
                    <Setter Property="SnapsToDevicePixels" Value="True" />
                    <Setter Property="UseLayoutRounding" Value="True" />

                    <Style.Triggers>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding IntegrityState}" Value="Validating" />
                                <Condition Binding="{Binding DataContext.IsRedumpFeatureVisible, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" Value="True" />
                            </MultiDataTrigger.Conditions>

                            <Setter Property="Visibility" Value="Visible" />
                        </MultiDataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <Grid FlowDirection="{DynamicResource App.FlowDirection}"
                  Language="{DynamicResource App.XmlLanguage}"
                  SnapsToDevicePixels="True"
                  UseLayoutRounding="True">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0"
                      FlowDirection="{DynamicResource App.FlowDirection}"
                      Language="{DynamicResource App.XmlLanguage}"
                      SnapsToDevicePixels="True"
                      UseLayoutRounding="True">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="{DynamicResource Grid.Space.8}" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Viewbox Grid.Column="0"
                             Width="{DynamicResource Space.14}"
                             Height="{DynamicResource Space.14}"
                             VerticalAlignment="Center"
                             FlowDirection="LeftToRight"
                             Stretch="Uniform"
                             SnapsToDevicePixels="True">
                        <Path Data="{StaticResource Icon.DatabaseSearch}"
                              Fill="{DynamicResource Brush.Accent}"
                              Stretch="Uniform"
                              SnapsToDevicePixels="True" />
                    </Viewbox>

                    <TextBlock Grid.Column="2"
                               VerticalAlignment="Center"
                               FlowDirection="{DynamicResource App.FlowDirection}"
                               Language="{DynamicResource App.XmlLanguage}"
                               FontFamily="{DynamicResource FontFamily.Base}"
                               FontSize="{DynamicResource FontSize.Caption}"
                               FontWeight="{DynamicResource FontWeight.SemiBold}"
                               Foreground="{DynamicResource Brush.Accent}"
                               Text="{DynamicResource LocQueue_RedumpValidatingTitle}"
                               TextAlignment="{DynamicResource App.DefaultTextAlignment}"
                               TextTrimming="CharacterEllipsis"
                               TextWrapping="NoWrap"
                               SnapsToDevicePixels="True"
                               UseLayoutRounding="True" />
                </Grid>

                <ProgressBar Grid.Row="1"
                             Margin="{DynamicResource Inset.0.6.0.0}"
                             FlowDirection="LeftToRight"
                             IsIndeterminate="True"
                             Style="{StaticResource FluentQueueCardProgressBar}" />
            </Grid>
        </Border>
    </DataTemplate>

</ResourceDictionary>
