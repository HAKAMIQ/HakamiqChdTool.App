<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="FluentSidebarSectionCard" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="{DynamicResource Brush.Card}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Transparent}" />
        <Setter Property="BorderThickness" Value="{DynamicResource Inset.None}" />
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.Card}" />
        <Setter Property="Padding" Value="{DynamicResource Inset.16.All}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
    </Style>

    <Style x:Key="FluentWorkspaceCard" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="{DynamicResource Brush.Layer.Card}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
        <Setter Property="BorderThickness" Value="{DynamicResource Inset.1.All}" />
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.Card}" />
        <Setter Property="Padding" Value="{DynamicResource Inset.None}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
    </Style>

    <Style x:Key="FluentMiniStatCard" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="{DynamicResource Brush.Layer.Card}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
        <Setter Property="BorderThickness" Value="{DynamicResource Inset.1.All}" />
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.Card}" />
        <Setter Property="Padding" Value="{DynamicResource Inset.18.All}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
    </Style>

    <Style x:Key="FluentActionCard"
           TargetType="{x:Type Border}"
           BasedOn="{StaticResource FluentMiniStatCard}">
        <Setter Property="Background" Value="{DynamicResource Brush.Layer.Card}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Transparent}" />
        <Setter Property="BorderThickness" Value="{DynamicResource Inset.None}" />
        <Setter Property="Padding" Value="{DynamicResource Inset.18.All}" />
    </Style>

    <Style x:Key="FluentToolsCard"
           TargetType="{x:Type Border}"
           BasedOn="{StaticResource FluentActionCard}">
        <Setter Property="Padding" Value="{DynamicResource Inset.18.All}" />
    </Style>

    <Style x:Key="FluentProcessingActionCard"
           TargetType="{x:Type Border}"
           BasedOn="{StaticResource FluentMiniStatCard}">
        <Setter Property="Background" Value="{DynamicResource Brush.Layer.Card}" />
        <Setter Property="Padding" Value="{DynamicResource Inset.14.12}" />
    </Style>

    <Style x:Key="FluentFooterStatusStrip" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="{DynamicResource Brush.Layer.Card}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
        <Setter Property="BorderThickness" Value="{DynamicResource Inset.0.1.0.0}" />
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.None}" />
        <Setter Property="Padding" Value="{DynamicResource Inset.16.10}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
    </Style>

    <Style x:Key="FluentSidePanelCard"
           TargetType="{x:Type Border}"
           BasedOn="{StaticResource FluentSidebarSectionCard}">
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.Card}" />
        <Setter Property="Padding" Value="{DynamicResource Inset.16.All}" />
        <Setter Property="BorderThickness" Value="{DynamicResource Inset.None}" />
    </Style>

    <Style x:Key="FluentSettingsSummaryLabel" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="{DynamicResource FontSize.CaptionSmall}" />
        <Setter Property="FontWeight" Value="{DynamicResource FontWeight.SemiBold}" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
        <Setter Property="Margin" Value="{DynamicResource Inset.0.0.0.4}" />
        <Setter Property="FlowDirection" Value="{DynamicResource App.FlowDirection}" />
        <Setter Property="Language" Value="{DynamicResource App.XmlLanguage}" />
        <Setter Property="TextAlignment" Value="{DynamicResource App.TextAlignment}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style x:Key="FluentSettingsSummaryValue" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="{DynamicResource FontSize.Caption}" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="FlowDirection" Value="{DynamicResource App.FlowDirection}" />
        <Setter Property="Language" Value="{DynamicResource App.XmlLanguage}" />
        <Setter Property="TextAlignment" Value="{DynamicResource App.TextAlignment}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style x:Key="FluentWorkflowFactCard" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="{DynamicResource Brush.Surface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Transparent}" />
        <Setter Property="BorderThickness" Value="{DynamicResource Inset.None}" />
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.Control}" />
        <Setter Property="Padding" Value="{DynamicResource Inset.12.10}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
    </Style>

    <Style x:Key="FluentWorkflowFactLabel"
           TargetType="{x:Type TextBlock}"
           BasedOn="{StaticResource FluentSettingsSummaryLabel}">
        <Setter Property="Margin" Value="{DynamicResource Inset.0.0.0.8}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSize.Micro}" />
        <Setter Property="FontWeight" Value="{DynamicResource FontWeight.SemiBold}" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Muted}" />
    </Style>

    <Style x:Key="FluentWorkflowFactValue"
           TargetType="{x:Type TextBlock}"
           BasedOn="{StaticResource FluentSettingsSummaryValue}">
        <Setter Property="FontSize" Value="{DynamicResource FontSize.Caption}" />
        <Setter Property="LineHeight" Value="{DynamicResource Text.LineHeight.FactValue}" />
    </Style>

    <Style x:Key="FluentFooterSessionCapsule" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="{DynamicResource Brush.Layer.Card}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
        <Setter Property="BorderThickness" Value="{DynamicResource Inset.0.1.0.0}" />
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.None}" />
        <Setter Property="Padding" Value="{DynamicResource Inset.16.10}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
    </Style>

    <Style x:Key="FluentHeaderThemeCluster" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="{DynamicResource Brush.Control.Fill.Rest}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Transparent}" />
        <Setter Property="BorderThickness" Value="{DynamicResource Inset.None}" />
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.HeaderCluster}" />
        <Setter Property="Padding" Value="{DynamicResource Inset.4.All}" />
        <Setter Property="TextElement.Foreground" Value="{DynamicResource Brush.Text.Primary}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
    </Style>

    <Style x:Key="FluentHeaderTitleText" TargetType="{x:Type TextBlock}">
        <Setter Property="FontFamily" Value="{DynamicResource HeaderEnglishFont}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSize.HeaderTitle}" />
        <Setter Property="FontWeight" Value="{DynamicResource FontWeight.SemiBold}" />
        <Setter Property="Foreground" Value="{DynamicResource HeaderChromeForegroundBrush}" />
        <Setter Property="FlowDirection" Value="{DynamicResource App.FlowDirection}" />
        <Setter Property="Language" Value="{DynamicResource App.XmlLanguage}" />
        <Setter Property="TextAlignment" Value="{DynamicResource App.TextAlignment}" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        <Setter Property="TextWrapping" Value="NoWrap" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style x:Key="FluentHeaderSubtitleText" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="{DynamicResource FontSize.Micro}" />
        <Setter Property="Foreground" Value="{DynamicResource HeaderChromeMutedForegroundBrush}" />
        <Setter Property="FlowDirection" Value="{DynamicResource App.FlowDirection}" />
        <Setter Property="Language" Value="{DynamicResource App.XmlLanguage}" />
        <Setter Property="TextAlignment" Value="{DynamicResource App.TextAlignment}" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        <Setter Property="TextWrapping" Value="NoWrap" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style x:Key="FluentSectionTitleText" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="{DynamicResource FontSize.SectionTitle}" />
        <Setter Property="FontWeight" Value="{DynamicResource FontWeight.SemiBold}" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
        <Setter Property="FlowDirection" Value="{DynamicResource App.FlowDirection}" />
        <Setter Property="Language" Value="{DynamicResource App.XmlLanguage}" />
        <Setter Property="TextAlignment" Value="{DynamicResource App.TextAlignment}" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        <Setter Property="TextWrapping" Value="NoWrap" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style x:Key="HakamiqSettingsPanelCard"
           TargetType="{x:Type Border}"
           BasedOn="{StaticResource FluentWorkspaceCard}">
        <Setter Property="Padding" Value="{DynamicResource Inset.16.All}" />
        <Setter Property="Background" Value="{DynamicResource Brush.Surface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Transparent}" />
        <Setter Property="BorderThickness" Value="{DynamicResource Inset.None}" />
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.Card}" />
        <Setter Property="TextElement.Foreground" Value="{DynamicResource Brush.Text.Primary}" />
    </Style>

    <Style x:Key="HakamiqSettingsCard"
           TargetType="{x:Type Border}"
           BasedOn="{StaticResource FluentActionCard}">
        <Setter Property="Background" Value="{DynamicResource Brush.Card}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Transparent}" />
        <Setter Property="BorderThickness" Value="{DynamicResource Inset.None}" />
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.Card}" />
        <Setter Property="Padding" Value="{DynamicResource Inset.16.All}" />
        <Setter Property="MinHeight" Value="{DynamicResource Space.120}" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="TextElement.Foreground" Value="{DynamicResource Brush.Text.Primary}" />
    </Style>

    <Style x:Key="HakamiqSettingsCardTitle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="{DynamicResource FontSize.BodyStrong}" />
        <Setter Property="FontWeight" Value="{DynamicResource FontWeight.SemiBold}" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
        <Setter Property="FlowDirection" Value="{DynamicResource App.FlowDirection}" />
        <Setter Property="Language" Value="{DynamicResource App.XmlLanguage}" />
        <Setter Property="TextAlignment" Value="{DynamicResource App.TextAlignment}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style x:Key="HakamiqSettingsCardDescription" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="{DynamicResource FontSize.Caption}" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
        <Setter Property="FlowDirection" Value="{DynamicResource App.FlowDirection}" />
        <Setter Property="Language" Value="{DynamicResource App.XmlLanguage}" />
        <Setter Property="TextAlignment" Value="{DynamicResource App.TextAlignment}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

</ResourceDictionary>