<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="CardBaseStyle"
           TargetType="{x:Type Border}">
        <Setter Property="BorderThickness" Value="{DynamicResource Inset.1.All}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="FlowDirection" Value="{DynamicResource App.FlowDirection}" />
    </Style>

    <Style x:Key="RootWindowCardStyle"
           TargetType="{x:Type Border}"
           BasedOn="{StaticResource CardBaseStyle}">
        <Setter Property="Background" Value="{DynamicResource Brush.Layer.Canvas}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Transparent}" />
        <Setter Property="BorderThickness" Value="{DynamicResource Inset.None}" />
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.Window}" />
        <Setter Property="Padding" Value="{DynamicResource Inset.None}" />
    </Style>

    <Style x:Key="RootCardStyle"
           TargetType="{x:Type Border}"
           BasedOn="{StaticResource RootWindowCardStyle}" />

    <Style x:Key="PanelCardStyle"
           TargetType="{x:Type Border}"
           BasedOn="{StaticResource CardBaseStyle}">
        <Setter Property="Background" Value="{DynamicResource Brush.Layer.Surface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.Card.Large}" />
        <Setter Property="Padding" Value="{DynamicResource Inset.14.12}" />
    </Style>

    <Style x:Key="InnerCardStyle"
           TargetType="{x:Type Border}"
           BasedOn="{StaticResource CardBaseStyle}">
        <Setter Property="Background" Value="{DynamicResource Brush.Layer.Surface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.Card.Medium}" />
        <Setter Property="Padding" Value="{DynamicResource Inset.12.10}" />
    </Style>

    <Style x:Key="ElevatedCardStyle"
           TargetType="{x:Type Border}"
           BasedOn="{StaticResource CardBaseStyle}">
        <Setter Property="Background" Value="{DynamicResource Brush.Layer.Card}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.Card.Large}" />
        <Setter Property="Padding" Value="{DynamicResource Inset.14.12}" />
    </Style>

    <Style x:Key="InteractiveCardStyle"
           TargetType="{x:Type Border}"
           BasedOn="{StaticResource CardBaseStyle}">
        <Setter Property="Background" Value="{DynamicResource Brush.Layer.Card}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.Card.Large}" />
        <Setter Property="Padding" Value="{DynamicResource Inset.14.12}" />

        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource Brush.Control.Fill.Hover}" />
                <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="PopoverCardStyle"
           TargetType="{x:Type Border}"
           BasedOn="{StaticResource CardBaseStyle}">
        <Setter Property="Background" Value="{DynamicResource Brush.Layer.Elevated}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.Card.Medium}" />
        <Setter Property="Padding" Value="{DynamicResource Inset.8.All}" />
    </Style>

    <Style x:Key="DialogCardStyle"
           TargetType="{x:Type Border}"
           BasedOn="{StaticResource CardBaseStyle}">
        <Setter Property="Background" Value="{DynamicResource Brush.Layer.Card}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.Card.Dialog}" />
        <Setter Property="Padding" Value="{DynamicResource Inset.20.16}" />
    </Style>

</ResourceDictionary>