<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:input="clr-namespace:System.Windows.Input;assembly=PresentationCore">

	<Style x:Key="FluentQueueTaskRowCard" TargetType="{x:Type Border}">
		<Setter Property="Margin" Value="{DynamicResource Inset.0.0.0.4}" />
		<Setter Property="Padding" Value="{DynamicResource Inset.8.All}" />
		<Setter Property="Background" Value="{DynamicResource Brush.Transparent}" />
		<Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
		<Setter Property="BorderThickness" Value="{DynamicResource Inset.0.0.0.1}" />
		<Setter Property="CornerRadius" Value="{DynamicResource Radius.None}" />
		<Setter Property="SnapsToDevicePixels" Value="True" />
		<Setter Property="UseLayoutRounding" Value="True" />
		<Style.Triggers>
			<DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType={x:Type DataGridRow}}}" Value="True">
				<Setter Property="Background" Value="{DynamicResource Brush.Layer.Elevated}" />
				<Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
			</DataTrigger>

			<DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType={x:Type DataGridRow}}}" Value="True">
				<Setter Property="Background" Value="{DynamicResource Brush.Accent.SelectedBackground}" />
				<Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent.SelectedBorder}" />
			</DataTrigger>
		</Style.Triggers>
	</Style>

	<Style x:Key="FluentQueueProgressPanelBorder" TargetType="{x:Type Border}">
		<Setter Property="Padding" Value="{DynamicResource Inset.None}" />
		<Setter Property="Background" Value="{x:Null}" />
		<Setter Property="BorderThickness" Value="{DynamicResource Inset.None}" />
		<Setter Property="CornerRadius" Value="{DynamicResource Radius.None}" />
		<Setter Property="SnapsToDevicePixels" Value="True" />
		<Setter Property="UseLayoutRounding" Value="True" />
	</Style>

	<Style x:Key="FluentQueueCardProgressBar" TargetType="{x:Type ProgressBar}">
		<Setter Property="Height" Value="{DynamicResource Space.8}" />
		<Setter Property="MinHeight" Value="{DynamicResource Space.8}" />
		<Setter Property="Background" Value="{DynamicResource QueueProgressTrackBrush}" />
		<Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
		<Setter Property="BorderThickness" Value="{DynamicResource Inset.1.All}" />
		<Setter Property="Foreground" Value="{DynamicResource QueueProgressFillBrush}" />
		<Setter Property="SnapsToDevicePixels" Value="True" />
		<Setter Property="UseLayoutRounding" Value="True" />
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="{x:Type ProgressBar}">
					<Border x:Name="TemplateRoot"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{DynamicResource Radius.None}"
                            ClipToBounds="True"
                            SnapsToDevicePixels="True"
                            UseLayoutRounding="True">
						<Grid SnapsToDevicePixels="True"
                              UseLayoutRounding="True">
							<Border x:Name="PART_Track"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="{DynamicResource Radius.None}"
                                    SnapsToDevicePixels="True" />

							<Border x:Name="PART_Indicator"
                                    HorizontalAlignment="Left"
                                    Background="{TemplateBinding Foreground}"
                                    CornerRadius="{DynamicResource Radius.None}"
                                    SnapsToDevicePixels="True" />
						</Grid>
					</Border>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>

	<Style x:Key="FluentQueueActivityDotsText" TargetType="{x:Type TextBlock}">
		<Setter Property="VerticalAlignment" Value="Center" />
		<Setter Property="FontSize" Value="{DynamicResource FontSize.Caption}" />
		<Setter Property="FontWeight" Value="{DynamicResource FontWeight.SemiBold}" />
		<Setter Property="Foreground" Value="{DynamicResource Brush.Accent}" />
		<Setter Property="Text" Value="•••" />
		<Setter Property="TextAlignment" Value="Center" />
		<Setter Property="FlowDirection" Value="LeftToRight" />
		<Setter Property="Language" Value="en-US" />
		<Setter Property="IsHitTestVisible" Value="False" />
		<Setter Property="SnapsToDevicePixels" Value="True" />
	</Style>

	<Style x:Key="FluentQueueStatusChipBorder" TargetType="{x:Type Border}">
		<Setter Property="Padding" Value="{DynamicResource Inset.10.5}" />
		<Setter Property="CornerRadius" Value="{DynamicResource Radius.Control}" />
		<Setter Property="BorderThickness" Value="{DynamicResource Inset.None}" />
		<Setter Property="Background" Value="{DynamicResource NeutralBadgeBrush}" />
		<Setter Property="BorderBrush" Value="{DynamicResource Brush.Transparent}" />
		<Setter Property="SnapsToDevicePixels" Value="True" />
		<Setter Property="UseLayoutRounding" Value="True" />
		<Style.Triggers>
			<DataTrigger Binding="{Binding QueueRowDisplayState}" Value="Processing">
				<Setter Property="Background" Value="{DynamicResource ActiveBadgeBrush}" />
			</DataTrigger>
			<DataTrigger Binding="{Binding QueueRowDisplayState}" Value="Extracting">
				<Setter Property="Background" Value="{DynamicResource ActiveBadgeBrush}" />
			</DataTrigger>
			<DataTrigger Binding="{Binding QueueRowDisplayState}" Value="Converting">
				<Setter Property="Background" Value="{DynamicResource ActiveBadgeBrush}" />
			</DataTrigger>
			<DataTrigger Binding="{Binding QueueRowDisplayState}" Value="Verifying">
				<Setter Property="Background" Value="{DynamicResource ActiveBadgeBrush}" />
			</DataTrigger>
			<DataTrigger Binding="{Binding QueueRowDisplayState}" Value="ReadingFile">
				<Setter Property="Background" Value="{DynamicResource ActiveBadgeBrush}" />
			</DataTrigger>
			<MultiDataTrigger>
				<MultiDataTrigger.Conditions>
					<Condition Binding="{Binding QueueRowDisplayState}" Value="Completed" />
					<Condition Binding="{Binding QueueRowDisplayFinalResult}" Value="Healthy" />
				</MultiDataTrigger.Conditions>
				<Setter Property="Background" Value="{DynamicResource SuccessBadgeBrush}" />
			</MultiDataTrigger>
			<MultiDataTrigger>
				<MultiDataTrigger.Conditions>
					<Condition Binding="{Binding QueueRowDisplayState}" Value="Completed" />
					<Condition Binding="{Binding QueueRowDisplayFinalResult}" Value="Moved" />
				</MultiDataTrigger.Conditions>
				<Setter Property="Background" Value="{DynamicResource SuccessBadgeBrush}" />
			</MultiDataTrigger>
			<MultiDataTrigger>
				<MultiDataTrigger.Conditions>
					<Condition Binding="{Binding QueueRowDisplayState}" Value="Completed" />
					<Condition Binding="{Binding QueueRowDisplayFinalResult}" Value="Extracted" />
				</MultiDataTrigger.Conditions>
				<Setter Property="Background" Value="{DynamicResource SuccessBadgeBrush}" />
			</MultiDataTrigger>
			<DataTrigger Binding="{Binding QueueRowDisplayState}" Value="Failed">
				<Setter Property="Background" Value="{DynamicResource ErrorBadgeBrush}" />
			</DataTrigger>
			<DataTrigger Binding="{Binding QueueRowDisplayState}" Value="PasswordRequired">
				<Setter Property="Background" Value="{DynamicResource WarningBadgeBrush}" />
			</DataTrigger>
			<DataTrigger Binding="{Binding QueueRowDisplayState}" Value="Skipped">
				<Setter Property="Background" Value="{DynamicResource WarningBadgeBrush}" />
			</DataTrigger>
			<DataTrigger Binding="{Binding QueueRowDisplayFinalResult}" Value="SkippedExists">
				<Setter Property="Background" Value="{DynamicResource WarningBadgeBrush}" />
			</DataTrigger>
			<DataTrigger Binding="{Binding QueueRowDisplayState}" Value="Cancelled">
				<Setter Property="Background" Value="{DynamicResource NeutralBadgeBrush}" />
			</DataTrigger>
		</Style.Triggers>
	</Style>

	<Style x:Key="FluentQueueStatusChipText" TargetType="{x:Type TextBlock}">
		<Setter Property="FontSize" Value="{DynamicResource FontSize.Caption}" />
		<Setter Property="FontWeight" Value="{DynamicResource FontWeight.SemiBold}" />
		<Setter Property="Foreground" Value="{DynamicResource NeutralBadgeForegroundBrush}" />
		<Setter Property="FlowDirection" Value="{DynamicResource App.FlowDirection}" />
		<Setter Property="Language" Value="{DynamicResource App.XmlLanguage}" />
		<Setter Property="TextAlignment" Value="{DynamicResource App.TextAlignment}" />
		<Setter Property="TextTrimming" Value="CharacterEllipsis" />
		<Setter Property="TextWrapping" Value="NoWrap" />
		<Setter Property="SnapsToDevicePixels" Value="True" />
		<Style.Triggers>
			<DataTrigger Binding="{Binding QueueRowDisplayState}" Value="Processing">
				<Setter Property="Foreground" Value="{DynamicResource ActiveBadgeForegroundBrush}" />
			</DataTrigger>
			<DataTrigger Binding="{Binding QueueRowDisplayState}" Value="Extracting">
				<Setter Property="Foreground" Value="{DynamicResource ActiveBadgeForegroundBrush}" />
			</DataTrigger>
			<DataTrigger Binding="{Binding QueueRowDisplayState}" Value="Converting">
				<Setter Property="Foreground" Value="{DynamicResource ActiveBadgeForegroundBrush}" />
			</DataTrigger>
			<DataTrigger Binding="{Binding QueueRowDisplayState}" Value="Verifying">
				<Setter Property="Foreground" Value="{DynamicResource ActiveBadgeForegroundBrush}" />
			</DataTrigger>
			<DataTrigger Binding="{Binding QueueRowDisplayState}" Value="ReadingFile">
				<Setter Property="Foreground" Value="{DynamicResource ActiveBadgeForegroundBrush}" />
			</DataTrigger>
			<MultiDataTrigger>
				<MultiDataTrigger.Conditions>
					<Condition Binding="{Binding QueueRowDisplayState}" Value="Completed" />
					<Condition Binding="{Binding QueueRowDisplayFinalResult}" Value="Healthy" />
				</MultiDataTrigger.Conditions>
				<Setter Property="Foreground" Value="{DynamicResource SuccessBadgeForegroundBrush}" />
			</MultiDataTrigger>
			<MultiDataTrigger>
				<MultiDataTrigger.Conditions>
					<Condition Binding="{Binding QueueRowDisplayState}" Value="Completed" />
					<Condition Binding="{Binding QueueRowDisplayFinalResult}" Value="Moved" />
				</MultiDataTrigger.Conditions>
				<Setter Property="Foreground" Value="{DynamicResource SuccessBadgeForegroundBrush}" />
			</MultiDataTrigger>
			<MultiDataTrigger>
				<MultiDataTrigger.Conditions>
					<Condition Binding="{Binding QueueRowDisplayState}" Value="Completed" />
					<Condition Binding="{Binding QueueRowDisplayFinalResult}" Value="Extracted" />
				</MultiDataTrigger.Conditions>
				<Setter Property="Foreground" Value="{DynamicResource SuccessBadgeForegroundBrush}" />
			</MultiDataTrigger>
			<DataTrigger Binding="{Binding QueueRowDisplayState}" Value="Failed">
				<Setter Property="Foreground" Value="{DynamicResource ErrorBadgeForegroundBrush}" />
			</DataTrigger>
			<DataTrigger Binding="{Binding QueueRowDisplayState}" Value="PasswordRequired">
				<Setter Property="Foreground" Value="{DynamicResource WarningBadgeForegroundBrush}" />
			</DataTrigger>
			<DataTrigger Binding="{Binding QueueRowDisplayState}" Value="Skipped">
				<Setter Property="Foreground" Value="{DynamicResource WarningBadgeForegroundBrush}" />
			</DataTrigger>
			<DataTrigger Binding="{Binding QueueRowDisplayFinalResult}" Value="SkippedExists">
				<Setter Property="Foreground" Value="{DynamicResource WarningBadgeForegroundBrush}" />
			</DataTrigger>
			<DataTrigger Binding="{Binding QueueRowDisplayState}" Value="Cancelled">
				<Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
			</DataTrigger>
		</Style.Triggers>
	</Style>

	<Style x:Key="FluentQueueRowSubtleActionButton" TargetType="{x:Type Button}">
		<Setter Property="Background" Value="{DynamicResource Brush.Control.Fill.Rest}" />
		<Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
		<Setter Property="BorderBrush" Value="{DynamicResource Brush.Control.Stroke.Default}" />
		<Setter Property="BorderThickness" Value="{DynamicResource Inset.1.All}" />
		<Setter Property="Padding" Value="{DynamicResource Inset.10.6}" />
		<Setter Property="FontSize" Value="{DynamicResource FontSize.Caption}" />
		<Setter Property="FontWeight" Value="{DynamicResource FontWeight.SemiBold}" />
		<Setter Property="MinWidth" Value="{DynamicResource Space.68}" />
		<Setter Property="Cursor" Value="{x:Static input:Cursors.Hand}" />
		<Setter Property="FocusVisualStyle" Value="{StaticResource FluentFocusVisualStyle}" />
		<Setter Property="ToolTipService.ShowDuration" Value="{DynamicResource ToolTip.ShowDuration.Long}" />
		<Setter Property="HorizontalContentAlignment" Value="Center" />
		<Setter Property="VerticalContentAlignment" Value="Center" />
		<Setter Property="FlowDirection" Value="{DynamicResource App.FlowDirection}" />
		<Setter Property="Language" Value="{DynamicResource App.XmlLanguage}" />
		<Setter Property="SnapsToDevicePixels" Value="True" />
		<Setter Property="UseLayoutRounding" Value="True" />
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="{x:Type Button}">
					<Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{DynamicResource Radius.Control}"
                            Padding="{TemplateBinding Padding}"
                            Language="{TemplateBinding Language}"
                            SnapsToDevicePixels="True"
                            UseLayoutRounding="True">
						<ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          RecognizesAccessKey="True"
                                          FlowDirection="{TemplateBinding FlowDirection}"
                                          Language="{TemplateBinding Language}"
                                          TextElement.Foreground="{TemplateBinding Foreground}" />
					</Border>

					<ControlTemplate.Triggers>
						<Trigger Property="IsMouseOver" Value="True">
							<Setter TargetName="Root" Property="Background" Value="{DynamicResource Brush.Control.Fill.Hover}" />
							<Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Brush.Control.Stroke.Strong}" />
						</Trigger>

						<Trigger Property="IsPressed" Value="True">
							<Setter TargetName="Root" Property="Background" Value="{DynamicResource Brush.Control.Fill.Pressed}" />
						</Trigger>

						<Trigger Property="IsKeyboardFocused" Value="True">
							<Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Brush.Control.Stroke.Focus}" />
						</Trigger>

						<Trigger Property="IsEnabled" Value="False">
							<Setter TargetName="Root" Property="Background" Value="{DynamicResource Brush.Control.Fill.Disabled}" />
							<Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
							<Setter Property="Foreground" Value="{DynamicResource Brush.Text.Disabled}" />
							<Setter Property="Cursor" Value="{x:Static input:Cursors.Arrow}" />
						</Trigger>
					</ControlTemplate.Triggers>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>

	<Style x:Key="FluentQueueRowActionButton"
           TargetType="{x:Type Button}"
           BasedOn="{StaticResource FluentQueueRowSubtleActionButton}" />

	<Style x:Key="FluentMinimalDataGrid" TargetType="{x:Type DataGrid}">
		<Setter Property="GridLinesVisibility" Value="None" />
		<Setter Property="HeadersVisibility" Value="None" />
		<Setter Property="BorderThickness" Value="{DynamicResource Inset.None}" />
		<Setter Property="Background" Value="{DynamicResource Brush.Layer.Surface}" />
		<Setter Property="RowBackground" Value="{DynamicResource Brush.Transparent}" />
		<Setter Property="RowHeaderWidth" Value="{DynamicResource DataGrid.RowHeaderWidth.None}" />
		<Setter Property="AutoGenerateColumns" Value="False" />
		<Setter Property="CanUserAddRows" Value="False" />
		<Setter Property="SelectionUnit" Value="FullRow" />
		<Setter Property="SelectionMode" Value="Single" />
		<Setter Property="EnableRowVirtualization" Value="True" />
		<Setter Property="VirtualizingPanel.IsVirtualizing" Value="True" />
		<Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling" />
		<Setter Property="FlowDirection" Value="{DynamicResource App.FlowDirection}" />
		<Setter Property="Language" Value="{DynamicResource App.XmlLanguage}" />
		<Setter Property="SnapsToDevicePixels" Value="True" />
		<Setter Property="UseLayoutRounding" Value="True" />
	</Style>

	<Style x:Key="FluentDataGridRow" TargetType="{x:Type DataGridRow}">
		<Setter Property="Background" Value="{DynamicResource Brush.Transparent}" />
		<Setter Property="BorderThickness" Value="{DynamicResource Inset.None}" />
		<Setter Property="MinHeight" Value="{DynamicResource Space.72}" />
		<Setter Property="Margin" Value="{DynamicResource Inset.None}" />
		<Setter Property="FocusVisualStyle" Value="{StaticResource FluentFocusVisualStyle}" />
		<Setter Property="FlowDirection" Value="{DynamicResource App.FlowDirection}" />
		<Setter Property="Language" Value="{DynamicResource App.XmlLanguage}" />
		<Setter Property="SnapsToDevicePixels" Value="True" />
		<Setter Property="UseLayoutRounding" Value="True" />
		<Style.Triggers>
			<Trigger Property="IsSelected" Value="True">
				<Setter Property="Background" Value="{DynamicResource Brush.Transparent}" />
			</Trigger>

			<MultiTrigger>
				<MultiTrigger.Conditions>
					<Condition Property="IsMouseOver" Value="True" />
					<Condition Property="IsSelected" Value="False" />
				</MultiTrigger.Conditions>
				<Setter Property="Background" Value="{DynamicResource Brush.Transparent}" />
			</MultiTrigger>
		</Style.Triggers>
	</Style>

	<Style x:Key="FluentDataGridCell" TargetType="{x:Type DataGridCell}">
		<Setter Property="Background" Value="{DynamicResource Brush.Transparent}" />
		<Setter Property="BorderThickness" Value="{DynamicResource Inset.None}" />
		<Setter Property="Padding" Value="{DynamicResource Inset.None}" />
		<Setter Property="FocusVisualStyle" Value="{StaticResource FluentFocusVisualStyle}" />
		<Setter Property="FlowDirection" Value="{DynamicResource App.FlowDirection}" />
		<Setter Property="Language" Value="{DynamicResource App.XmlLanguage}" />
		<Setter Property="SnapsToDevicePixels" Value="True" />
	</Style>

	<Style x:Key="FluentQueueWorkspaceHeader" TargetType="{x:Type Border}">
		<Setter Property="Background" Value="{DynamicResource Brush.Surface}" />
		<Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
		<Setter Property="BorderThickness" Value="{DynamicResource Inset.0.0.0.1}" />
		<Setter Property="CornerRadius" Value="{DynamicResource Radius.QueueWorkspaceHeader}" />
		<Setter Property="Padding" Value="{DynamicResource Inset.16.14}" />
		<Setter Property="SnapsToDevicePixels" Value="True" />
		<Setter Property="UseLayoutRounding" Value="True" />
	</Style>

</ResourceDictionary>