<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:input="clr-namespace:System.Windows.Input;assembly=PresentationCore">

    <Style x:Key="FluentFocusVisualStyle" TargetType="{x:Type Control}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Control}">
                    <Grid Margin="{DynamicResource Inset.2.All}"
                          SnapsToDevicePixels="True"
                          UseLayoutRounding="True">
                        <Border BorderBrush="{DynamicResource Brush.Focus.StrokeOuter}"
                                BorderThickness="{DynamicResource Inset.1.All}"
                                CornerRadius="{DynamicResource Radius.Control}"
                                SnapsToDevicePixels="True" />
                        <Border Margin="{DynamicResource Inset.1.All}"
                                BorderBrush="{DynamicResource Brush.Focus.StrokeInner}"
                                BorderThickness="{DynamicResource Inset.1.All}"
                                CornerRadius="{DynamicResource Radius.Control}"
                                SnapsToDevicePixels="True" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <SolidColorBrush x:Key="FluentPageBackgroundBrush" Color="{DynamicResource Color.Background}" />

    <SolidColorBrush x:Key="FluentAccentBrush" Color="{DynamicResource Color.Accent}" />

    <SolidColorBrush x:Key="FluentHeaderBgBrush" Color="{DynamicResource Color.Surface}" />

    <SolidColorBrush x:Key="FluentCardSurfaceBrush" Color="{DynamicResource Color.Card}" />

    <SolidColorBrush x:Key="FluentSecondaryButtonBgBrush" Color="{DynamicResource Color.Surface}" />

    <SolidColorBrush x:Key="FluentSecondaryTextBrush" Color="{DynamicResource Color.Text.Secondary}" />

    <Style x:Key="FluentPathIconBase" TargetType="{x:Type Path}">
        <Setter Property="Stretch" Value="Uniform" />
        <Setter Property="FlowDirection" Value="LeftToRight" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Fill" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Control}}}" />
    </Style>

    <Style x:Key="FluentPathIcon.Small"
           TargetType="{x:Type Path}"
           BasedOn="{StaticResource FluentPathIconBase}">
        <Setter Property="Width" Value="{DynamicResource Space.12}" />
        <Setter Property="Height" Value="{DynamicResource Space.12}" />
    </Style>

    <Style x:Key="FluentPathIcon.Medium"
           TargetType="{x:Type Path}"
           BasedOn="{StaticResource FluentPathIconBase}">
        <Setter Property="Width" Value="{DynamicResource Space.16}" />
        <Setter Property="Height" Value="{DynamicResource Space.16}" />
    </Style>

    <Style x:Key="FluentPathIcon.Large"
           TargetType="{x:Type Path}"
           BasedOn="{StaticResource FluentPathIconBase}">
        <Setter Property="Width" Value="{DynamicResource Space.20}" />
        <Setter Property="Height" Value="{DynamicResource Space.20}" />
    </Style>

    <Style x:Key="FluentSectionLabel" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="{DynamicResource FontSize.Caption}" />
        <Setter Property="FontWeight" Value="{DynamicResource FontWeight.SemiBold}" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
        <Setter Property="FlowDirection" Value="{DynamicResource App.FlowDirection}" />
        <Setter Property="Language" Value="{DynamicResource App.XmlLanguage}" />
        <Setter Property="TextAlignment" Value="{DynamicResource App.TextAlignment}" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        <Setter Property="TextWrapping" Value="NoWrap" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style x:Key="FluentMutedCaption" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="{DynamicResource FontSize.CaptionSmall}" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Muted}" />
        <Setter Property="FlowDirection" Value="{DynamicResource App.FlowDirection}" />
        <Setter Property="Language" Value="{DynamicResource App.XmlLanguage}" />
        <Setter Property="TextAlignment" Value="{DynamicResource App.TextAlignment}" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        <Setter Property="TextWrapping" Value="NoWrap" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

</ResourceDictionary>
