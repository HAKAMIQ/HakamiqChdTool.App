<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:input="clr-namespace:System.Windows.Input;assembly=PresentationCore">

    <Style x:Key="FluentTextBoxStyle" TargetType="{x:Type TextBox}">
        <Setter Property="MinHeight" Value="{DynamicResource Space.32}" />
        <Setter Property="Padding" Value="{DynamicResource Inset.10.6}" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
        <Setter Property="Background" Value="{DynamicResource Brush.Control.Fill.Rest}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Control.Stroke.Default}" />
        <Setter Property="BorderThickness" Value="{DynamicResource Inset.1.All}" />
        <Setter Property="CaretBrush" Value="{DynamicResource Brush.Text.Primary}" />
        <Setter Property="SelectionBrush" Value="{DynamicResource Brush.Accent.Subtle}" />
        <Setter Property="SelectionTextBrush" Value="{DynamicResource Brush.Text.Primary}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="FontSize" Value="{DynamicResource FontSize.Body}" />
        <Setter Property="FontFamily" Value="{DynamicResource FontFamily.Text}" />
        <Setter Property="FlowDirection" Value="{DynamicResource App.FlowDirection}" />
        <Setter Property="TextAlignment" Value="{DynamicResource App.TextAlignment}" />
        <Setter Property="Language" Value="{DynamicResource App.XmlLanguage}" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TextBox}">
                    <Grid Language="{TemplateBinding Language}"
                          SnapsToDevicePixels="True"
                          UseLayoutRounding="True">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{DynamicResource Radius.Control}"
                                Language="{TemplateBinding Language}"
                                SnapsToDevicePixels="True"
                                UseLayoutRounding="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          Focusable="False"
                                          FlowDirection="{TemplateBinding FlowDirection}"
                                          Language="{TemplateBinding Language}"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden" />
                        </Border>

                        <Border x:Name="Underline"
                                Height="1"
                                VerticalAlignment="Bottom"
                                HorizontalAlignment="Stretch"
                                Background="{DynamicResource Brush.Border.Subtle}"
                                IsHitTestVisible="False"
                                SnapsToDevicePixels="True" />
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource Brush.Control.Fill.Hover}" />
                            <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Brush.Control.Stroke.Strong}" />
                            <Setter TargetName="Underline" Property="Background" Value="{DynamicResource Brush.Control.Stroke.Strong}" />
                        </Trigger>

                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Brush.Control.Stroke.Focus}" />
                            <Setter TargetName="Underline" Property="Height" Value="2" />
                            <Setter TargetName="Underline" Property="Background" Value="{DynamicResource Brush.Control.Stroke.Focus}" />
                        </Trigger>

                        <Trigger Property="IsReadOnly" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource Brush.Control.Fill.Rest}" />
                            <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
                            <Setter TargetName="Underline" Property="Background" Value="{DynamicResource Brush.Border.Subtle}" />
                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource Brush.Control.Fill.Disabled}" />
                            <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
                            <Setter TargetName="Underline" Property="Background" Value="{DynamicResource Brush.Border.Subtle}" />
                            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Disabled}" />
                            <Setter Property="CaretBrush" Value="{DynamicResource Brush.Text.Disabled}" />
                            <Setter Property="Opacity" Value="{DynamicResource Opacity.Disabled.Control}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="FluentTechnicalTextBoxStyle"
           TargetType="{x:Type TextBox}"
           BasedOn="{StaticResource FluentTextBoxStyle}">
        <Setter Property="FlowDirection" Value="LeftToRight" />
        <Setter Property="TextAlignment" Value="Left" />
        <Setter Property="Language" Value="en-US" />
        <Setter Property="FontFamily" Value="{DynamicResource FontFamily.Mono}" />
    </Style>

    <Style x:Key="FluentCheckBoxStyle" TargetType="{x:Type CheckBox}">
        <Setter Property="MinHeight" Value="{DynamicResource Space.32}" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
        <Setter Property="Background" Value="{DynamicResource Brush.Transparent}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Indicator.Stroke}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="FontSize" Value="{DynamicResource FontSize.Body}" />
        <Setter Property="FontFamily" Value="{DynamicResource FontFamily.Text}" />
        <Setter Property="FlowDirection" Value="{DynamicResource App.FlowDirection}" />
        <Setter Property="Language" Value="{DynamicResource App.XmlLanguage}" />
        <Setter Property="Cursor" Value="{x:Static input:Cursors.Hand}" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type CheckBox}">
                    <Grid x:Name="Root"
                          MinHeight="{TemplateBinding MinHeight}"
                          Background="{TemplateBinding Background}"
                          FlowDirection="{TemplateBinding FlowDirection}"
                          Language="{TemplateBinding Language}"
                          SnapsToDevicePixels="True"
                          UseLayoutRounding="True">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="{DynamicResource Grid.Space.20}" />
                            <ColumnDefinition Width="{DynamicResource Grid.Space.8}" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border x:Name="Box"
                                Grid.Column="0"
                                Width="{DynamicResource Space.18}"
                                Height="{DynamicResource Space.18}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Background="{DynamicResource Brush.Control.Fill.Rest}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{DynamicResource Inset.1.All}"
                                CornerRadius="{DynamicResource Radius.CheckBox}"
                                SnapsToDevicePixels="True">
                            <Path x:Name="CheckGlyph"
                                  Width="{DynamicResource Space.12}"
                                  Height="{DynamicResource Space.8}"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  FlowDirection="LeftToRight"
                                  Stretch="Uniform"
                                  Stroke="{DynamicResource Brush.Foreground.OnAccent}"
                                  StrokeThickness="{DynamicResource Fluent.StrokeThickness.Thick}"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Data="{StaticResource Icon.Checkmark}"
                                  Visibility="Collapsed" />
                        </Border>

                        <Border x:Name="IndeterminateGlyph"
                                Grid.Column="0"
                                Width="{DynamicResource Space.8}"
                                Height="{DynamicResource Space.2}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Background="{DynamicResource Brush.Foreground.OnAccent}"
                                CornerRadius="{DynamicResource Radius.Pill}"
                                Visibility="Collapsed" />

                        <ContentPresenter Grid.Column="2"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Content="{TemplateBinding Content}"
                                          ContentStringFormat="{TemplateBinding ContentStringFormat}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          ContentTemplateSelector="{TemplateBinding ContentTemplateSelector}"
                                          RecognizesAccessKey="True"
                                          FlowDirection="{TemplateBinding FlowDirection}"
                                          Language="{TemplateBinding Language}"
                                          TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Box" Property="Background" Value="{DynamicResource Brush.Control.Fill.Hover}" />
                            <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource Brush.Indicator.Stroke.Hover}" />
                        </Trigger>

                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Box" Property="Background" Value="{DynamicResource Brush.Control.Fill.Pressed}" />
                            <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource Brush.Control.Stroke.Focus}" />
                        </Trigger>

                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource Brush.Control.Stroke.Focus}" />
                        </Trigger>

                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Box" Property="Background" Value="{DynamicResource Brush.Accent}" />
                            <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                            <Setter TargetName="CheckGlyph" Property="Visibility" Value="Visible" />
                            <Setter TargetName="IndeterminateGlyph" Property="Visibility" Value="Collapsed" />
                        </Trigger>

                        <Trigger Property="IsChecked" Value="{x:Null}">
                            <Setter TargetName="Box" Property="Background" Value="{DynamicResource Brush.Accent}" />
                            <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                            <Setter TargetName="CheckGlyph" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="IndeterminateGlyph" Property="Visibility" Value="Visible" />
                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Root" Property="Opacity" Value="{DynamicResource Opacity.Disabled.Control}" />
                            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Disabled}" />
                            <Setter Property="Cursor" Value="{x:Static input:Cursors.Arrow}" />
                            <Setter TargetName="Box" Property="Background" Value="{DynamicResource Brush.Control.Fill.Disabled}" />
                            <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource Brush.Indicator.Stroke.Disabled}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type TextBox}" BasedOn="{StaticResource FluentTextBoxStyle}" />
    <Style TargetType="{x:Type CheckBox}" BasedOn="{StaticResource FluentCheckBoxStyle}" />

</ResourceDictionary>