# Normalize source text
* text=auto

# Windows scripts
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Source and project files
*.cs text
*.xaml text
*.csproj text
*.sln text
*.props text
*.targets text

# Documentation and config
*.md text
*.txt text
*.json text
*.yml text
*.yaml text
*.xml text

# Disc descriptor files
*.cue text
*.gdi text
*.toc text

# Binary assets and packages
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.ico binary
*.exe binary
*.dll binary
*.pdb binary
*.zip binary
*.7z binary
*.rar binary

# Disc and image files
*.chd binary
*.iso binary
*.bin binary
*.img binary
*.cso binary
*.zso binary
*.pkg binary
