<UserControl x:Class="HakamiqChdTool.App.Views.Options.GeneralSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="{DynamicResource App.FlowDirection}"
             Language="{DynamicResource App.XmlLanguage}"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../Resources/Style/OptionsWindowStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Style="{StaticResource Win11SettingsPageRoot}">
        <ScrollViewer Style="{StaticResource Win11SettingsScrollViewer}">
            <StackPanel Style="{StaticResource Win11SettingsContentStack}">

                <Border Style="{StaticResource Win11SettingsSection}">
                    <Grid FlowDirection="{DynamicResource App.FlowDirection}"
                          Language="{DynamicResource App.XmlLanguage}"
                          SnapsToDevicePixels="True">

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0"
                              Style="{StaticResource Win11SettingsSectionHeader}">
                            <TextBlock Style="{StaticResource Win11SettingsSectionTitleText}"
                                       Text="{DynamicResource LocGeneralSettings_AppearanceSection}"
                                       ToolTip="{DynamicResource LocGeneralSettings_AppearanceSection}" />
                        </Grid>

                        <Border Grid.Row="1"
                                Style="{StaticResource Win11SettingsRow}">
                            <Grid Style="{StaticResource Win11SettingsRowGrid}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="{DynamicResource Grid.Space.16}" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="0"
                                      Style="{StaticResource Win11SettingsRowTextArea}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Style="{StaticResource Win11SettingsRowTitleText}"
                                               Text="{DynamicResource LocGeneralSettings_LanguageTitle}"
                                               ToolTip="{DynamicResource LocGeneralSettings_LanguageTitle}" />

                                    <TextBlock Grid.Row="1"
                                               Style="{StaticResource Win11SettingsRowDescriptionText}"
                                               Text="{DynamicResource LocGeneralSettings_LanguageDescription}"
                                               ToolTip="{DynamicResource LocGeneralSettings_LanguageDescription}" />
                                </Grid>

                                <ComboBox x:Name="UiLanguageComboBox"
                                          Grid.Column="2"
                                          SelectedValue="{Binding UiLanguage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          SelectedValuePath="Tag"
                                          IsTextSearchEnabled="True"
                                          Style="{StaticResource Win11SettingsComboBox}"
                                          ToolTip="{DynamicResource LocGeneralSettings_LanguageTitle}"
                                          AutomationProperties.Name="{DynamicResource LocGeneralSettings_LanguageTitle}">
                                    <ComboBoxItem Tag="ar-SA"
                                                  Content="{DynamicResource LocLanguage_Arabic}" />

                                    <ComboBoxItem Tag="en-US"
                                                  Content="{DynamicResource LocLanguage_English}" />
                                </ComboBox>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2"
                                Style="{StaticResource Win11SettingsRow}">
                            <Grid Style="{StaticResource Win11SettingsRowGrid}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="{DynamicResource Grid.Space.16}" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="0"
                                      Style="{StaticResource Win11SettingsRowTextArea}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Style="{StaticResource Win11SettingsRowTitleText}"
                                               Text="{DynamicResource LocGeneralSettings_ThemeTitle}"
                                               ToolTip="{DynamicResource LocGeneralSettings_ThemeTitle}" />

                                    <TextBlock Grid.Row="1"
                                               Style="{StaticResource Win11SettingsRowDescriptionText}"
                                               Text="{DynamicResource LocGeneralSettings_ThemeDescription}"
                                               ToolTip="{DynamicResource LocGeneralSettings_ThemeDescription}" />
                                </Grid>

                                <ComboBox x:Name="ThemeComboBox"
                                          Grid.Column="2"
                                          SelectedValue="{Binding Theme, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          SelectedValuePath="Tag"
                                          IsTextSearchEnabled="True"
                                          Style="{StaticResource Win11SettingsComboBox}"
                                          ToolTip="{DynamicResource LocGeneralSettings_ThemeTitle}"
                                          AutomationProperties.Name="{DynamicResource LocGeneralSettings_ThemeTitle}">
                                    <ComboBoxItem Tag="Light"
                                                  Content="{DynamicResource LocUi_Theme_Light}" />

                                    <ComboBoxItem Tag="Dark"
                                                  Content="{DynamicResource LocUi_Theme_Dark}" />

                                    <ComboBoxItem Tag="Hakamiq"
                                                  Content="{DynamicResource LocUi_Theme_Hakamiq}" />
                                </ComboBox>
                            </Grid>
                        </Border>

                        <Border Grid.Row="3"
                                Style="{StaticResource Win11SettingsLastRow}">
                            <Grid Style="{StaticResource Win11SettingsRowGrid}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="{DynamicResource Grid.Space.16}" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="0"
                                      Style="{StaticResource Win11SettingsRowTextArea}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Style="{StaticResource Win11SettingsRowTitleText}"
                                               Text="{DynamicResource LocGeneralSettings_PortableModeTitle}"
                                               ToolTip="{DynamicResource LocGeneralSettings_PortableModeTitle}" />

                                    <TextBlock Grid.Row="1"
                                               Style="{StaticResource Win11SettingsRowDescriptionText}"
                                               Text="{DynamicResource LocGeneralSettings_PortableModeDescription}"
                                               ToolTip="{DynamicResource LocGeneralSettings_PortableModeDescription}" />
                                </Grid>

                                <CheckBox Grid.Column="2"
                                          IsChecked="{Binding PortableMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Style="{StaticResource Win11SettingsCheckBox}"
                                          ToolTip="{DynamicResource LocGeneralSettings_PortableModeTitle}"
                                          AutomationProperties.Name="{DynamicResource LocGeneralSettings_PortableModeTitle}" />
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>