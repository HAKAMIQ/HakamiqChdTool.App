<Window x:Class="HakamiqChdTool.App.Views.AdvancedOptionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:advancedOptions="clr-namespace:HakamiqChdTool.App.Views.AdvancedOptions"
        Title="{DynamicResource LocAdvancedOptions_WindowTitle}"
        Width="960"
        Height="640"
        MinWidth="960"
        MinHeight="640"
        SizeToContent="Manual"
        ResizeMode="NoResize"
        WindowStyle="None"
        WindowStartupLocation="CenterOwner"
        FlowDirection="{DynamicResource App.FlowDirection}"
        Language="{DynamicResource App.XmlLanguage}"
        Icon="pack://application:,,,/Resources/HakamiqLogo.ico"
        Background="{DynamicResource Brush.Layer.Canvas}"
        Foreground="{DynamicResource Brush.Text.Primary}"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        FontFamily="{DynamicResource FontFamily.Text}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Style/AdvancedOptionsWindowStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="AdvancedOptionsWindow.RootFrame"
                   TargetType="{x:Type Border}">
                <Setter Property="Background" Value="{DynamicResource Brush.Layer.Surface}" />
                <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
                <Setter Property="BorderThickness" Value="{DynamicResource Inset.1.All}" />
                <Setter Property="CornerRadius" Value="{DynamicResource Radius.Card}" />
                <Setter Property="TextElement.Foreground" Value="{DynamicResource Brush.Text.Primary}" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
                <Setter Property="UseLayoutRounding" Value="True" />
            </Style>

            <Style x:Key="AdvancedOptionsWindow.HeaderFooter"
                   TargetType="{x:Type Border}">
                <Setter Property="Background" Value="{DynamicResource Brush.Layer.Card}" />
                <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
                <Setter Property="Padding" Value="12,8" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
                <Setter Property="UseLayoutRounding" Value="True" />
            </Style>

            <Style x:Key="AdvancedOptionsWindow.Card"
                   TargetType="{x:Type Border}">
                <Setter Property="Background" Value="{DynamicResource Brush.Layer.Card}" />
                <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
                <Setter Property="BorderThickness" Value="{DynamicResource Inset.1.All}" />
                <Setter Property="CornerRadius" Value="{DynamicResource Radius.Card}" />
                <Setter Property="Padding" Value="10" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="VerticalAlignment" Value="Stretch" />
                <Setter Property="TextElement.Foreground" Value="{DynamicResource Brush.Text.Primary}" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
                <Setter Property="UseLayoutRounding" Value="True" />
            </Style>

            <Style x:Key="AdvancedOptionsWindow.InnerPanel"
                   TargetType="{x:Type Border}">
                <Setter Property="Background" Value="{DynamicResource Brush.Layer.Surface}" />
                <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
                <Setter Property="BorderThickness" Value="{DynamicResource Inset.1.All}" />
                <Setter Property="CornerRadius" Value="{DynamicResource Radius.Control}" />
                <Setter Property="Padding" Value="10" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="VerticalAlignment" Value="Stretch" />
                <Setter Property="TextElement.Foreground" Value="{DynamicResource Brush.Text.Primary}" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
                <Setter Property="UseLayoutRounding" Value="True" />
            </Style>

            <Style x:Key="AdvancedOptionsWindow.HeaderTextColumn"
                   TargetType="{x:Type StackPanel}">
                <Setter Property="FlowDirection" Value="{DynamicResource App.FlowDirection}" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>

            <Style x:Key="AdvancedOptionsWindow.SectionAccent"
                   TargetType="{x:Type Border}">
                <Setter Property="Width" Value="{DynamicResource Space.4}" />
                <Setter Property="Height" Value="24" />
                <Setter Property="Background" Value="{DynamicResource Brush.Accent}" />
                <Setter Property="CornerRadius" Value="{DynamicResource Radius.Control}" />
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="VerticalAlignment" Value="Top" />
                <Setter Property="Margin" Value="{DynamicResource Inset.0.2.0.0}" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
            </Style>

            <Style x:Key="AdvancedOptionsWindow.GeneralText"
                   TargetType="{x:Type TextBlock}">
                <Setter Property="FontFamily" Value="{DynamicResource FontFamily.Text}" />
                <Setter Property="FlowDirection" Value="{DynamicResource App.FlowDirection}" />
                <Setter Property="Language" Value="{DynamicResource App.XmlLanguage}" />
                <Setter Property="TextAlignment" Value="{DynamicResource AdvancedOptions.SettingsTextAlignment}" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="TextWrapping" Value="Wrap" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
            </Style>

            <Style x:Key="AdvancedOptionsWindow.TitleText"
                   TargetType="{x:Type TextBlock}"
                   BasedOn="{StaticResource AdvancedOptionsWindow.GeneralText}">
                <Setter Property="FontSize" Value="{DynamicResource FontSize.SectionTitle}" />
                <Setter Property="FontWeight" Value="{DynamicResource FontWeight.SemiBold}" />
                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
                <Setter Property="TextWrapping" Value="NoWrap" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            </Style>

            <Style x:Key="AdvancedOptionsWindow.SectionTitleText"
                   TargetType="{x:Type TextBlock}"
                   BasedOn="{StaticResource AdvancedOptionsWindow.GeneralText}">
                <Setter Property="FontSize" Value="{DynamicResource FontSize.BodyStrong}" />
                <Setter Property="FontWeight" Value="{DynamicResource FontWeight.SemiBold}" />
                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
                <Setter Property="TextWrapping" Value="NoWrap" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            </Style>

            <Style x:Key="AdvancedOptionsWindow.BodyText"
                   TargetType="{x:Type TextBlock}"
                   BasedOn="{StaticResource AdvancedOptionsWindow.GeneralText}">
                <Setter Property="FontSize" Value="{DynamicResource FontSize.Caption}" />
                <Setter Property="FontWeight" Value="{DynamicResource FontWeight.Regular}" />
                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
                <Setter Property="LineHeight" Value="{DynamicResource Font.LineHeight.Body}" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            </Style>

            <Style x:Key="AdvancedOptionsWindow.TabText"
                   TargetType="{x:Type TextBlock}"
                   BasedOn="{StaticResource AdvancedOptionsWindow.GeneralText}">
                <Setter Property="FontSize" Value="{DynamicResource FontSize.BodySmall}" />
                <Setter Property="FontWeight" Value="{DynamicResource FontWeight.SemiBold}" />
                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
                <Setter Property="TextWrapping" Value="NoWrap" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            </Style>

            <Style x:Key="AdvancedOptionsWindow.CompactPrimaryButton"
                   TargetType="{x:Type Button}"
                   BasedOn="{StaticResource PrimaryButtonStyle}">
                <Setter Property="MinWidth" Value="{DynamicResource Space.112}" />
                <Setter Property="MaxWidth" Value="150" />
                <Setter Property="Padding" Value="10,5" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>

            <Style x:Key="AdvancedOptionsWindow.CompactSecondaryButton"
                   TargetType="{x:Type Button}"
                   BasedOn="{StaticResource SecondaryButtonStyle}">
                <Setter Property="MinWidth" Value="{DynamicResource Space.112}" />
                <Setter Property="MaxWidth" Value="150" />
                <Setter Property="Padding" Value="10,5" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="{DynamicResource Space.0}"
                            CornerRadius="{DynamicResource Radius.Dialog}"
                            GlassFrameThickness="{DynamicResource Inset.None}"
                            ResizeBorderThickness="{DynamicResource Inset.None}"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Border Style="{StaticResource AdvancedOptionsWindow.RootFrame}">
        <Grid ClipToBounds="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Style="{StaticResource AdvancedOptionsWindow.HeaderFooter}"
                    BorderThickness="{DynamicResource Inset.0.0.0.1}"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid FlowDirection="{DynamicResource App.FlowDirection}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Style="{StaticResource AdvancedOptionsWindow.SectionAccent}" />

                    <StackPanel Grid.Column="2"
                                Style="{StaticResource AdvancedOptionsWindow.HeaderTextColumn}">
                        <TextBlock Text="{DynamicResource LocAdvancedOptions_WindowTitle}"
                                   Style="{StaticResource AdvancedOptionsWindow.TitleText}" />

                        <TextBlock Margin="{DynamicResource Inset.0.2.0.0}"
                                   Text="{DynamicResource LocAdvancedOptions_HeaderDescription}"
                                   Style="{StaticResource AdvancedOptionsWindow.BodyText}"
                                   TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>

                    <Button Grid.Column="4"
                            Width="{DynamicResource Space.32}"
                            Height="{DynamicResource Space.32}"
                            MinWidth="{DynamicResource Space.32}"
                            Padding="{DynamicResource Inset.None}"
                            VerticalAlignment="Center"
                            Style="{StaticResource HeaderIconButtonStyle}"
                            ToolTip="{DynamicResource LocCommon_Close}"
                            Click="CancelButton_Click"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Viewbox Width="{DynamicResource Space.12}"
                                 Height="{DynamicResource Space.12}"
                                 FlowDirection="LeftToRight"
                                 Stretch="Uniform">
                            <Path Data="{StaticResource Icon.Close}"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  Stretch="Uniform" />
                        </Viewbox>
                    </Button>
                </Grid>
            </Border>

            <Grid Grid.Row="1"
                  Margin="{DynamicResource Inset.10.All}"
                  MinHeight="0"
                  VerticalAlignment="Stretch"
                  FlowDirection="{DynamicResource App.FlowDirection}">
                <Border Style="{StaticResource AdvancedOptionsWindow.Card}">
                    <Grid MinHeight="0"
                          VerticalAlignment="Stretch"
                          FlowDirection="{DynamicResource App.FlowDirection}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="{DynamicResource Grid.AdvancedOptionsSidebar.Width}" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Style="{StaticResource AdvancedOptionsWindow.InnerPanel}">
                            <Grid FlowDirection="{DynamicResource App.FlowDirection}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="10" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="6" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="6" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="6" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="6" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0"
                                      FlowDirection="{DynamicResource App.FlowDirection}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            Style="{StaticResource AdvancedOptionsWindow.SectionAccent}" />

                                    <StackPanel Grid.Column="2"
                                                Style="{StaticResource AdvancedOptionsWindow.HeaderTextColumn}">
                                        <TextBlock Text="{DynamicResource LocAdvancedOptions_SectionsTitle}"
                                                   Style="{StaticResource AdvancedOptionsWindow.SectionTitleText}" />

                                        <TextBlock Margin="{DynamicResource Inset.0.4.0.0}"
                                                   Text="{DynamicResource LocAdvancedOptions_SectionsDescription}"
                                                   Style="{StaticResource AdvancedOptionsWindow.BodyText}" />
                                    </StackPanel>
                                </Grid>

                                <RadioButton x:Name="GeneralTabButton"
                                             Grid.Row="2"
                                             GroupName="AdvancedTabs"
                                             IsChecked="True"
                                             Tag="{StaticResource Icon.Info}"
                                             Style="{StaticResource RightSidebarRadioButtonStyle}"
                                             Checked="OnTabButtonChecked">
                                    <TextBlock Text="{DynamicResource LocAdvancedOptions_TabGeneral}"
                                               Style="{StaticResource AdvancedOptionsWindow.TabText}" />
                                </RadioButton>

                                <RadioButton x:Name="PathsTabButton"
                                             Grid.Row="4"
                                             GroupName="AdvancedTabs"
                                             Tag="{StaticResource Icon.Folder}"
                                             Style="{StaticResource RightSidebarRadioButtonStyle}"
                                             Checked="OnTabButtonChecked">
                                    <TextBlock Text="{DynamicResource LocAdvancedOptions_TabPaths}"
                                               Style="{StaticResource AdvancedOptionsWindow.TabText}" />
                                </RadioButton>

                                <RadioButton x:Name="RedumpTabButton"
                                             Grid.Row="6"
                                             GroupName="AdvancedTabs"
                                             Tag="{StaticResource Icon.DatabaseSearch}"
                                             Style="{StaticResource RightSidebarRadioButtonStyle}"
                                             Checked="OnTabButtonChecked">
                                    <TextBlock Text="{DynamicResource LocAdvancedOptions_TabRedump}"
                                               Style="{StaticResource AdvancedOptionsWindow.TabText}" />
                                </RadioButton>

                                <RadioButton x:Name="ProcessingTabButton"
                                             Grid.Row="8"
                                             GroupName="AdvancedTabs"
                                             Tag="{StaticResource Icon.Settings}"
                                             Style="{StaticResource RightSidebarRadioButtonStyle}"
                                             Checked="OnTabButtonChecked">
                                    <TextBlock Text="{DynamicResource LocAdvancedOptions_TabProcessing}"
                                               Style="{StaticResource AdvancedOptionsWindow.TabText}" />
                                </RadioButton>

                                <RadioButton x:Name="PerformanceTabButton"
                                             Grid.Row="10"
                                             GroupName="AdvancedTabs"
                                             Tag="{StaticResource Icon.Games}"
                                             Style="{StaticResource RightSidebarRadioButtonStyle}"
                                             Checked="OnTabButtonChecked">
                                    <TextBlock Text="{DynamicResource LocAdvancedOptions_TabPerformance}"
                                               Style="{StaticResource AdvancedOptionsWindow.TabText}" />
                                </RadioButton>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2"
                                Style="{StaticResource AdvancedOptionsWindow.InnerPanel}"
                                Padding="{DynamicResource Inset.None}"
                                MinHeight="0">
                            <Grid Background="{DynamicResource Brush.Transparent}"
                                  MinHeight="0"
                                  ClipToBounds="True"
                                  FlowDirection="{DynamicResource App.FlowDirection}">

                                <advancedOptions:GeneralSettingsView x:Name="GeneralPanel"
                                                                     HorizontalAlignment="Stretch"
                                                                     VerticalAlignment="Stretch" />

                                <advancedOptions:PathsSettingsView x:Name="PathsPanel"
                                                                   HorizontalAlignment="Stretch"
                                                                   VerticalAlignment="Stretch"
                                                                   Visibility="Collapsed" />

                                <advancedOptions:RedumpSettingsView x:Name="RedumpPanel"
                                                                    HorizontalAlignment="Stretch"
                                                                    VerticalAlignment="Stretch"
                                                                    Visibility="Collapsed" />

                                <advancedOptions:ProcessingSettingsView x:Name="ProcessingPanel"
                                                                        HorizontalAlignment="Stretch"
                                                                        VerticalAlignment="Stretch"
                                                                        Visibility="Collapsed" />

                                <advancedOptions:PerformanceSettingsView x:Name="PerformancePanel"
                                                                         HorizontalAlignment="Stretch"
                                                                         VerticalAlignment="Stretch"
                                                                         Visibility="Collapsed" />
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="2"
                    Style="{StaticResource AdvancedOptionsWindow.HeaderFooter}"
                    BorderThickness="{DynamicResource Inset.0.1.0.0}">
                <Grid FlowDirection="{DynamicResource App.FlowDirection}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button x:Name="RestoreDefaultsButton"
                            Grid.Column="0"
                            Content="{DynamicResource LocAdvancedOptions_RestoreDefaults}"
                            Style="{StaticResource AdvancedOptionsWindow.CompactSecondaryButton}"
                            Click="RestoreDefaultsButton_Click" />

                    <Grid Grid.Column="2"
                          FlowDirection="{DynamicResource App.FlowDirection}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Content="{DynamicResource LocCommon_Cancel}"
                                Style="{StaticResource AdvancedOptionsWindow.CompactSecondaryButton}"
                                Click="CancelButton_Click" />

                        <Button Grid.Column="2"
                                Content="{DynamicResource LocCommon_Apply}"
                                Style="{StaticResource AdvancedOptionsWindow.CompactSecondaryButton}"
                                Click="ApplyButton_Click"
                                IsEnabled="{Binding CanSave}" />

                        <Button Grid.Column="4"
                                Content="{DynamicResource LocCommon_Ok}"
                                Style="{StaticResource AdvancedOptionsWindow.CompactPrimaryButton}"
                                Click="OkButton_Click"
                                IsEnabled="{Binding CanConfirm}" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>