<UserControl x:Class="HakamiqChdTool.App.Views.Main.QueueToolbarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="{DynamicResource App.FlowDirection}"
             Language="{DynamicResource App.XmlLanguage}"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">

    <Border Style="{DynamicResource FluentQueueWorkspaceHeader}">
        <Grid FlowDirection="{DynamicResource App.FlowDirection}"
              Language="{DynamicResource App.XmlLanguage}"
              SnapsToDevicePixels="True">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="{DynamicResource Grid.Space.12}" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0"
                  MinWidth="0"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Center"
                  FlowDirection="{DynamicResource App.FlowDirection}"
                  Language="{DynamicResource App.XmlLanguage}"
                  SnapsToDevicePixels="True">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="{DynamicResource Grid.Space.10}" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Width="{DynamicResource Space.36}"
                        Height="{DynamicResource Space.36}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="{DynamicResource Brush.Accent.Subtle}"
                        BorderBrush="{DynamicResource Brush.Accent.SelectedBorder}"
                        BorderThickness="{DynamicResource Inset.1.All}"
                        CornerRadius="{DynamicResource Radius.Control}"
                        SnapsToDevicePixels="True">

                    <Viewbox Width="{DynamicResource Space.18}"
                             Height="{DynamicResource Space.18}"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             FlowDirection="LeftToRight"
                             Stretch="Uniform">

                        <Path Data="{StaticResource Icon.DocumentAdd}"
                              Fill="{DynamicResource Brush.Accent.Text}"
                              Stretch="Uniform"
                              SnapsToDevicePixels="True" />
                    </Viewbox>
                </Border>

                <StackPanel Grid.Column="2"
                            MinWidth="0"
                            Style="{DynamicResource QueueWorkspaceHeaderTextColumn}">

                    <TextBlock Style="{DynamicResource QueueWorkspaceHeaderTitleText}"
                               Text="{DynamicResource LocUi_QueueSection_Title}"
                               TextTrimming="CharacterEllipsis"
                               TextWrapping="NoWrap"
                               ToolTip="{DynamicResource LocUi_QueueSection_Title}" />

                    <TextBlock Style="{DynamicResource QueueWorkspaceHeaderSubtitleText}"
                               Text="{DynamicResource LocUi_QueueSection_Subtitle}"
                               TextTrimming="CharacterEllipsis"
                               TextWrapping="NoWrap"
                               ToolTip="{DynamicResource LocUi_QueueSection_Subtitle}" />
                </StackPanel>
            </Grid>

            <Grid Grid.Column="2"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  FlowDirection="{DynamicResource App.FlowDirection}"
                  Language="{DynamicResource App.XmlLanguage}"
                  SnapsToDevicePixels="True">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="{DynamicResource Grid.Space.6}" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Command="{Binding SelectFilesCommand}"
                        IsEnabled="{Binding IsShellEnabled}"
                        Style="{DynamicResource QueueWorkspaceToolButton}"
                        ToolTip="{DynamicResource LocUi_Hub_AddFiles}"
                        AutomationProperties.Name="{DynamicResource LocUi_Hub_AddFiles}">

                    <Grid FlowDirection="{DynamicResource App.FlowDirection}"
                          Language="{DynamicResource App.XmlLanguage}"
                          SnapsToDevicePixels="True">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="{DynamicResource Grid.Space.6}" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Viewbox Grid.Column="0"
                                 Width="{DynamicResource Space.16}"
                                 Height="{DynamicResource Space.16}"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 FlowDirection="LeftToRight"
                                 Stretch="Uniform">

                            <Path Data="{StaticResource Icon.DocumentAdd}"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                                  Stretch="Uniform"
                                  SnapsToDevicePixels="True" />
                        </Viewbox>

                        <TextBlock Grid.Column="2"
                                   Style="{DynamicResource QueueWorkspaceCommandText}"
                                   Text="{DynamicResource LocUi_Hub_AddFiles}"
                                   TextTrimming="CharacterEllipsis"
                                   TextWrapping="NoWrap" />
                    </Grid>
                </Button>

                <Button Grid.Column="2"
                        Command="{Binding SelectFolderCommand}"
                        IsEnabled="{Binding IsShellEnabled}"
                        Style="{DynamicResource QueueWorkspaceToolButton}"
                        ToolTip="{DynamicResource LocUi_Hub_AddFolder}"
                        AutomationProperties.Name="{DynamicResource LocUi_Hub_AddFolder}">

                    <Grid FlowDirection="{DynamicResource App.FlowDirection}"
                          Language="{DynamicResource App.XmlLanguage}"
                          SnapsToDevicePixels="True">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="{DynamicResource Grid.Space.6}" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Viewbox Grid.Column="0"
                                 Width="{DynamicResource Space.16}"
                                 Height="{DynamicResource Space.16}"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 FlowDirection="LeftToRight"
                                 Stretch="Uniform">

                            <Path Data="{StaticResource Icon.FolderAdd}"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                                  Stretch="Uniform"
                                  SnapsToDevicePixels="True" />
                        </Viewbox>

                        <TextBlock Grid.Column="2"
                                   Style="{DynamicResource QueueWorkspaceCommandText}"
                                   Text="{DynamicResource LocUi_Hub_AddFolder}"
                                   TextTrimming="CharacterEllipsis"
                                   TextWrapping="NoWrap" />
                    </Grid>
                </Button>
            </Grid>
        </Grid>
    </Border>
</UserControl>