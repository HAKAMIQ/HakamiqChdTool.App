<UserControl x:Class="HakamiqChdTool.App.Views.Main.QueueSummaryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="{DynamicResource App.FlowDirection}"
             Language="{DynamicResource App.XmlLanguage}"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">

    <Border HorizontalAlignment="Stretch"
            VerticalAlignment="Center"
            Padding="{DynamicResource Inset.8.6}"
            Background="{DynamicResource Brush.Transparent}"
            BorderBrush="{DynamicResource Brush.Transparent}"
            BorderThickness="{DynamicResource Inset.None}"
            CornerRadius="{DynamicResource Radius.Control}"
            SnapsToDevicePixels="True">

        <Grid HorizontalAlignment="Stretch"
              VerticalAlignment="Center"
              FlowDirection="{DynamicResource App.FlowDirection}"
              Language="{DynamicResource App.XmlLanguage}"
              SnapsToDevicePixels="True">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="{DynamicResource Grid.Space.6}" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    MinWidth="{DynamicResource Space.20}"
                    Height="{DynamicResource Space.20}"
                    Padding="{DynamicResource Inset.6.0}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{DynamicResource Brush.Accent.Subtle}"
                    BorderBrush="{DynamicResource Brush.Accent.SelectedBorder}"
                    BorderThickness="{DynamicResource Inset.1.All}"
                    CornerRadius="{DynamicResource Radius.Pill}"
                    SnapsToDevicePixels="True">

                <TextBlock HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontFamily="{DynamicResource FontFamily.Text}"
                           FontSize="{DynamicResource FontSize.Caption}"
                           FontWeight="{DynamicResource FontWeight.SemiBold}"
                           Foreground="{DynamicResource Brush.Accent.Text}"
                           Text="{Binding QueueItems.Count, StringFormat={}{0}}"
                           TextAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           TextWrapping="NoWrap"
                           SnapsToDevicePixels="True" />
            </Border>

            <TextBlock Grid.Column="2"
                       HorizontalAlignment="Stretch"
                       VerticalAlignment="Center"
                       Style="{DynamicResource QueueWorkspace.GeneralText}"
                       FontSize="{DynamicResource FontSize.Caption}"
                       Foreground="{DynamicResource Brush.Text.Secondary}"
                       Text="{DynamicResource LocUi_QueueSummary_Tasks}"
                       TextAlignment="{DynamicResource Options.SettingsTextAlignment}"
                       TextTrimming="CharacterEllipsis"
                       TextWrapping="NoWrap"
                       SnapsToDevicePixels="True" />
        </Grid>
    </Border>
</UserControl>
