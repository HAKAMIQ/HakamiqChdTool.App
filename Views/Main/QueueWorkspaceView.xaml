<UserControl x:Class="HakamiqChdTool.App.Views.Main.QueueWorkspaceView"
             x:Name="QueueWorkspaceRoot"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dd="urn:gong-wpf-dragdrop"
             xmlns:main="clr-namespace:HakamiqChdTool.App.Views.Main"
             FlowDirection="{DynamicResource App.FlowDirection}"
             Language="{DynamicResource App.XmlLanguage}"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">

    <Border x:Name="WorkspaceCardRoot"
            AllowDrop="True"
            Drop="ForwardWorkspaceDrop"
            PreviewDragOver="ForwardWorkspacePreviewDragOver"
            PreviewDragLeave="ForwardWorkspacePreviewDragLeave"
            PreviewDrop="ForwardWorkspacePreviewDrop"
            Style="{StaticResource FluentWorkspaceCard}"
            ClipToBounds="True"
            SnapsToDevicePixels="True">

        <Grid FlowDirection="{DynamicResource App.FlowDirection}"
              Language="{DynamicResource App.XmlLanguage}"
              Background="{DynamicResource Brush.Layer.Surface}"
              SnapsToDevicePixels="True"
              ClipToBounds="True">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <main:QueueToolbarView Grid.Row="0" />

            <Grid x:Name="QueueHostSurface"
                  Grid.Row="1"
                  MinHeight="{DynamicResource Layout.Queue.MinHeight}"
                  Background="{DynamicResource Brush.Layer.Surface}"
                  FlowDirection="{DynamicResource App.FlowDirection}"
                  Language="{DynamicResource App.XmlLanguage}"
                  ClipToBounds="True"
                  SnapsToDevicePixels="True">

                <Border Margin="{DynamicResource Inset.8.All}"
                        Background="{DynamicResource Brush.Layer.Card}"
                        BorderBrush="{DynamicResource Brush.Border.Subtle}"
                        BorderThickness="{DynamicResource Inset.1.All}"
                        CornerRadius="{DynamicResource Radius.Card}"
                        ClipToBounds="True"
                        SnapsToDevicePixels="True">

                    <Grid FlowDirection="{DynamicResource App.FlowDirection}"
                          Language="{DynamicResource App.XmlLanguage}"
                          ClipToBounds="True"
                          SnapsToDevicePixels="True">

                        <Rectangle x:Name="DropZoneDashedFrame"
                                   Margin="{DynamicResource Inset.8.All}"
                                   RadiusX="{DynamicResource Space.12}"
                                   RadiusY="{DynamicResource Space.12}"
                                   Fill="{DynamicResource Brush.Transparent}"
                                   Stroke="{DynamicResource DropZoneBorderBrush}"
                                   StrokeDashArray="{DynamicResource StrokeDash.DropZone}"
                                   StrokeThickness="{DynamicResource StrokeThickness.Control}"
                                   IsHitTestVisible="False"
                                   SnapsToDevicePixels="True">

                            <Rectangle.Style>
                                <Style TargetType="{x:Type Rectangle}">
                                    <Setter Property="Visibility"
                                            Value="Visible" />

                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding TaskGrid.HasItems, ElementName=QueueListSection}"
                                                     Value="True">
                                            <Setter Property="Visibility"
                                                    Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Rectangle.Style>
                        </Rectangle>

                        <main:QueueListView x:Name="QueueListSection"
                                            TaskGridDrop="ForwardWorkspaceDrop"
                                            TasksLoadingRow="ForwardTasksLoadingRow"
                                            TasksUnloadingRow="ForwardTasksUnloadingRow"
                                            TasksScrollChanged="ForwardTasksScrollChanged"
                                            TasksPreviewMouseRightButtonDown="ForwardTasksPreviewMouseRightButtonDown"
                                            TasksMouseDoubleClick="ForwardTasksMouseDoubleClick"
                                            TasksSelectionChanged="ForwardTasksSelectionChanged"
                                            QueueContextMenuOpened="ForwardQueueContextMenuOpened" />

                        <Border x:Name="EmptyQueueDropHint"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Panel.ZIndex="{DynamicResource Panel.ZIndex.Overlay}"
                                IsHitTestVisible="False"
                                Padding="{DynamicResource Inset.12.All}">

                            <Border.Style>
                                <Style TargetType="{x:Type Border}">
                                    <Setter Property="Visibility"
                                            Value="Visible" />

                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding TaskGrid.HasItems, ElementName=QueueListSection}"
                                                     Value="True">
                                            <Setter Property="Visibility"
                                                    Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <main:QueueEmptyStateView OperationModeKey="{Binding OperationModeKey, ElementName=QueueWorkspaceRoot}" />
                        </Border>
                    </Grid>
                </Border>

                <Border x:Name="DropHighlightOverlay"
                        Margin="{DynamicResource Inset.8.All}"
                        Background="{DynamicResource Brush.Accent}"
                        CornerRadius="{DynamicResource Radius.Card}"
                        IsHitTestVisible="False"
                        Opacity="{DynamicResource Opacity.Hidden}"
                        Panel.ZIndex="{DynamicResource Panel.ZIndex.Overlay}"
                        SnapsToDevicePixels="True" />

                <Grid Style="{StaticResource QueueWorkspaceIntakeOverlay}"
                      Panel.ZIndex="{DynamicResource Panel.ZIndex.Overlay}">

                    <Rectangle Fill="{DynamicResource Brush.Text.Primary}"
                               Opacity="0.22"
                               SnapsToDevicePixels="True" />

                    <Border Style="{StaticResource QueueWorkspaceIntakeDialog}">
                        <Grid FlowDirection="{DynamicResource App.FlowDirection}"
                              Language="{DynamicResource App.XmlLanguage}"
                              SnapsToDevicePixels="True">

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="{DynamicResource Grid.Space.10}" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="{DynamicResource Grid.Space.8}" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="{DynamicResource Grid.Space.8}" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0"
                                  FlowDirection="{DynamicResource App.FlowDirection}"
                                  Language="{DynamicResource App.XmlLanguage}"
                                  SnapsToDevicePixels="True">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="{DynamicResource Grid.Space.10}" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Width="{DynamicResource Space.36}"
                                        Height="{DynamicResource Space.36}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Background="{DynamicResource Brush.Accent.Subtle}"
                                        BorderBrush="{DynamicResource Brush.Accent.SelectedBorder}"
                                        BorderThickness="{DynamicResource Inset.1.All}"
                                        CornerRadius="{DynamicResource Radius.Control}"
                                        SnapsToDevicePixels="True">

                                    <Viewbox Width="{DynamicResource Space.18}"
                                             Height="{DynamicResource Space.18}"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             FlowDirection="LeftToRight"
                                             Stretch="Uniform">

                                        <Path Data="{StaticResource Icon.DocumentAdd}"
                                              Fill="{DynamicResource Brush.Accent.Text}"
                                              Stretch="Uniform"
                                              SnapsToDevicePixels="True" />
                                    </Viewbox>
                                </Border>

                                <StackPanel Grid.Column="2"
                                            MinWidth="0"
                                            FlowDirection="{DynamicResource App.FlowDirection}"
                                            Language="{DynamicResource App.XmlLanguage}">

                                    <TextBlock Style="{StaticResource QueueWorkspaceActivityCardTitleText}"
                                               Text="{Binding IntakeTitle}"
                                               TextTrimming="CharacterEllipsis"
                                               TextWrapping="NoWrap" />

                                    <TextBlock Style="{StaticResource QueueWorkspaceActivityCardBodyText}"
                                               Text="{Binding IntakeStageText}"
                                               TextTrimming="CharacterEllipsis"
                                               TextWrapping="NoWrap" />
                                </StackPanel>
                            </Grid>

                            <StackPanel Grid.Row="2"
                                        FlowDirection="{DynamicResource App.FlowDirection}"
                                        Language="{DynamicResource App.XmlLanguage}">

                                <TextBlock Style="{StaticResource QueueWorkspaceActivityCardBodyText}"
                                           Text="{Binding IntakeAddedText}"
                                           TextTrimming="CharacterEllipsis"
                                           TextWrapping="NoWrap" />

                                <TextBlock Style="{StaticResource QueueWorkspaceActivityCardBodyText}"
                                           Text="{Binding IntakeScannedText}"
                                           TextTrimming="CharacterEllipsis"
                                           TextWrapping="NoWrap" />

                                <TextBlock Style="{StaticResource QueueWorkspaceActivityCardBodyText}"
                                           Text="{Binding IntakeWarningText}"
                                           TextTrimming="CharacterEllipsis"
                                           TextWrapping="Wrap"
                                           Visibility="{Binding IsIntakeWarningVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            </StackPanel>

                            <ProgressBar Grid.Row="4"
                                         FlowDirection="LeftToRight"
                                         IsIndeterminate="True"
                                         Style="{StaticResource FluentQueueCardProgressBar}" />

                            <Button Grid.Row="6"
                                    HorizontalAlignment="Center"
                                    Command="{Binding CancelIntakeCommand}"
                                    IsEnabled="{Binding IntakeCanCancel}"
                                    Style="{StaticResource QueueWorkspaceFooterDangerCommand}"
                                    ToolTip="{DynamicResource LocQueueAdd_CancelAdd}"
                                    AutomationProperties.Name="{DynamicResource LocQueueAdd_CancelAdd}">

                                <TextBlock Style="{StaticResource QueueWorkspaceCommandText}"
                                           Text="{DynamicResource LocQueueAdd_CancelAdd}"
                                           TextTrimming="CharacterEllipsis"
                                           TextWrapping="NoWrap" />
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <Border Grid.Row="2"
                    Padding="{DynamicResource Inset.8.All}"
                    Background="{DynamicResource Brush.Layer.Surface}"
                    BorderBrush="{DynamicResource Brush.Border.Subtle}"
                    BorderThickness="{DynamicResource Inset.1.0.1.1}"
                    SnapsToDevicePixels="True">

                <Grid FlowDirection="{DynamicResource App.FlowDirection}"
                      Language="{DynamicResource App.XmlLanguage}"
                      SnapsToDevicePixels="True">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="{DynamicResource Grid.Space.12}" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <main:QueueSummaryView Grid.Column="0"
                                           HorizontalAlignment="Stretch"
                                           VerticalAlignment="Center" />

                    <Grid Grid.Column="2"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          FlowDirection="{DynamicResource App.FlowDirection}"
                          Language="{DynamicResource App.XmlLanguage}"
                          SnapsToDevicePixels="True">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="{DynamicResource Grid.Space.8}" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="{DynamicResource Grid.Space.8}" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Command="{Binding StartProcessingCommand}"
                                Style="{StaticResource QueueWorkspaceFooterPrimaryCommand}"
                                ToolTip="{DynamicResource LocUi_Hub_StartProcessing}"
                                AutomationProperties.Name="{DynamicResource LocUi_Hub_StartProcessing}">

                            <TextBlock Style="{StaticResource QueueWorkspaceCommandText}"
                                       Text="{DynamicResource LocUi_Hub_StartProcessing}"
                                       TextTrimming="CharacterEllipsis"
                                       TextWrapping="NoWrap" />
                        </Button>

                        <Button Grid.Column="2"
                                Command="{Binding CancelProcessingCommand}"
                                Style="{StaticResource QueueWorkspaceFooterDangerCommand}"
                                ToolTip="{DynamicResource LocUi_Hub_Stop}"
                                AutomationProperties.Name="{DynamicResource LocUi_Hub_Stop}">

                            <TextBlock Style="{StaticResource QueueWorkspaceCommandText}"
                                       Text="{DynamicResource LocUi_Hub_Stop}"
                                       TextTrimming="CharacterEllipsis"
                                       TextWrapping="NoWrap" />
                        </Button>

                        <Button Grid.Column="4"
                                Command="{Binding ClearQueueCommand}"
                                Style="{StaticResource QueueWorkspaceFooterSecondaryCommand}"
                                ToolTip="{DynamicResource LocUi_Hub_ClearQueue}"
                                AutomationProperties.Name="{DynamicResource LocUi_Hub_ClearQueue}">

                            <TextBlock Style="{StaticResource QueueWorkspaceCommandText}"
                                       Text="{DynamicResource LocUi_Hub_ClearQueue}"
                                       TextTrimming="CharacterEllipsis"
                                       TextWrapping="NoWrap" />
                        </Button>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
