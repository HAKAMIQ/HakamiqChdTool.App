<UserControl x:Class="HakamiqChdTool.App.Views.Main.QueueWorkspaceView"
             x:Name="QueueWorkspaceRoot"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dd="urn:gong-wpf-dragdrop"
             FlowDirection="{DynamicResource App.FlowDirection}"
             Language="{DynamicResource App.XmlLanguage}"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">

    <UserControl.Resources>

        <Style x:Key="QueueWorkspace.ContextMenuScrollBar"
               TargetType="{x:Type ScrollBar}"
               BasedOn="{StaticResource FluentScrollBarStyle}">
            <Setter Property="Background" Value="{DynamicResource Brush.Layer.Elevated}" />
        </Style>

        <Style x:Key="QueueWorkspace.ContextMenu"
               TargetType="{x:Type ContextMenu}">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
            <Setter Property="Background" Value="{DynamicResource Brush.Layer.Elevated}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
            <Setter Property="BorderThickness" Value="{DynamicResource Inset.1.All}" />
            <Setter Property="Padding" Value="{DynamicResource Inset.4.All}" />
            <Setter Property="FlowDirection" Value="{DynamicResource App.FlowDirection}" />
            <Setter Property="Language" Value="{DynamicResource App.XmlLanguage}" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="UseLayoutRounding" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ContextMenu}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{DynamicResource Radius.Card}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True"
                                UseLayoutRounding="True">
                            <ScrollViewer Background="{TemplateBinding Background}"
                                          CanContentScroll="False"
                                          HorizontalScrollBarVisibility="Disabled"
                                          VerticalScrollBarVisibility="Auto"
                                          PanningMode="VerticalOnly"
                                          Focusable="False">
                                <ScrollViewer.Resources>
                                    <Style TargetType="{x:Type ScrollBar}"
                                           BasedOn="{StaticResource QueueWorkspace.ContextMenuScrollBar}" />
                                </ScrollViewer.Resources>

                                <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle" />
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="QueueWorkspace.ContextMenuItem"
               TargetType="{x:Type MenuItem}">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
            <Setter Property="Background" Value="{DynamicResource Brush.Transparent}" />
            <Setter Property="Padding" Value="{DynamicResource Inset.12.8}" />
            <Setter Property="MinWidth" Value="260" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="UseLayoutRounding" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type MenuItem}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="{DynamicResource Radius.Control}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True"
                                UseLayoutRounding="True">
                            <AccessText Text="{Binding Header, RelativeSource={RelativeSource TemplatedParent}}"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Stretch"
                                        FlowDirection="{TemplateBinding FlowDirection}"
                                        Language="{TemplateBinding Language}"
                                        TextAlignment="{DynamicResource AdvancedOptions.SettingsTextAlignment}"
                                        TextTrimming="CharacterEllipsis"
                                        Foreground="{TemplateBinding Foreground}" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource Brush.Control.Fill.Hover}" />
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Disabled}" />
                                <Setter TargetName="Root" Property="Opacity" Value="{DynamicResource Opacity.Disabled.Control}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="QueueWorkspace.ContextMenuSeparator"
               TargetType="{x:Type Separator}">
            <Setter Property="Height" Value="1" />
            <Setter Property="Margin" Value="8,4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Separator}">
                        <Border Height="1"
                                Background="{DynamicResource Brush.Border.Subtle}"
                                SnapsToDevicePixels="True" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="QueueWorkspace.GeneralText"
               TargetType="{x:Type TextBlock}">
            <Setter Property="FontFamily" Value="{DynamicResource FontFamily.Text}" />
            <Setter Property="FlowDirection" Value="{DynamicResource App.FlowDirection}" />
            <Setter Property="Language" Value="{DynamicResource App.XmlLanguage}" />
            <Setter Property="TextAlignment" Value="{DynamicResource AdvancedOptions.SettingsTextAlignment}" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="QueueWorkspaceHeaderTextColumn"
               TargetType="{x:Type StackPanel}">
            <Setter Property="FlowDirection" Value="{DynamicResource App.FlowDirection}" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="QueueWorkspaceHeaderTitleText"
               TargetType="{x:Type TextBlock}"
               BasedOn="{StaticResource QueueWorkspace.GeneralText}">
            <Setter Property="FontSize" Value="{DynamicResource FontSize.SectionTitle}" />
            <Setter Property="FontWeight" Value="{DynamicResource FontWeight.SemiBold}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="TextWrapping" Value="NoWrap" />
        </Style>

        <Style x:Key="QueueWorkspaceHeaderSubtitleText"
               TargetType="{x:Type TextBlock}"
               BasedOn="{StaticResource QueueWorkspace.GeneralText}">
            <Setter Property="Margin" Value="{DynamicResource Inset.0.2.0.0}" />
            <Setter Property="FontSize" Value="{DynamicResource FontSize.CaptionSmall}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="TextWrapping" Value="NoWrap" />
        </Style>

        <Style x:Key="QueueWorkspaceCommandText"
               TargetType="{x:Type TextBlock}"
               BasedOn="{StaticResource QueueWorkspace.GeneralText}">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="QueueWorkspaceDropHintText"
               TargetType="{x:Type TextBlock}"
               BasedOn="{StaticResource QueueWorkspace.GeneralText}">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="MaxWidth" Value="{DynamicResource Layout.DropHint.MaxWidth}" />
            <Setter Property="FontSize" Value="{DynamicResource FontSize.BodyStrong}" />
            <Setter Property="FontWeight" Value="{DynamicResource FontWeight.SemiBold}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="QueueWorkspaceActivityCardTitleText"
               TargetType="{x:Type TextBlock}"
               BasedOn="{StaticResource QueueWorkspace.GeneralText}">
            <Setter Property="FontSize" Value="{DynamicResource FontSize.BodyStrong}" />
            <Setter Property="FontWeight" Value="{DynamicResource FontWeight.SemiBold}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="TextWrapping" Value="NoWrap" />
        </Style>

        <Style x:Key="QueueWorkspaceActivityCardBodyText"
               TargetType="{x:Type TextBlock}"
               BasedOn="{StaticResource QueueWorkspace.GeneralText}">
            <Setter Property="Margin" Value="{DynamicResource Inset.0.4.0.0}" />
            <Setter Property="FontSize" Value="{DynamicResource FontSize.BodySmall}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="QueueWorkspaceIntakeOverlay"
               TargetType="{x:Type Grid}">
            <Setter Property="Panel.ZIndex" Value="40" />
            <Setter Property="Visibility" Value="Collapsed" />
            <Setter Property="FlowDirection" Value="{DynamicResource App.FlowDirection}" />
            <Setter Property="Language" Value="{DynamicResource App.XmlLanguage}" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsIntakeActive}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="QueueWorkspaceIntakeDialog"
               TargetType="{x:Type Border}">
            <Setter Property="Width" Value="420" />
            <Setter Property="MaxWidth" Value="520" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Padding" Value="{DynamicResource Inset.16.All}" />
            <Setter Property="Background" Value="{DynamicResource Brush.Layer.Elevated}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
            <Setter Property="BorderThickness" Value="{DynamicResource Inset.1.All}" />
            <Setter Property="CornerRadius" Value="{DynamicResource Radius.Card}" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>


        <Style x:Key="QueueWorkspaceToolButton"
               TargetType="{x:Type Button}">
            <Setter Property="MinHeight" Value="{DynamicResource Space.36}" />
            <Setter Property="Padding" Value="{DynamicResource Inset.10.6}" />
            <Setter Property="Background" Value="{DynamicResource Brush.Control.Fill.Rest}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Control.Stroke.Default}" />
            <Setter Property="BorderThickness" Value="{DynamicResource Inset.1.All}" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FlowDirection" Value="{DynamicResource App.FlowDirection}" />
            <Setter Property="Language" Value="{DynamicResource App.XmlLanguage}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{DynamicResource Radius.Control}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              RecognizesAccessKey="True"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                    <Condition Property="IsPressed" Value="False" />
                                    <Condition Property="IsEnabled" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Brush.Control.Fill.Hover}" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Brush.Control.Stroke.Strong}" />
                                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
                            </MultiTrigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Brush.Accent.SelectedBackground}" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Brush.Accent.SelectedBorder}" />
                                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Brush.Control.Fill.Disabled}" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Brush.Control.Stroke.Default}" />
                                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="QueueWorkspaceFooterCommandBase"
               TargetType="{x:Type Button}">
            <Setter Property="MinHeight" Value="{DynamicResource Space.36}" />
            <Setter Property="Padding" Value="{DynamicResource Inset.12.8}" />
            <Setter Property="Background" Value="{DynamicResource Brush.Control.Fill.Rest}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Control.Stroke.Default}" />
            <Setter Property="BorderThickness" Value="{DynamicResource Inset.1.All}" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FlowDirection" Value="{DynamicResource App.FlowDirection}" />
            <Setter Property="Language" Value="{DynamicResource App.XmlLanguage}" />
            <Setter Property="FontSize" Value="{DynamicResource FontSize.BodySmall}" />
            <Setter Property="FontWeight" Value="{DynamicResource FontWeight.SemiBold}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{DynamicResource Radius.Control}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              RecognizesAccessKey="True"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                    <Condition Property="IsPressed" Value="False" />
                                    <Condition Property="IsEnabled" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Brush.Control.Fill.Hover}" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Brush.Control.Stroke.Strong}" />
                                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
                            </MultiTrigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Brush.Accent.SelectedBackground}" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Brush.Accent.SelectedBorder}" />
                                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Brush.Control.Fill.Disabled}" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Brush.Control.Stroke.Default}" />
                                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="QueueWorkspaceFooterPrimaryCommand"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource QueueWorkspaceFooterCommandBase}">
            <Setter Property="MinWidth" Value="148" />
            <Setter Property="MaxWidth" Value="180" />
            <Setter Property="Background" Value="{DynamicResource Brush.Accent}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.Foreground.OnAccent}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{DynamicResource Radius.Control}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              RecognizesAccessKey="True"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                    <Condition Property="IsPressed" Value="False" />
                                    <Condition Property="IsEnabled" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Brush.Accent.Hover}" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Brush.Accent.Hover}" />
                                <Setter Property="Foreground" Value="{DynamicResource Brush.Foreground.OnAccent}" />
                            </MultiTrigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Brush.Accent.Pressed}" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Brush.Accent.Pressed}" />
                                <Setter Property="Foreground" Value="{DynamicResource Brush.Foreground.OnAccent}" />
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Brush.Control.Fill.Disabled}" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Brush.Control.Stroke.Default}" />
                                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="QueueWorkspaceFooterSecondaryCommand"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource QueueWorkspaceFooterCommandBase}">
            <Setter Property="MinWidth" Value="112" />
            <Setter Property="MaxWidth" Value="144" />
        </Style>

        <Style x:Key="QueueWorkspaceFooterDangerCommand"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource QueueWorkspaceFooterCommandBase}">
            <Setter Property="MinWidth" Value="108" />
            <Setter Property="MaxWidth" Value="140" />
        </Style>
    </UserControl.Resources>

    <Border x:Name="WorkspaceCardRoot"
            AllowDrop="True"
            Drop="ForwardWorkspaceDrop"
            PreviewDragOver="ForwardWorkspacePreviewDragOver"
            PreviewDragLeave="ForwardWorkspacePreviewDragLeave"
            PreviewDrop="ForwardWorkspacePreviewDrop"
            Style="{StaticResource FluentWorkspaceCard}"
            ClipToBounds="True">

        <Grid FlowDirection="{DynamicResource App.FlowDirection}"
              SnapsToDevicePixels="True"
              ClipToBounds="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Style="{StaticResource FluentQueueWorkspaceHeader}">
                <Grid FlowDirection="{DynamicResource App.FlowDirection}"
                      SnapsToDevicePixels="True">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="{DynamicResource Grid.Space.8}" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0"
                          MinWidth="0"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Center"
                          FlowDirection="{DynamicResource App.FlowDirection}"
                          SnapsToDevicePixels="True">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="{DynamicResource Grid.Space.8}" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Viewbox Grid.Column="0"
                                 Width="{DynamicResource Space.20}"
                                 Height="{DynamicResource Space.20}"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 FlowDirection="LeftToRight"
                                 Stretch="Uniform">
                            <Path Data="{StaticResource Icon.DocumentAdd}"
                                  Fill="{DynamicResource Brush.Accent}"
                                  Stretch="Uniform" />
                        </Viewbox>

                        <StackPanel Grid.Column="2"
                                    MinWidth="0"
                                    Style="{StaticResource QueueWorkspaceHeaderTextColumn}">
                            <TextBlock Style="{StaticResource QueueWorkspaceHeaderTitleText}"
                                       Text="{DynamicResource LocUi_QueueSection_Title}" />

                            <TextBlock Style="{StaticResource QueueWorkspaceHeaderSubtitleText}"
                                       Text="{DynamicResource LocUi_QueueSection_Subtitle}" />
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Column="2"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          FlowDirection="{DynamicResource App.FlowDirection}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="{DynamicResource Grid.Space.6}" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Command="{Binding SelectFilesCommand}"
                                IsEnabled="{Binding IsShellEnabled}"
                                Style="{StaticResource QueueWorkspaceToolButton}">
                            <Grid FlowDirection="{DynamicResource App.FlowDirection}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="{DynamicResource Grid.Space.6}" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Viewbox Grid.Column="0"
                                         Width="{DynamicResource Space.16}"
                                         Height="{DynamicResource Space.16}"
                                         FlowDirection="LeftToRight"
                                         Stretch="Uniform">
                                    <Path Data="{StaticResource Icon.DocumentAdd}"
                                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                                          Stretch="Uniform" />
                                </Viewbox>

                                <TextBlock Grid.Column="2"
                                           Style="{StaticResource QueueWorkspaceCommandText}"
                                           Text="{DynamicResource LocUi_Hub_AddFiles}" />
                            </Grid>
                        </Button>

                        <Button Grid.Column="2"
                                Command="{Binding SelectFolderCommand}"
                                IsEnabled="{Binding IsShellEnabled}"
                                Style="{StaticResource QueueWorkspaceToolButton}">
                            <Grid FlowDirection="{DynamicResource App.FlowDirection}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="{DynamicResource Grid.Space.6}" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Viewbox Grid.Column="0"
                                         Width="{DynamicResource Space.16}"
                                         Height="{DynamicResource Space.16}"
                                         FlowDirection="LeftToRight"
                                         Stretch="Uniform">
                                    <Path Data="{StaticResource Icon.FolderAdd}"
                                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                                          Stretch="Uniform" />
                                </Viewbox>

                                <TextBlock Grid.Column="2"
                                           Style="{StaticResource QueueWorkspaceCommandText}"
                                           Text="{DynamicResource LocUi_Hub_AddFolder}" />
                            </Grid>
                        </Button>
                    </Grid>
                </Grid>
            </Border>

            <Grid x:Name="QueueHostSurface"
                  Grid.Row="1"
                  MinHeight="{DynamicResource Layout.Queue.MinHeight}"
                  Background="{DynamicResource Brush.Layer.Surface}"
                  FlowDirection="{DynamicResource App.FlowDirection}"
                  ClipToBounds="True"
                  SnapsToDevicePixels="True">

                <Rectangle x:Name="DropZoneDashedFrame"
                           Margin="{DynamicResource Inset.8.All}"
                           RadiusX="{DynamicResource Space.12}"
                           RadiusY="{DynamicResource Space.12}"
                           Fill="{DynamicResource Brush.Transparent}"
                           IsHitTestVisible="False"
                           Stroke="{DynamicResource DropZoneBorderBrush}"
                           StrokeDashArray="{DynamicResource StrokeDash.DropZone}"
                           StrokeThickness="{DynamicResource StrokeThickness.Control}">
                    <Rectangle.Style>
                        <Style TargetType="{x:Type Rectangle}">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasItems, ElementName=TasksDataGrid}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Rectangle.Style>
                </Rectangle>

                <Border x:Name="DropHighlightOverlay"
                        Margin="{DynamicResource Inset.8.All}"
                        Background="{DynamicResource Brush.Accent}"
                        CornerRadius="{DynamicResource Radius.Card}"
                        IsHitTestVisible="False"
                        Opacity="{DynamicResource Opacity.Hidden}"
                        SnapsToDevicePixels="True" />

                <DataGrid x:Name="TasksDataGrid"
                          ItemsSource="{Binding QueueItems}"
                          SelectedItem="{Binding SelectedTask, Mode=TwoWay}"
                          EnableRowVirtualization="True"
                          EnableColumnVirtualization="True"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          VirtualizingPanel.ScrollUnit="Item"
                          ScrollViewer.CanContentScroll="True"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          Margin="{DynamicResource Inset.8.All}"
                          FlowDirection="{DynamicResource App.FlowDirection}"
                          Language="{DynamicResource App.XmlLanguage}"
                          AllowDrop="True"
                          Drop="ForwardWorkspaceDrop"
                          dd:DragDrop.IsDragSource="True"
                          dd:DragDrop.IsDropTarget="False"
                          CellStyle="{StaticResource FluentDataGridCell}"
                          LoadingRow="ForwardTasksLoadingRow"
                          UnloadingRow="ForwardTasksUnloadingRow"
                          ScrollViewer.ScrollChanged="ForwardTasksScrollChanged"
                          PreviewMouseRightButtonDown="ForwardTasksPreviewMouseRightButtonDown"
                          MouseDoubleClick="ForwardTasksMouseDoubleClick"
                          RowStyle="{StaticResource FluentDataGridRow}"
                          Style="{StaticResource FluentMinimalDataGrid}"
                          Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                          SelectionChanged="ForwardTasksSelectionChanged">

                    <DataGrid.Resources>
                        <Style TargetType="{x:Type ScrollBar}"
                               BasedOn="{StaticResource FluentScrollBarStyle}" />
                    </DataGrid.Resources>

                    <DataGrid.ContextMenu>
                        <ContextMenu DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Mode=Self}}"
                                     FlowDirection="{Binding PlacementTarget.FlowDirection, RelativeSource={RelativeSource Mode=Self}}"
                                     Language="{Binding PlacementTarget.Language, RelativeSource={RelativeSource Mode=Self}}"
                                     Style="{StaticResource QueueWorkspace.ContextMenu}"
                                     Opened="ForwardQueueContextMenuOpened">
                            <ContextMenu.Resources>
                                <Style TargetType="{x:Type MenuItem}"
                                       BasedOn="{StaticResource QueueWorkspace.ContextMenuItem}" />
                                <Style TargetType="{x:Type Separator}"
                                       BasedOn="{StaticResource QueueWorkspace.ContextMenuSeparator}" />
                            </ContextMenu.Resources>
                            <MenuItem Command="{Binding ProcessIsoCueGdiCommand}"
                                      CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                      Header="{DynamicResource LocCtx_ConvertToChd}" />

                            <MenuItem Command="{Binding ProcessArchiveCommand}"
                                      CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                      Header="{DynamicResource LocCtx_ExtractArchive}" />

                            <MenuItem Command="{Binding ProcessChdExtractCommand}"
                                      CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                      Header="{DynamicResource LocCtx_ExtractFromChd}" />

                            <MenuItem Command="{Binding CancelQueueJobCommand}"
                                      CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                      Header="{DynamicResource LocCtx_CancelJob}" />

                            <Separator />

                            <MenuItem Command="{Binding RetryQueueItemCommand}"
                                      CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                      Header="{DynamicResource LocCtx_Retry}" />

                            <MenuItem Command="{Binding RemoveQueueItemCommand}"
                                      CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                      Header="{DynamicResource LocCtx_Remove}" />

                            <MenuItem Command="{Binding OpenFolderCommand}"
                                      CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                      Header="{DynamicResource LocCtx_OpenPath}" />
                        </ContextMenu>
                    </DataGrid.ContextMenu>

                    <DataGrid.Columns>
                        <DataGridTemplateColumn Width="*"
                                                CellTemplate="{StaticResource FluentQueueRowTemplate}" />
                    </DataGrid.Columns>
                </DataGrid>


                <Grid Style="{StaticResource QueueWorkspaceIntakeOverlay}">
                    <Rectangle Fill="{DynamicResource Brush.Text.Primary}"
                               Opacity="0.22"
                               SnapsToDevicePixels="True" />

                    <Border Style="{StaticResource QueueWorkspaceIntakeDialog}">
                        <Grid FlowDirection="{DynamicResource App.FlowDirection}"
                              Language="{DynamicResource App.XmlLanguage}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="{DynamicResource Grid.Space.10}" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="{DynamicResource Grid.Space.8}" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="{DynamicResource Grid.Space.8}" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0"
                                  FlowDirection="{DynamicResource App.FlowDirection}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="{DynamicResource Grid.Space.10}" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Viewbox Grid.Column="0"
                                         Width="{DynamicResource Space.22}"
                                         Height="{DynamicResource Space.22}"
                                         VerticalAlignment="Center"
                                         FlowDirection="LeftToRight"
                                         Stretch="Uniform">
                                    <Path Data="{StaticResource Icon.DocumentAdd}"
                                          Fill="{DynamicResource Brush.Accent}"
                                          Stretch="Uniform" />
                                </Viewbox>

                                <StackPanel Grid.Column="2"
                                            MinWidth="0"
                                            FlowDirection="{DynamicResource App.FlowDirection}">
                                    <TextBlock Style="{StaticResource QueueWorkspaceActivityCardTitleText}"
                                               Text="{Binding IntakeTitle}" />
                                    <TextBlock Style="{StaticResource QueueWorkspaceActivityCardBodyText}"
                                               Text="{Binding IntakeStageText}" />
                                </StackPanel>
                            </Grid>

                            <StackPanel Grid.Row="2"
                                        FlowDirection="{DynamicResource App.FlowDirection}">
                                <TextBlock Style="{StaticResource QueueWorkspaceActivityCardBodyText}"
                                           Text="{Binding IntakeAddedText}" />
                                <TextBlock Style="{StaticResource QueueWorkspaceActivityCardBodyText}"
                                           Text="{Binding IntakeScannedText}" />
                                <TextBlock Style="{StaticResource QueueWorkspaceActivityCardBodyText}"
                                           Text="{Binding IntakeWarningText}"
                                           Visibility="{Binding IsIntakeWarningVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            </StackPanel>

                            <ProgressBar Grid.Row="4"
                                         Height="{DynamicResource Space.4}"
                                         FlowDirection="LeftToRight"
                                         Background="{DynamicResource Brush.Progress.Track}"
                                         Foreground="{DynamicResource Brush.Accent}"
                                         BorderThickness="{DynamicResource Inset.None}"
                                         IsIndeterminate="True" />

                            <Button Grid.Row="6"
                                    HorizontalAlignment="Center"
                                    Command="{Binding CancelIntakeCommand}"
                                    IsEnabled="{Binding IntakeCanCancel}"
                                    Style="{StaticResource QueueWorkspaceFooterDangerCommand}">
                                <TextBlock Style="{StaticResource QueueWorkspaceCommandText}"
                                           Text="{DynamicResource LocQueueAdd_CancelAdd}" />
                            </Button>
                        </Grid>
                    </Border>
                </Grid>

                <Border x:Name="EmptyQueueDropHint"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Panel.ZIndex="{DynamicResource Panel.ZIndex.Overlay}"
                        IsHitTestVisible="False"
                        Padding="{DynamicResource Inset.8.All}">
                    <Border.Style>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasItems, ElementName=TasksDataGrid}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>

                    <Grid HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          FlowDirection="{DynamicResource App.FlowDirection}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="{DynamicResource Grid.Space.8}" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Width="{DynamicResource Space.48}"
                                Height="{DynamicResource Space.48}"
                                HorizontalAlignment="Center"
                                Background="{DynamicResource Brush.Accent.Subtle}"
                                BorderBrush="{DynamicResource Brush.Transparent}"
                                BorderThickness="{DynamicResource Inset.None}"
                                CornerRadius="{DynamicResource Radius.DropHintIcon}"
                                SnapsToDevicePixels="True">
                            <Viewbox Width="{DynamicResource Space.24}"
                                     Height="{DynamicResource Space.24}"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     FlowDirection="LeftToRight"
                                     Stretch="Uniform">
                                <Path Data="{StaticResource Icon.FolderOpen}"
                                      Fill="{DynamicResource Brush.Accent}"
                                      Stretch="Uniform" />
                            </Viewbox>
                        </Border>

                        <TextBlock Grid.Row="2">
                            <TextBlock.Style>
                                <Style TargetType="{x:Type TextBlock}"
                                       BasedOn="{StaticResource QueueWorkspaceDropHintText}">
                                    <Setter Property="Text" Value="{DynamicResource LocUi_DropZone_Convert}" />

                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding OperationModeKey, ElementName=QueueWorkspaceRoot}" Value="Extract">
                                            <Setter Property="Text" Value="{DynamicResource LocUi_DropZone_Extract}" />
                                        </DataTrigger>

                                        <DataTrigger Binding="{Binding OperationModeKey, ElementName=QueueWorkspaceRoot}" Value="Verify">
                                            <Setter Property="Text" Value="{DynamicResource LocUi_DropZone_Verify}" />
                                        </DataTrigger>

                                        <DataTrigger Binding="{Binding OperationModeKey, ElementName=QueueWorkspaceRoot}" Value="ScanConvert">
                                            <Setter Property="Text" Value="{DynamicResource LocUi_DropZone_ScanConvert}" />
                                        </DataTrigger>

                                        <DataTrigger Binding="{Binding OperationModeKey, ElementName=QueueWorkspaceRoot}" Value="ScanExtract">
                                            <Setter Property="Text" Value="{DynamicResource LocUi_DropZone_ScanExtract}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="2"
                    Padding="{DynamicResource Inset.8.All}"
                    Background="{DynamicResource Brush.Layer.Surface}"
                    BorderBrush="{DynamicResource Brush.Border.Subtle}"
                    BorderThickness="{DynamicResource Inset.1.All}"
                    SnapsToDevicePixels="True">
                <Grid FlowDirection="{DynamicResource App.FlowDirection}"
                      SnapsToDevicePixels="True">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="1"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          FlowDirection="{DynamicResource App.FlowDirection}"
                          SnapsToDevicePixels="True">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="{DynamicResource Grid.Space.8}" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="{DynamicResource Grid.Space.8}" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Command="{Binding StartProcessingCommand}"
                                Style="{StaticResource QueueWorkspaceFooterPrimaryCommand}">
                            <TextBlock Style="{StaticResource QueueWorkspaceCommandText}"
                                       Text="{DynamicResource LocUi_Hub_StartProcessing}" />
                        </Button>

                        <Button Grid.Column="2"
                                Command="{Binding CancelProcessingCommand}"
                                Style="{StaticResource QueueWorkspaceFooterDangerCommand}">
                            <TextBlock Style="{StaticResource QueueWorkspaceCommandText}"
                                       Text="{DynamicResource LocUi_Hub_Stop}" />
                        </Button>

                        <Button Grid.Column="4"
                                Command="{Binding ClearQueueCommand}"
                                Style="{StaticResource QueueWorkspaceFooterSecondaryCommand}">
                            <TextBlock Style="{StaticResource QueueWorkspaceCommandText}"
                                       Text="{DynamicResource LocUi_Hub_ClearQueue}" />
                        </Button>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
