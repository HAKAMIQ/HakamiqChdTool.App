<UserControl x:Class="HakamiqChdTool.App.Views.Main.MainHeaderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
             FlowDirection="{DynamicResource App.FlowDirection}"
             Language="{DynamicResource App.XmlLanguage}"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">

    <UserControl.Resources>
        <Style x:Key="MainHeaderBrandGroup"
               TargetType="{x:Type Grid}">
            <Setter Property="FlowDirection" Value="{DynamicResource App.FlowDirection}" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="MainHeaderTitleColumn"
               TargetType="{x:Type StackPanel}">
            <Setter Property="FlowDirection" Value="{DynamicResource App.FlowDirection}" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="MainHeaderGeneralText"
               TargetType="{x:Type TextBlock}">
            <Setter Property="FontFamily" Value="{DynamicResource FontFamily.Text}" />
            <Setter Property="FlowDirection" Value="{DynamicResource App.FlowDirection}" />
            <Setter Property="Language" Value="{DynamicResource App.XmlLanguage}" />
            <Setter Property="TextAlignment" Value="{DynamicResource App.TextAlignment}" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="MainHeaderTitleText"
               TargetType="{x:Type TextBlock}"
               BasedOn="{StaticResource MainHeaderGeneralText}">
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="{DynamicResource FontWeight.SemiBold}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="TextWrapping" Value="NoWrap" />
        </Style>

        <Style x:Key="MainHeaderSubtitleText"
               TargetType="{x:Type TextBlock}"
               BasedOn="{StaticResource MainHeaderGeneralText}">
            <Setter Property="Margin" Value="{DynamicResource Inset.0.2.0.0}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
            <Setter Property="FontSize" Value="{DynamicResource FontSize.CaptionSmall}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="TextWrapping" Value="NoWrap" />
        </Style>

        <Style x:Key="MainHeaderButtonText"
               TargetType="{x:Type TextBlock}"
               BasedOn="{StaticResource MainHeaderGeneralText}">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="{DynamicResource App.TextAlignment}" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="MainHeaderLogoSurface"
               TargetType="{x:Type Border}">
            <Setter Property="Width" Value="{DynamicResource Space.40}" />
            <Setter Property="Height" Value="{DynamicResource Space.40}" />
            <Setter Property="Background" Value="{DynamicResource HeaderLogoPlateBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource HeaderLogoPlateBorderBrush}" />
            <Setter Property="BorderThickness" Value="{DynamicResource Inset.1.All}" />
            <Setter Property="CornerRadius" Value="{DynamicResource Radius.Control}" />
            <Setter Property="ClipToBounds" Value="True" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="UseLayoutRounding" Value="True" />
        </Style>

        <Style x:Key="MainHeaderDivider"
               TargetType="{x:Type Border}">
            <Setter Property="Width" Value="{DynamicResource StrokeThickness.Control}" />
            <Setter Property="Height" Value="{DynamicResource Space.24}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Background" Value="{DynamicResource Brush.Border.Subtle}" />
            <Setter Property="Opacity" Value="{DynamicResource Opacity.Divider.Subtle}" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="MainHeaderGhostButton"
               TargetType="{x:Type Button}">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="MinWidth" Value="58" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Background" Value="{DynamicResource Brush.Transparent}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Transparent}" />
            <Setter Property="BorderThickness" Value="{DynamicResource Inset.1.All}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
            <Setter Property="FontFamily" Value="{DynamicResource FontFamily.Text}" />
            <Setter Property="FontSize" Value="{DynamicResource FontSize.CaptionSmall}" />
            <Setter Property="FontWeight" Value="{DynamicResource FontWeight.SemiBold}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FlowDirection" Value="{DynamicResource App.FlowDirection}" />
            <Setter Property="Language" Value="{DynamicResource App.XmlLanguage}" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="UseLayoutRounding" Value="True" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{DynamicResource Radius.Control}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root"
                                        Property="Background"
                                        Value="{DynamicResource Brush.Layer.Surface}" />
                                <Setter TargetName="Root"
                                        Property="BorderBrush"
                                        Value="{DynamicResource Brush.Border.Subtle}" />
                                <Setter Property="Foreground"
                                        Value="{DynamicResource Brush.Text.Primary}" />
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root"
                                        Property="Background"
                                        Value="{DynamicResource Brush.Layer.Card}" />
                                <Setter TargetName="Root"
                                        Property="BorderBrush"
                                        Value="{DynamicResource Brush.Border.Subtle}" />
                                <Setter Property="Foreground"
                                        Value="{DynamicResource Brush.Text.Primary}" />
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MainHeaderCaptionBtnStyle"
               TargetType="{x:Type Button}">
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="56" />
            <Setter Property="Padding" Value="{DynamicResource Inset.None}" />
            <Setter Property="Background" Value="{DynamicResource Brush.Transparent}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Transparent}" />
            <Setter Property="BorderThickness" Value="{DynamicResource Inset.None}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FlowDirection" Value="{DynamicResource App.FlowDirection}" />
            <Setter Property="Language" Value="{DynamicResource App.XmlLanguage}" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="UseLayoutRounding" Value="True" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root"
                                        Property="Background"
                                        Value="{DynamicResource Brush.Layer.Surface}" />
                                <Setter Property="Foreground"
                                        Value="{DynamicResource Brush.Text.Primary}" />
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root"
                                        Property="Background"
                                        Value="{DynamicResource Brush.Layer.Card}" />
                                <Setter Property="Foreground"
                                        Value="{DynamicResource Brush.Text.Primary}" />
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MainHeaderCaptionCloseBtnStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource MainHeaderCaptionBtnStyle}" />
    </UserControl.Resources>

    <Border Background="{DynamicResource Brush.Layer.Canvas}"
            BorderBrush="{DynamicResource Brush.Transparent}"
            BorderThickness="{DynamicResource Inset.None}"
            SnapsToDevicePixels="True">

        <Grid FlowDirection="{DynamicResource App.FlowDirection}"
              SnapsToDevicePixels="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="{DynamicResource Grid.Space.56}" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  Margin="{DynamicResource Inset.16.0.16.0}"
                  VerticalAlignment="Stretch"
                  FlowDirection="{DynamicResource App.FlowDirection}"
                  SnapsToDevicePixels="True">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="{DynamicResource Grid.Space.16}" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="{DynamicResource Grid.Space.12}" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="{DynamicResource Grid.Space.12}" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0"
                      MinWidth="0"
                      Style="{StaticResource MainHeaderBrandGroup}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="{DynamicResource Grid.Space.12}" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Style="{StaticResource MainHeaderLogoSurface}">
                        <Image Width="40"
                               Height="44"
                               Margin="{DynamicResource Inset.None}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Source="pack://application:,,,/Resources/HakamiqLogo.png"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               SnapsToDevicePixels="True" />
                    </Border>

                    <StackPanel Grid.Column="2"
                                MinWidth="0"
                                Style="{StaticResource MainHeaderTitleColumn}">
                        <TextBlock Style="{StaticResource MainHeaderTitleText}"
                                   Text="{DynamicResource LocUi_WindowTitle}" />

                        <TextBlock Style="{StaticResource MainHeaderSubtitleText}"
                                   Text="{DynamicResource LocUi_WindowSubtitle}" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Column="2"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      FlowDirection="{DynamicResource App.FlowDirection}"
                      SnapsToDevicePixels="True">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="{DynamicResource Grid.Space.6}" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button x:Name="HeaderSettingsButton"
                            Grid.Column="0"
                            Command="{Binding OpenAdvancedOptionsCommand}"
                            Style="{StaticResource MainHeaderGhostButton}"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <TextBlock Text="{DynamicResource LocUi_Header_Settings}"
                                   Style="{StaticResource MainHeaderButtonText}" />
                    </Button>

                    <Button x:Name="HeaderAboutButton"
                            Grid.Column="2"
                            Command="{Binding OpenAboutCommand}"
                            Style="{StaticResource MainHeaderGhostButton}"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <TextBlock Text="{DynamicResource LocUi_Header_About}"
                                   Style="{StaticResource MainHeaderButtonText}" />
                    </Button>
                </Grid>

                <Border Grid.Column="4"
                        Style="{StaticResource MainHeaderDivider}" />

                <StackPanel Grid.Column="6"
                            Orientation="Horizontal"
                            FlowDirection="{DynamicResource App.CaptionButtonsFlowDirection}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            SnapsToDevicePixels="True">

                    <Button x:Name="CaptionMinimizeButton"
                            ToolTip="{DynamicResource LocUi_Header_Minimize}"
                            Click="ForwardMinimizeRequested"
                            Style="{StaticResource MainHeaderCaptionBtnStyle}"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">

                        <Viewbox Width="{DynamicResource Space.12}"
                                 Height="{DynamicResource Space.12}"
                                 Stretch="Uniform"
                                 FlowDirection="LeftToRight">

                            <Path Data="{StaticResource Icon.Minimize}"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                                  Stretch="Uniform" />
                        </Viewbox>
                    </Button>

                    <Button x:Name="CaptionMaximizeRestoreButton"
                            ToolTip="{DynamicResource LocUi_Header_Maximize}"
                            Click="ForwardMaximizeRestoreRequested"
                            Style="{StaticResource MainHeaderCaptionBtnStyle}"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">

                        <Viewbox Width="{DynamicResource Space.12}"
                                 Height="{DynamicResource Space.12}"
                                 Stretch="Uniform"
                                 FlowDirection="LeftToRight">

                            <Path x:Name="CaptionMaximizeRestorePath"
                                  Data="{StaticResource Icon.Maximize}"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                                  Stretch="Uniform" />
                        </Viewbox>
                    </Button>

                    <Button x:Name="CaptionCloseButton"
                            ToolTip="{DynamicResource LocUi_Header_Close}"
                            Click="ForwardCloseRequested"
                            Style="{StaticResource MainHeaderCaptionCloseBtnStyle}"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">

                        <Viewbox Width="{DynamicResource Space.12}"
                                 Height="{DynamicResource Space.12}"
                                 Stretch="Uniform"
                                 FlowDirection="LeftToRight">

                            <Path Data="{StaticResource Icon.Close}"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                                  Stretch="Uniform" />
                        </Viewbox>
                    </Button>
                </StackPanel>
            </Grid>

            <Border Grid.Row="1"
                    Height="{DynamicResource StrokeThickness.Control}"
                    Background="{DynamicResource Brush.Border.Subtle}"
                    Opacity="{DynamicResource Opacity.Divider.Subtle}"
                    SnapsToDevicePixels="True" />
        </Grid>
    </Border>
</UserControl>
