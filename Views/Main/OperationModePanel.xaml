<UserControl x:Class="HakamiqChdTool.App.Views.Main.OperationModePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:input="clr-namespace:System.Windows.Input;assembly=PresentationCore"
             FlowDirection="{DynamicResource App.FlowDirection}"
             Language="{DynamicResource App.XmlLanguage}"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">

    <UserControl.Resources>
        <Style x:Key="OperationModePanelText"
               TargetType="{x:Type TextBlock}">
            <Setter Property="FontFamily" Value="{DynamicResource FontFamily.Text}" />
            <Setter Property="FlowDirection" Value="{DynamicResource App.FlowDirection}" />
            <Setter Property="Language" Value="{DynamicResource App.XmlLanguage}" />
            <Setter Property="TextAlignment" Value="{DynamicResource AdvancedOptions.SettingsTextAlignment}" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="ToolTipService.ShowDuration" Value="{DynamicResource ToolTip.ShowDuration.Long}" />
        </Style>

        <Style x:Key="OperationModePanelHeaderTitleText"
               TargetType="{x:Type TextBlock}"
               BasedOn="{StaticResource OperationModePanelText}">
            <Setter Property="FontSize" Value="{DynamicResource FontSize.BodyStrong}" />
            <Setter Property="FontWeight" Value="{DynamicResource FontWeight.SemiBold}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="TextWrapping" Value="NoWrap" />
        </Style>

        <Style x:Key="OperationModePanelModeChipText"
               TargetType="{x:Type TextBlock}"
               BasedOn="{StaticResource OperationModePanelText}">
            <Setter Property="FontSize" Value="{DynamicResource FontSize.BodySmall}" />
            <Setter Property="FontWeight" Value="{DynamicResource FontWeight.SemiBold}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="TextWrapping" Value="NoWrap" />
        </Style>

        <Style x:Key="OperationModePanelModeChip"
               TargetType="{x:Type RadioButton}">
            <Setter Property="Background" Value="{DynamicResource Brush.Layer.Card}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Control.Stroke.Default}" />
            <Setter Property="BorderThickness" Value="{DynamicResource Inset.1.All}" />
            <Setter Property="Padding" Value="{DynamicResource Inset.12.10}" />
            <Setter Property="Margin" Value="{DynamicResource Inset.None}" />
            <Setter Property="Cursor" Value="{x:Static input:Cursors.Hand}" />
            <Setter Property="FontFamily" Value="{DynamicResource FontFamily.Text}" />
            <Setter Property="FontSize" Value="{DynamicResource FontSize.BodySmall}" />
            <Setter Property="FontWeight" Value="{DynamicResource FontWeight.SemiBold}" />
            <Setter Property="MinHeight" Value="{DynamicResource Space.44}" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FlowDirection" Value="{DynamicResource App.FlowDirection}" />
            <Setter Property="Language" Value="{DynamicResource App.XmlLanguage}" />
            <Setter Property="FocusVisualStyle" Value="{StaticResource FluentFocusVisualStyle}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RadioButton}">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{DynamicResource Radius.Card}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">

                            <Grid FlowDirection="{TemplateBinding FlowDirection}"
                                  Language="{TemplateBinding Language}"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Center"
                                  SnapsToDevicePixels="True">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="{DynamicResource Grid.Space.8}" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="{DynamicResource Grid.Space.10}" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Border x:Name="SelectionBar"
                                        Grid.Column="0"
                                        Width="{DynamicResource Space.3}"
                                        Height="{DynamicResource Space.18}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Background="{DynamicResource Brush.Accent}"
                                        CornerRadius="{DynamicResource Radius.AccentLine}"
                                        IsHitTestVisible="False"
                                        Opacity="{DynamicResource Opacity.Hidden}"
                                        SnapsToDevicePixels="True" />

                                <TextBlock Grid.Column="2"
                                           Text="{TemplateBinding Content}"
                                           Foreground="{TemplateBinding Foreground}"
                                           Style="{StaticResource OperationModePanelModeChipText}" />

                                <Viewbox Grid.Column="4"
                                         Width="{DynamicResource Space.20}"
                                         Height="{DynamicResource Space.20}"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"
                                         FlowDirection="LeftToRight"
                                         Stretch="Uniform">
                                    <Path Data="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"
                                          Fill="{TemplateBinding Foreground}"
                                          Stretch="Uniform" />
                                </Viewbox>
                            </Grid>
                        </Border>

                        <ControlTemplate.Triggers>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                    <Condition Property="IsChecked" Value="False" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Brush.Control.Fill.Hover}" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Brush.Control.Stroke.Strong}" />
                                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
                            </MultiTrigger>

                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Brush.Accent.SelectedBackground}" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Brush.Accent.SelectedBorder}" />
                                <Setter TargetName="SelectionBar" Property="Opacity" Value="1" />
                                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
                            </Trigger>

                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                    <Condition Property="IsChecked" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Brush.Accent.SelectedBorder}" />
                                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
                            </MultiTrigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Brush.Control.Fill.Disabled}" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Brush.Control.Stroke.Default}" />
                                <Setter TargetName="SelectionBar" Property="Opacity" Value="{DynamicResource Opacity.Hidden}" />
                                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Disabled}" />
                                <Setter Property="Cursor" Value="{x:Static input:Cursors.Arrow}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Style="{StaticResource FluentActionCard}"
            Padding="{DynamicResource Inset.14.All}"
            HorizontalAlignment="Stretch">
        <Grid FlowDirection="{DynamicResource App.FlowDirection}"
              Language="{DynamicResource App.XmlLanguage}"
              SnapsToDevicePixels="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="{DynamicResource Grid.Space.12}" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="{DynamicResource Grid.Space.8}" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="{DynamicResource Grid.Space.8}" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="{DynamicResource Grid.Space.0}" />
                <RowDefinition Height="{DynamicResource Grid.Space.0}" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  FlowDirection="{DynamicResource App.FlowDirection}"
                  Language="{DynamicResource App.XmlLanguage}"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Center"
                  MinWidth="0"
                  SnapsToDevicePixels="True">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="{DynamicResource Grid.Space.8}" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="{DynamicResource Grid.Space.8}" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="2"
                           Text="{DynamicResource LocUi_Card_Mode_Title}"
                           ToolTip="{DynamicResource LocUi_Card_Mode_Title}"
                           Style="{StaticResource OperationModePanelHeaderTitleText}" TextAlignment="Center" />
            </Grid>

            <RadioButton x:Name="ModeConvertRadio"
                         Grid.Row="2"
                         GroupName="OperationMode"
                         IsChecked="True"
                         Tag="{StaticResource Icon.Operation.Convert}"
                         Content="{DynamicResource LocUi_Mode_Convert}"
                         ToolTip="{DynamicResource LocUi_Mode_Convert_Tooltip}"
                         Style="{StaticResource OperationModePanelModeChip}"
                         Click="OnOperationModeRadioClick" />

            <RadioButton x:Name="ModeExtractRadio"
                         Grid.Row="4"
                         GroupName="OperationMode"
                         Tag="{StaticResource Icon.Operation.Extract}"
                         Content="{DynamicResource LocUi_Mode_Extract}"
                         ToolTip="{DynamicResource LocUi_Mode_Extract_Tooltip}"
                         Style="{StaticResource OperationModePanelModeChip}"
                         Click="OnOperationModeRadioClick" />

            <RadioButton x:Name="ModeVerifyRadio"
                         Grid.Row="6"
                         GroupName="OperationMode"
                         Tag="{StaticResource Icon.Operation.Verify}"
                         Content="{DynamicResource LocUi_Mode_Verify}"
                         ToolTip="{DynamicResource LocUi_Mode_Verify_Tooltip}"
                         Style="{StaticResource OperationModePanelModeChip}"
                         Click="OnOperationModeRadioClick" />

            <RadioButton x:Name="ModeScanConvertRadio"
                         Grid.Row="9"
                         GroupName="OperationMode"
                         Visibility="Collapsed"
                         IsTabStop="False"
                         Tag="{StaticResource Icon.DatabaseSearch}"
                         Content="{DynamicResource LocUi_Mode_ScanConvert}"
                         ToolTip="{DynamicResource LocUi_Mode_ScanConvert_Tooltip}"
                         Style="{StaticResource OperationModePanelModeChip}"
                         Click="OnOperationModeRadioClick" />

            <RadioButton x:Name="ModeScanExtractRadio"
                         Grid.Row="9"
                         GroupName="OperationMode"
                         Visibility="Collapsed"
                         IsTabStop="False"
                         Tag="{StaticResource Icon.FolderZip}"
                         Content="{DynamicResource LocUi_Mode_ScanExtract}"
                         ToolTip="{DynamicResource LocUi_Mode_ScanExtract_Tooltip}"
                         Style="{StaticResource OperationModePanelModeChip}"
                         Click="OnOperationModeRadioClick" />
        </Grid>
    </Border>
</UserControl>