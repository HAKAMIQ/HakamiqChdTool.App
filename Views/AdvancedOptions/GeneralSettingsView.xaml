<UserControl x:Class="HakamiqChdTool.App.Views.AdvancedOptions.GeneralSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="{DynamicResource App.FlowDirection}"
             Language="{DynamicResource App.XmlLanguage}"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../Resources/Style/AdvancedOptionsWindowStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="GeneralSettings.HeaderTextColumn" TargetType="{x:Type StackPanel}">
                <Setter Property="FlowDirection" Value="{DynamicResource App.FlowDirection}" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>

            <Style x:Key="GeneralSettings.SectionAccent" TargetType="{x:Type Border}">
                <Setter Property="Width" Value="{DynamicResource Space.4}" />
                <Setter Property="Height" Value="{DynamicResource Space.32}" />
                <Setter Property="Background" Value="{DynamicResource Brush.Accent}" />
                <Setter Property="CornerRadius" Value="{DynamicResource Radius.Control}" />
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="VerticalAlignment" Value="Top" />
                <Setter Property="Margin" Value="{DynamicResource Inset.0.2.0.0}" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
            </Style>

            <Style x:Key="GeneralSettings.TitleText" TargetType="{x:Type TextBlock}">
                <Setter Property="FlowDirection" Value="{DynamicResource App.FlowDirection}" />
                <Setter Property="FontFamily" Value="{DynamicResource FontFamily.Text}" />
                <Setter Property="FontSize" Value="{DynamicResource FontSize.BodyStrong}" />
                <Setter Property="FontWeight" Value="{DynamicResource FontWeight.SemiBold}" />
                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
                <Setter Property="TextWrapping" Value="NoWrap" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="TextAlignment" Value="{DynamicResource AdvancedOptions.SettingsTextAlignment}" />
            </Style>

            <Style x:Key="GeneralSettings.DescriptionText" TargetType="{x:Type TextBlock}">
                <Setter Property="FlowDirection" Value="{DynamicResource App.FlowDirection}" />
                <Setter Property="FontFamily" Value="{DynamicResource FontFamily.Text}" />
                <Setter Property="FontSize" Value="{DynamicResource FontSize.CaptionSmall}" />
                <Setter Property="FontWeight" Value="{DynamicResource FontWeight.Regular}" />
                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
                <Setter Property="TextWrapping" Value="Wrap" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="TextAlignment" Value="{DynamicResource AdvancedOptions.SettingsTextAlignment}" />
            </Style>

            <Style x:Key="GeneralSettings.RowTitleText" TargetType="{x:Type TextBlock}">
                <Setter Property="FlowDirection" Value="{DynamicResource App.FlowDirection}" />
                <Setter Property="FontFamily" Value="{DynamicResource FontFamily.Text}" />
                <Setter Property="FontSize" Value="{DynamicResource FontSize.BodySmall}" />
                <Setter Property="FontWeight" Value="{DynamicResource FontWeight.SemiBold}" />
                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
                <Setter Property="TextWrapping" Value="NoWrap" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="TextAlignment" Value="{DynamicResource AdvancedOptions.SettingsTextAlignment}" />
            </Style>

            <Style x:Key="GeneralSettings.RowDescriptionText" TargetType="{x:Type TextBlock}">
                <Setter Property="FlowDirection" Value="{DynamicResource App.FlowDirection}" />
                <Setter Property="FontFamily" Value="{DynamicResource FontFamily.Text}" />
                <Setter Property="FontSize" Value="{DynamicResource FontSize.CaptionSmall}" />
                <Setter Property="FontWeight" Value="{DynamicResource FontWeight.Regular}" />
                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
                <Setter Property="TextWrapping" Value="Wrap" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="TextAlignment" Value="{DynamicResource AdvancedOptions.SettingsTextAlignment}" />
            </Style>

            <Style x:Key="GeneralSettings.ComboBox" TargetType="{x:Type ComboBox}" BasedOn="{StaticResource FluentComboBoxStyle}">
                <Setter Property="Width" Value="220" />
                <Setter Property="SelectedValuePath" Value="Tag" />
                <Setter Property="FlowDirection" Value="{DynamicResource App.FlowDirection}" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="HorizontalAlignment" Value="Center" />
            </Style>

            <Style x:Key="GeneralSettings.CheckBox" TargetType="{x:Type CheckBox}" BasedOn="{StaticResource FluentCheckBoxStyle}">
                <Setter Property="Width" Value="{DynamicResource Space.32}" />
                <Setter Property="MinWidth" Value="{DynamicResource Space.32}" />
                <Setter Property="FlowDirection" Value="{DynamicResource App.FlowDirection}" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="HorizontalAlignment" Value="Center" />
            </Style>


            <Style x:Key="GeneralSettings.CompactActionButton"
                   TargetType="{x:Type Button}"
                   BasedOn="{StaticResource SecondaryButtonStyle}">
                <Setter Property="MinWidth" Value="{DynamicResource Space.112}" />
                <Setter Property="MaxWidth" Value="{DynamicResource Space.120}" />
                <Setter Property="MinHeight" Value="{DynamicResource Space.36}" />
                <Setter Property="Padding" Value="{DynamicResource Inset.12.8}" />
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>

            <Style x:Key="GeneralSettings.SectionCard"
                   TargetType="{x:Type Border}"
                   BasedOn="{StaticResource HakamiqSettingsCard}">
                <Setter Property="Background" Value="{DynamicResource Brush.Layer.Card}" />
                <Setter Property="BorderBrush" Value="{DynamicResource Brush.Transparent}" />
                <Setter Property="BorderThickness" Value="{DynamicResource Inset.None}" />
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Style="{StaticResource HakamiqSettingsCard}"
            Padding="{DynamicResource Inset.12.All}">
        <ScrollViewer FlowDirection="{DynamicResource App.FlowDirection}"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto"
                      CanContentScroll="False"
                      PanningMode="VerticalOnly"
                      Focusable="False">
            <Grid FlowDirection="{DynamicResource App.FlowDirection}"
                  HorizontalAlignment="Stretch">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Style="{StaticResource GeneralSettings.SectionCard}"
                        Padding="{DynamicResource Inset.12.All}">
                    <Grid FlowDirection="{DynamicResource App.FlowDirection}"
                          HorizontalAlignment="Stretch">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="{DynamicResource Grid.Space.12}" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0"
                              FlowDirection="{DynamicResource App.FlowDirection}"
                              HorizontalAlignment="Stretch">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="{DynamicResource Grid.Space.12}" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Style="{StaticResource GeneralSettings.SectionAccent}" />

                            <StackPanel Grid.Column="2"
                                        Style="{StaticResource GeneralSettings.HeaderTextColumn}">
                                <TextBlock Style="{StaticResource GeneralSettings.TitleText}"
                                           Text="{DynamicResource LocGeneralSettings_AppearanceSection}" />
                            </StackPanel>
                        </Grid>

                        <Border Grid.Row="2"
                                Style="{StaticResource FluentSettingsOptionRow}">
                            <Grid Style="{StaticResource FluentSettingsOptionRowGrid}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="{DynamicResource Grid.Space.12}" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="0"
                                      Style="{StaticResource FluentSettingsOptionTextArea}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="{DynamicResource Grid.Space.4}" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Style="{StaticResource GeneralSettings.RowTitleText}"
                                               Text="{DynamicResource LocGeneralSettings_LanguageTitle}" />

                                    <TextBlock Grid.Row="2"
                                               Style="{StaticResource GeneralSettings.RowDescriptionText}"
                                               Text="{DynamicResource LocGeneralSettings_LanguageDescription}" />
                                </Grid>

                                <ComboBox x:Name="UiLanguageComboBox"
                                          Grid.Column="2"
                                          SelectedValue="{Binding UiLanguage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Style="{StaticResource GeneralSettings.ComboBox}">
                                    <ComboBoxItem Tag="ar-SA"
                                                  Content="{DynamicResource LocLanguage_Arabic}" />
                                    <ComboBoxItem Tag="en-US"
                                                  Content="{DynamicResource LocLanguage_English}" />
                                </ComboBox>
                            </Grid>
                        </Border>

                        <Border Grid.Row="3"
                                Style="{StaticResource FluentSettingsOptionRow}">
                            <Grid Style="{StaticResource FluentSettingsOptionRowGrid}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="{DynamicResource Grid.Space.12}" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="0"
                                      Style="{StaticResource FluentSettingsOptionTextArea}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="{DynamicResource Grid.Space.4}" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Style="{StaticResource GeneralSettings.RowTitleText}"
                                               Text="{DynamicResource LocGeneralSettings_ThemeTitle}" />

                                    <TextBlock Grid.Row="2"
                                               Style="{StaticResource GeneralSettings.RowDescriptionText}"
                                               Text="{DynamicResource LocGeneralSettings_ThemeDescription}" />
                                </Grid>

                                <ComboBox x:Name="ThemeComboBox"
                                          Grid.Column="2"
                                          SelectedValue="{Binding Theme, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Style="{StaticResource GeneralSettings.ComboBox}">
                                    <ComboBoxItem Tag="Light"
                                                  Content="{DynamicResource LocUi_Theme_Light}" />
                                    <ComboBoxItem Tag="Dark"
                                                  Content="{DynamicResource LocUi_Theme_Dark}" />
                                    <ComboBoxItem Tag="Hakamiq"
                                                  Content="{DynamicResource LocUi_Theme_Hakamiq}" />
                                </ComboBox>
                            </Grid>
                        </Border>

                        <Border Grid.Row="4"
                                Style="{StaticResource FluentSettingsOptionRow}">
                            <Grid Style="{StaticResource FluentSettingsOptionRowGrid}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="{DynamicResource Grid.Space.12}" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="0"
                                      Style="{StaticResource FluentSettingsOptionTextArea}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="{DynamicResource Grid.Space.4}" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Style="{StaticResource GeneralSettings.RowTitleText}"
                                               Text="{DynamicResource LocGeneralSettings_PortableModeTitle}" />

                                    <TextBlock Grid.Row="2"
                                               Style="{StaticResource GeneralSettings.RowDescriptionText}"
                                               Text="{DynamicResource LocGeneralSettings_PortableModeDescription}" />
                                </Grid>

                                <CheckBox Grid.Column="2"
                                          IsChecked="{Binding PortableMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Style="{StaticResource GeneralSettings.CheckBox}" />
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </Border>
</UserControl>
