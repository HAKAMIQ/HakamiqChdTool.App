<UserControl x:Class="HakamiqChdTool.App.Views.AdvancedOptions.PathsSettingsView"
             x:Name="PathsSettingsRoot"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="{DynamicResource App.FlowDirection}"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">

	<UserControl.Resources>
		<ResourceDictionary>
			<Style x:Key="PathsSettings.RootCard" TargetType="{x:Type Border}">
				<Setter Property="Background" Value="{DynamicResource Brush.Layer.Surface}" />
				<Setter Property="BorderBrush" Value="{DynamicResource Brush.Transparent}" />
				<Setter Property="BorderThickness" Value="{DynamicResource Inset.None}" />
				<Setter Property="CornerRadius" Value="{DynamicResource Radius.Card}" />
				<Setter Property="Padding" Value="12" />
				<Setter Property="HorizontalAlignment" Value="Stretch" />
				<Setter Property="VerticalAlignment" Value="Stretch" />
				<Setter Property="TextElement.Foreground" Value="{DynamicResource Brush.Text.Primary}" />
				<Setter Property="SnapsToDevicePixels" Value="True" />
			</Style>

			<Style x:Key="PathsSettings.SectionCard" TargetType="{x:Type Border}">
				<Setter Property="Background" Value="{DynamicResource Brush.Layer.Card}" />
				<Setter Property="BorderBrush" Value="{DynamicResource Brush.Transparent}" />
				<Setter Property="BorderThickness" Value="{DynamicResource Inset.None}" />
				<Setter Property="CornerRadius" Value="{DynamicResource Radius.Card}" />
				<Setter Property="Padding" Value="12" />
				<Setter Property="HorizontalAlignment" Value="Stretch" />
				<Setter Property="VerticalAlignment" Value="Top" />
				<Setter Property="TextElement.Foreground" Value="{DynamicResource Brush.Text.Primary}" />
				<Setter Property="SnapsToDevicePixels" Value="True" />
			</Style>

			<Style x:Key="PathsSettings.SettingRow" TargetType="{x:Type Border}">
				<Setter Property="Background" Value="{DynamicResource Brush.Transparent}" />
				<Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
				<Setter Property="BorderThickness" Value="{DynamicResource Inset.0.0.0.1}" />
				<Setter Property="Padding" Value="0,10,0,10" />
				<Setter Property="HorizontalAlignment" Value="Stretch" />
				<Setter Property="TextElement.Foreground" Value="{DynamicResource Brush.Text.Primary}" />
				<Setter Property="SnapsToDevicePixels" Value="True" />
			</Style>

			<Style x:Key="PathsSettings.LastSettingRow"
                   TargetType="{x:Type Border}"
                   BasedOn="{StaticResource PathsSettings.SettingRow}">
				<Setter Property="BorderThickness" Value="{DynamicResource Inset.None}" />
				<Setter Property="Padding" Value="0,10,0,0" />
			</Style>

			<Style x:Key="PathsSettings.HeaderTextColumn" TargetType="{x:Type StackPanel}">
				<Setter Property="FlowDirection" Value="{DynamicResource App.FlowDirection}" />
				<Setter Property="HorizontalAlignment" Value="Stretch" />
				<Setter Property="VerticalAlignment" Value="Center" />
			</Style>

			<Style x:Key="PathsSettings.SectionAccent" TargetType="{x:Type Border}">
				<Setter Property="Width" Value="{DynamicResource Space.4}" />
				<Setter Property="Height" Value="28" />
				<Setter Property="Background" Value="{DynamicResource Brush.Accent}" />
				<Setter Property="CornerRadius" Value="{DynamicResource Radius.Control}" />
				<Setter Property="HorizontalAlignment" Value="Center" />
				<Setter Property="VerticalAlignment" Value="Top" />
				<Setter Property="Margin" Value="{DynamicResource Inset.0.2.0.0}" />
				<Setter Property="SnapsToDevicePixels" Value="True" />
			</Style>

			<Style x:Key="PathsSettings.TitleText" TargetType="{x:Type TextBlock}">
				<Setter Property="FontFamily" Value="{DynamicResource FontFamily.Text}" />
				<Setter Property="FontSize" Value="{DynamicResource FontSize.BodyStrong}" />
				<Setter Property="FontWeight" Value="{DynamicResource FontWeight.SemiBold}" />
				<Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
				<Setter Property="HorizontalAlignment" Value="Center" />
				<Setter Property="FlowDirection" Value="{DynamicResource App.FlowDirection}" />
				<Setter Property="TextAlignment" Value="Center" />
				<Setter Property="TextWrapping" Value="NoWrap" />
				<Setter Property="TextTrimming" Value="CharacterEllipsis" />
			</Style>

			<Style x:Key="PathsSettings.DescriptionText" TargetType="{x:Type TextBlock}">
				<Setter Property="FontFamily" Value="{DynamicResource FontFamily.Text}" />
				<Setter Property="FontSize" Value="{DynamicResource FontSize.CaptionSmall}" />
				<Setter Property="FontWeight" Value="{DynamicResource FontWeight.Regular}" />
				<Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
				<Setter Property="HorizontalAlignment" Value="Stretch" />
				<Setter Property="FlowDirection" Value="{DynamicResource App.FlowDirection}" />
				<Setter Property="TextAlignment" Value="{DynamicResource AdvancedOptions.SettingsTextAlignment}" />
				<Setter Property="TextWrapping" Value="Wrap" />
			</Style>

			<Style x:Key="PathsSettings.RowTitleText" TargetType="{x:Type TextBlock}">
				<Setter Property="FontFamily" Value="{DynamicResource FontFamily.Text}" />
				<Setter Property="FontSize" Value="{DynamicResource FontSize.BodySmall}" />
				<Setter Property="FontWeight" Value="{DynamicResource FontWeight.SemiBold}" />
				<Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
				<Setter Property="HorizontalAlignment" Value="Stretch" />
				<Setter Property="FlowDirection" Value="{DynamicResource App.FlowDirection}" />
				<Setter Property="TextAlignment" Value="{DynamicResource AdvancedOptions.SettingsTextAlignment}" />
				<Setter Property="TextWrapping" Value="NoWrap" />
				<Setter Property="TextTrimming" Value="CharacterEllipsis" />
			</Style>

			<Style x:Key="PathsSettings.RowDescriptionText" TargetType="{x:Type TextBlock}">
				<Setter Property="FontFamily" Value="{DynamicResource FontFamily.Text}" />
				<Setter Property="FontSize" Value="{DynamicResource FontSize.CaptionSmall}" />
				<Setter Property="FontWeight" Value="{DynamicResource FontWeight.Regular}" />
				<Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
				<Setter Property="HorizontalAlignment" Value="Stretch" />
				<Setter Property="FlowDirection" Value="{DynamicResource App.FlowDirection}" />
				<Setter Property="TextAlignment" Value="{DynamicResource AdvancedOptions.SettingsTextAlignment}" />
				<Setter Property="TextWrapping" Value="Wrap" />
				<Setter Property="TextTrimming" Value="CharacterEllipsis" />
			</Style>

			<Style x:Key="PathsSettings.ChoiceControlRadio" TargetType="{x:Type RadioButton}">
				<Setter Property="Width" Value="{DynamicResource Space.32}" />
				<Setter Property="MinWidth" Value="{DynamicResource Space.32}" />
				<Setter Property="HorizontalAlignment" Value="Center" />
				<Setter Property="VerticalAlignment" Value="Center" />
				<Setter Property="FlowDirection" Value="{DynamicResource App.FlowDirection}" />
				<Setter Property="HorizontalContentAlignment" Value="Center" />
				<Setter Property="VerticalContentAlignment" Value="Center" />
			</Style>

			<Style x:Key="PathsSettings.ChoiceControlCheckBox"
                   TargetType="{x:Type CheckBox}"
                   BasedOn="{StaticResource FluentCheckBoxStyle}">
				<Setter Property="Width" Value="{DynamicResource Space.32}" />
				<Setter Property="MinWidth" Value="{DynamicResource Space.32}" />
				<Setter Property="HorizontalAlignment" Value="Center" />
				<Setter Property="VerticalAlignment" Value="Center" />
				<Setter Property="FlowDirection" Value="{DynamicResource App.FlowDirection}" />
				<Setter Property="HorizontalContentAlignment" Value="Center" />
				<Setter Property="VerticalContentAlignment" Value="Center" />
			</Style>

			<Style x:Key="PathsSettings.PathControlArea" TargetType="{x:Type Grid}">
				<Setter Property="Width" Value="340" />
				<Setter Property="HorizontalAlignment" Value="Center" />
				<Setter Property="VerticalAlignment" Value="Center" />
				<Setter Property="FlowDirection" Value="{DynamicResource App.FlowDirection}" />
			</Style>

			<Style x:Key="PathsSettings.TechnicalPathTextBox"
                   TargetType="{x:Type TextBox}"
                   BasedOn="{StaticResource FluentTechnicalTextBoxStyle}">
				<Setter Property="HorizontalAlignment" Value="Stretch" />
			</Style>

		</ResourceDictionary>
	</UserControl.Resources>

	<Border Style="{StaticResource PathsSettings.RootCard}">
		<ScrollViewer FlowDirection="{DynamicResource App.FlowDirection}"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto"
                      CanContentScroll="False"
                      PanningMode="VerticalOnly"
                      Focusable="False">

			<Grid x:Name="PathsContentGrid"
                  FlowDirection="{DynamicResource App.FlowDirection}"
                  HorizontalAlignment="Stretch">
				<Grid.RowDefinitions>
						<RowDefinition Height="Auto" />
						<RowDefinition Height="{DynamicResource Grid.Space.12}" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="{DynamicResource Grid.Space.12}" />
						<RowDefinition Height="Auto" />
				</Grid.RowDefinitions>

				<Border Grid.Row="0"
                        Style="{StaticResource PathsSettings.SectionCard}">
					<Grid FlowDirection="{DynamicResource App.FlowDirection}"
                          HorizontalAlignment="Stretch">
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto" />
							<RowDefinition Height="8" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
						</Grid.RowDefinitions>

						<Grid Grid.Row="0"
                              FlowDirection="{DynamicResource App.FlowDirection}"
                              HorizontalAlignment="Stretch">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="Auto" />
								<ColumnDefinition Width="{DynamicResource Grid.Space.12}" />
								<ColumnDefinition Width="*" />
							</Grid.ColumnDefinitions>

							<Border Grid.Column="0"
                                    Style="{StaticResource PathsSettings.SectionAccent}" />

							<StackPanel Grid.Column="2"
                                        Style="{StaticResource PathsSettings.HeaderTextColumn}">
								<TextBlock Style="{StaticResource PathsSettings.TitleText}"
                                           Text="{DynamicResource LocPaths_ChdmanSection}" />
							</StackPanel>
						</Grid>

						<Border Grid.Row="2"
                                Style="{StaticResource PathsSettings.SettingRow}">
							<Grid FlowDirection="{DynamicResource App.FlowDirection}"
                                  HorizontalAlignment="Stretch">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*" />
									<ColumnDefinition Width="{DynamicResource Grid.Space.12}" />
									<ColumnDefinition Width="Auto" />
								</Grid.ColumnDefinitions>

								<Grid Grid.Column="0"
                                      MinWidth="0"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Stretch">
									<Grid.RowDefinitions>
										<RowDefinition Height="Auto" />
										<RowDefinition Height="{DynamicResource Grid.Space.4}" />
										<RowDefinition Height="Auto" />
									</Grid.RowDefinitions>

									<TextBlock Grid.Row="0"
                                               Style="{StaticResource PathsSettings.RowTitleText}"
                                               Text="{DynamicResource LocPaths_UseBundledChdman}" />

									<TextBlock Grid.Row="2"
                                               Style="{StaticResource PathsSettings.RowDescriptionText}"
                                               Text="{DynamicResource LocPaths_UseBundledChdmanDesc}" />
								</Grid>

								<RadioButton x:Name="UseBundledChdmanRadioButton"
                                             Grid.Column="2"
                                             GroupName="ChdmanSource"
                                             IsChecked="{Binding UseBundledChdman, Mode=TwoWay}"
                                             Style="{StaticResource PathsSettings.ChoiceControlRadio}" />
							</Grid>
						</Border>

						<Border Grid.Row="3"
                                Style="{StaticResource PathsSettings.SettingRow}">
							<Grid FlowDirection="{DynamicResource App.FlowDirection}"
                                  HorizontalAlignment="Stretch">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*" />
									<ColumnDefinition Width="{DynamicResource Grid.Space.12}" />
									<ColumnDefinition Width="Auto" />
								</Grid.ColumnDefinitions>

								<Grid Grid.Column="0"
                                      MinWidth="0"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Stretch">
									<Grid.RowDefinitions>
										<RowDefinition Height="Auto" />
										<RowDefinition Height="{DynamicResource Grid.Space.4}" />
										<RowDefinition Height="Auto" />
									</Grid.RowDefinitions>

									<TextBlock Grid.Row="0"
                                               Style="{StaticResource PathsSettings.RowTitleText}"
                                               Text="{DynamicResource LocPaths_UseExternalChdman}" />

									<TextBlock Grid.Row="2"
                                               Style="{StaticResource PathsSettings.RowDescriptionText}"
                                               Text="{DynamicResource LocPaths_UseExternalChdmanDesc}" />
								</Grid>

								<RadioButton x:Name="UseExternalChdmanRadioButton"
                                             Grid.Column="2"
                                             GroupName="ChdmanSource"
                                             IsChecked="{Binding UseExternalChdman, Mode=TwoWay}"
                                             Style="{StaticResource PathsSettings.ChoiceControlRadio}" />
							</Grid>
						</Border>

						<Border Grid.Row="4"
                                Style="{StaticResource PathsSettings.LastSettingRow}">
							<Grid FlowDirection="{DynamicResource App.FlowDirection}"
                                  HorizontalAlignment="Stretch">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*" />
									<ColumnDefinition Width="{DynamicResource Grid.Space.12}" />
									<ColumnDefinition Width="Auto" />
								</Grid.ColumnDefinitions>

								<Grid Grid.Column="0"
                                      MinWidth="0"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Stretch">
									<Grid.RowDefinitions>
										<RowDefinition Height="Auto" />
										<RowDefinition Height="{DynamicResource Grid.Space.4}" />
										<RowDefinition Height="Auto" />
									</Grid.RowDefinitions>

									<TextBlock Grid.Row="0"
                                               Style="{StaticResource PathsSettings.RowTitleText}"
                                               Text="{DynamicResource LocPaths_ExternalChdmanPath}" />

									<TextBlock Grid.Row="2"
                                               Style="{StaticResource PathsSettings.RowDescriptionText}"
                                               Text="{DynamicResource LocPaths_ExternalChdmanPathDesc}" />
								</Grid>

								<Grid Grid.Column="2"
                                      Style="{StaticResource PathsSettings.PathControlArea}">
									<Grid.ColumnDefinitions>
										<ColumnDefinition Width="*" />
										<ColumnDefinition Width="{DynamicResource Grid.Space.8}" />
										<ColumnDefinition Width="Auto" />
									</Grid.ColumnDefinitions>

									<TextBox x:Name="ExternalChdmanPathTextBox"
                                             Grid.Column="0"
                                             Text="{Binding ExternalChdmanPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                                             IsEnabled="{Binding UseExternalChdman}"
                                             Style="{StaticResource PathsSettings.TechnicalPathTextBox}">
										<TextBox.ToolTip>
											<TextBlock Text="{Binding ExternalChdmanPath}"
                                                       FlowDirection="LeftToRight"
                                                       TextAlignment="Left"
                                                       Language="en-US"
                                                       TextWrapping="NoWrap" />
										</TextBox.ToolTip>
									</TextBox>

									<Button x:Name="BrowseExternalChdmanButton"
                                            Grid.Column="2"
                                            Content="{DynamicResource LocCommon_Browse}"
                                            Command="{Binding BrowseExternalChdmanCommand}"
                                            IsEnabled="{Binding UseExternalChdman}"
                                            Style="{StaticResource SecondaryButtonStyle}" />
								</Grid>
							</Grid>
						</Border>
					</Grid>
				</Border>
				<Border Grid.Row="2"
                        Style="{StaticResource PathsSettings.SectionCard}">
					<Grid FlowDirection="{DynamicResource App.FlowDirection}"
                          HorizontalAlignment="Stretch">
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto" />
							<RowDefinition Height="8" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
						</Grid.RowDefinitions>

						<Grid Grid.Row="0"
                              FlowDirection="{DynamicResource App.FlowDirection}"
                              HorizontalAlignment="Stretch">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="Auto" />
								<ColumnDefinition Width="{DynamicResource Grid.Space.12}" />
								<ColumnDefinition Width="*" />
							</Grid.ColumnDefinitions>

							<Border Grid.Column="0"
                                    Style="{StaticResource PathsSettings.SectionAccent}" />

							<StackPanel Grid.Column="2"
                                        Style="{StaticResource PathsSettings.HeaderTextColumn}">
								<TextBlock Style="{StaticResource PathsSettings.TitleText}"
                                           Text="{DynamicResource LocPaths_SaveAndTempSection}" />
							</StackPanel>
						</Grid>

						<Border Grid.Row="2"
                                Style="{StaticResource PathsSettings.SettingRow}">
							<Grid FlowDirection="{DynamicResource App.FlowDirection}"
                                  HorizontalAlignment="Stretch">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*" />
									<ColumnDefinition Width="{DynamicResource Grid.Space.12}" />
									<ColumnDefinition Width="Auto" />
								</Grid.ColumnDefinitions>

								<Grid Grid.Column="0"
                                      MinWidth="0"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Stretch">
									<Grid.RowDefinitions>
										<RowDefinition Height="Auto" />
										<RowDefinition Height="{DynamicResource Grid.Space.4}" />
										<RowDefinition Height="Auto" />
									</Grid.RowDefinitions>

									<TextBlock Grid.Row="0"
                                               Style="{StaticResource PathsSettings.RowTitleText}"
                                               Text="{DynamicResource LocPaths_CustomOutput}" />

									<TextBlock Grid.Row="2"
                                               Style="{StaticResource PathsSettings.RowDescriptionText}"
                                               Text="{DynamicResource LocPaths_CustomOutputDesc}" />
								</Grid>

								<CheckBox x:Name="UseCustomOutputRootCheckBox"
                                          Grid.Column="2"
                                          IsChecked="{Binding UseCustomOutputRoot, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Style="{StaticResource PathsSettings.ChoiceControlCheckBox}" />
							</Grid>
						</Border>

						<Border Grid.Row="3"
                                Style="{StaticResource PathsSettings.SettingRow}">
							<Grid FlowDirection="{DynamicResource App.FlowDirection}"
                                  HorizontalAlignment="Stretch">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*" />
									<ColumnDefinition Width="{DynamicResource Grid.Space.12}" />
									<ColumnDefinition Width="Auto" />
								</Grid.ColumnDefinitions>

								<Grid Grid.Column="0"
                                      MinWidth="0"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Stretch">
									<Grid.RowDefinitions>
										<RowDefinition Height="Auto" />
										<RowDefinition Height="{DynamicResource Grid.Space.4}" />
										<RowDefinition Height="Auto" />
									</Grid.RowDefinitions>

									<TextBlock Grid.Row="0"
                                               Style="{StaticResource PathsSettings.RowTitleText}"
                                               Text="{DynamicResource LocPaths_OutputFolder}" />

									<TextBlock Grid.Row="2"
                                               Style="{StaticResource PathsSettings.RowDescriptionText}"
                                               Text="{DynamicResource LocPaths_OutputFolderDesc}" />
								</Grid>

								<Grid Grid.Column="2"
                                      Style="{StaticResource PathsSettings.PathControlArea}">
									<Grid.ColumnDefinitions>
										<ColumnDefinition Width="*" />
										<ColumnDefinition Width="{DynamicResource Grid.Space.8}" />
										<ColumnDefinition Width="Auto" />
									</Grid.ColumnDefinitions>

									<TextBox x:Name="CustomOutputRootTextBox"
                                             Grid.Column="0"
                                             Text="{Binding CustomOutputRoot, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                                             IsEnabled="{Binding UseCustomOutputRoot}"
                                             Style="{StaticResource PathsSettings.TechnicalPathTextBox}">
										<TextBox.ToolTip>
											<TextBlock Text="{Binding CustomOutputRoot}"
                                                       FlowDirection="LeftToRight"
                                                       TextAlignment="Left"
                                                       Language="en-US"
                                                       TextWrapping="NoWrap" />
										</TextBox.ToolTip>
									</TextBox>

									<Button x:Name="BrowseOutputFolderButton"
                                            Grid.Column="2"
                                            Content="{DynamicResource LocCommon_Browse}"
                                            Command="{Binding BrowseOutputFolderCommand}"
                                            IsEnabled="{Binding UseCustomOutputRoot}"
                                            Style="{StaticResource SecondaryButtonStyle}" />
								</Grid>
							</Grid>
						</Border>

						<Border Grid.Row="4"
                                Style="{StaticResource PathsSettings.SettingRow}">
							<Grid FlowDirection="{DynamicResource App.FlowDirection}"
                                  HorizontalAlignment="Stretch">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*" />
									<ColumnDefinition Width="{DynamicResource Grid.Space.12}" />
									<ColumnDefinition Width="Auto" />
								</Grid.ColumnDefinitions>

								<Grid Grid.Column="0"
                                      MinWidth="0"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Stretch">
									<Grid.RowDefinitions>
										<RowDefinition Height="Auto" />
										<RowDefinition Height="{DynamicResource Grid.Space.4}" />
										<RowDefinition Height="Auto" />
									</Grid.RowDefinitions>

									<TextBlock Grid.Row="0"
                                               Style="{StaticResource PathsSettings.RowTitleText}"
                                               Text="{DynamicResource LocPaths_CustomTempFolder}" />

									<TextBlock Grid.Row="2"
                                               Style="{StaticResource PathsSettings.RowDescriptionText}"
                                               Text="{DynamicResource LocPaths_CustomTempFolderDesc}" />
								</Grid>

								<CheckBox Grid.Column="2"
                                          IsChecked="{Binding UseCustomPendingWorkspace, Mode=TwoWay}"
                                          Style="{StaticResource PathsSettings.ChoiceControlCheckBox}" />
							</Grid>
						</Border>

						<Border Grid.Row="5"
                                Style="{StaticResource PathsSettings.SettingRow}">
							<Grid FlowDirection="{DynamicResource App.FlowDirection}"
                                  HorizontalAlignment="Stretch">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*" />
									<ColumnDefinition Width="{DynamicResource Grid.Space.12}" />
									<ColumnDefinition Width="Auto" />
								</Grid.ColumnDefinitions>

								<Grid Grid.Column="0"
                                      MinWidth="0"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Stretch">
									<Grid.RowDefinitions>
										<RowDefinition Height="Auto" />
										<RowDefinition Height="{DynamicResource Grid.Space.4}" />
										<RowDefinition Height="Auto" />
									</Grid.RowDefinitions>

									<TextBlock Grid.Row="0"
                                               Style="{StaticResource PathsSettings.RowTitleText}"
                                               Text="{DynamicResource LocPaths_TempFolder}" />

									<TextBlock Grid.Row="2"
                                               Style="{StaticResource PathsSettings.RowDescriptionText}"
                                               Text="{DynamicResource LocPaths_TempFolderDesc}" />
								</Grid>

								<Grid Grid.Column="2"
                                      Style="{StaticResource PathsSettings.PathControlArea}">
									<Grid.ColumnDefinitions>
										<ColumnDefinition Width="*" />
										<ColumnDefinition Width="{DynamicResource Grid.Space.8}" />
										<ColumnDefinition Width="Auto" />
									</Grid.ColumnDefinitions>

									<TextBox x:Name="PendingWorkspaceCustomRootTextBox"
                                             Grid.Column="0"
                                             Text="{Binding PendingWorkspaceCustomRoot, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                                             IsEnabled="{Binding UseCustomPendingWorkspace}"
                                             Style="{StaticResource PathsSettings.TechnicalPathTextBox}">
										<TextBox.ToolTip>
											<TextBlock Text="{Binding PendingWorkspaceCustomRoot}"
                                                       FlowDirection="LeftToRight"
                                                       TextAlignment="Left"
                                                       Language="en-US"
                                                       TextWrapping="NoWrap" />
										</TextBox.ToolTip>
									</TextBox>

									<Button x:Name="BrowsePendingWorkspaceButton"
                                            Grid.Column="2"
                                            Content="{DynamicResource LocCommon_Browse}"
                                            Command="{Binding BrowsePendingWorkspaceCommand}"
                                            IsEnabled="{Binding UseCustomPendingWorkspace}"
                                            Style="{StaticResource SecondaryButtonStyle}" />
								</Grid>
							</Grid>
						</Border>

						<Border Grid.Row="6"
                                Style="{StaticResource PathsSettings.LastSettingRow}">
							<Grid FlowDirection="{DynamicResource App.FlowDirection}"
                                  HorizontalAlignment="Stretch">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*" />
									<ColumnDefinition Width="{DynamicResource Grid.Space.12}" />
									<ColumnDefinition Width="Auto" />
								</Grid.ColumnDefinitions>

								<Grid Grid.Column="0"
                                      MinWidth="0"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Stretch">
									<Grid.RowDefinitions>
										<RowDefinition Height="Auto" />
										<RowDefinition Height="{DynamicResource Grid.Space.4}" />
										<RowDefinition Height="Auto" />
									</Grid.RowDefinitions>

									<TextBlock Grid.Row="0"
                                               Style="{StaticResource PathsSettings.RowTitleText}"
                                               Text="{DynamicResource LocPaths_ShowStorageAdvisorDialog}" />

									<TextBlock Grid.Row="2"
                                               Style="{StaticResource PathsSettings.RowDescriptionText}"
                                               Text="{DynamicResource LocPaths_ShowStorageAdvisorDialogDesc}" />
								</Grid>

								<CheckBox Grid.Column="2"
                                          IsChecked="{Binding ShowStorageAdvisorDialog, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          IsEnabled="{Binding CanUseStorageAdvisor}"
                                          Style="{StaticResource PathsSettings.ChoiceControlCheckBox}" />
							</Grid>
						</Border>
					</Grid>
				</Border>

				<Border Grid.Row="4"
                        Style="{StaticResource PathsSettings.SectionCard}">
					<Grid FlowDirection="{DynamicResource App.FlowDirection}"
                          HorizontalAlignment="Stretch">
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto" />
							<RowDefinition Height="8" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
						</Grid.RowDefinitions>

						<Grid Grid.Row="0"
                              FlowDirection="{DynamicResource App.FlowDirection}"
                              HorizontalAlignment="Stretch">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="Auto" />
								<ColumnDefinition Width="{DynamicResource Grid.Space.12}" />
								<ColumnDefinition Width="*" />
							</Grid.ColumnDefinitions>

							<Border Grid.Column="0"
                                    Style="{StaticResource PathsSettings.SectionAccent}" />

							<StackPanel Grid.Column="2"
                                        Style="{StaticResource PathsSettings.HeaderTextColumn}">
								<TextBlock Style="{StaticResource PathsSettings.TitleText}"
                                           Text="{DynamicResource LocPaths_OrganizeSection}" />
							</StackPanel>
						</Grid>

						<Border Grid.Row="2"
                                Style="{StaticResource PathsSettings.SettingRow}">
							<Grid FlowDirection="{DynamicResource App.FlowDirection}"
                                  HorizontalAlignment="Stretch">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*" />
									<ColumnDefinition Width="{DynamicResource Grid.Space.12}" />
									<ColumnDefinition Width="Auto" />
								</Grid.ColumnDefinitions>

								<Grid Grid.Column="0"
                                      MinWidth="0"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Stretch">
									<Grid.RowDefinitions>
										<RowDefinition Height="Auto" />
										<RowDefinition Height="{DynamicResource Grid.Space.4}" />
										<RowDefinition Height="Auto" />
									</Grid.RowDefinitions>

									<TextBlock Grid.Row="0"
                                               Style="{StaticResource PathsSettings.RowTitleText}"
                                               Text="{DynamicResource LocPaths_OrganizeByPlatform}" />

									<TextBlock Grid.Row="2"
                                               Style="{StaticResource PathsSettings.RowDescriptionText}"
                                               Text="{DynamicResource LocPaths_OrganizeByPlatformDesc}" />
								</Grid>

								<CheckBox x:Name="OrganizeByPlatformCheckBox"
                                          Grid.Column="2"
                                          IsChecked="{Binding OrganizeByPlatform, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Style="{StaticResource PathsSettings.ChoiceControlCheckBox}" />
							</Grid>
						</Border>

						<Border Grid.Row="3"
                                Style="{StaticResource PathsSettings.LastSettingRow}">
							<Grid FlowDirection="{DynamicResource App.FlowDirection}"
                                  HorizontalAlignment="Stretch">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*" />
									<ColumnDefinition Width="{DynamicResource Grid.Space.12}" />
									<ColumnDefinition Width="Auto" />
								</Grid.ColumnDefinitions>

								<Grid Grid.Column="0"
                                      MinWidth="0"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Stretch">
									<Grid.RowDefinitions>
										<RowDefinition Height="Auto" />
										<RowDefinition Height="{DynamicResource Grid.Space.4}" />
										<RowDefinition Height="Auto" />
									</Grid.RowDefinitions>

									<TextBlock Grid.Row="0"
                                               Style="{StaticResource PathsSettings.RowTitleText}"
                                               Text="{DynamicResource LocPaths_OrganizeByRegion}" />

									<TextBlock Grid.Row="2"
                                               Style="{StaticResource PathsSettings.RowDescriptionText}"
                                               Text="{DynamicResource LocPaths_OrganizeByRegionDesc}" />
								</Grid>

								<CheckBox Grid.Column="2"
                                          IsChecked="{Binding OrganizeByRegion, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Style="{StaticResource PathsSettings.ChoiceControlCheckBox}" />
							</Grid>
						</Border>
					</Grid>
				</Border>
			</Grid>
		</ScrollViewer>
	</Border>
</UserControl>
