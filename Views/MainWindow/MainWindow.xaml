<Window x:Class="HakamiqChdTool.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:mainViews="clr-namespace:HakamiqChdTool.App.Views.Main"
        mc:Ignorable="d"
        Title="{DynamicResource LocUi_WindowTitle}"
        Width="{DynamicResource Window.Main.PreferredWidth}"
        Height="{DynamicResource Window.Main.PreferredHeight}"
        MinWidth="{DynamicResource Window.Main.MinWidth}"
        MinHeight="{DynamicResource Window.Main.MinHeight}"
        SizeToContent="Manual"
        FlowDirection="{DynamicResource App.FlowDirection}"
        Language="{DynamicResource App.XmlLanguage}"
        FontFamily="{DynamicResource FontFamily.Text}"
        Background="{DynamicResource Brush.Layer.Canvas}"
        Foreground="{DynamicResource Brush.Text.Primary}"
        WindowStartupLocation="Manual"
        Closing="MainWindow_Closing"
        ResizeMode="CanResize"
        StateChanged="MainWindow_StateChanged"
        WindowStyle="None"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="{DynamicResource Window.CaptionHeight}"
                            CornerRadius="{DynamicResource Radius.None}"
                            GlassFrameThickness="{DynamicResource Inset.None}"
                            ResizeBorderThickness="{DynamicResource Window.ResizeBorderThickness}"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="MainWindow.RootSurface"
               TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{DynamicResource Brush.Layer.Canvas}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
            <Setter Property="BorderThickness" Value="{DynamicResource Inset.1.All}" />
            <Setter Property="TextElement.Foreground" Value="{DynamicResource Brush.Text.Primary}" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="ClipToBounds" Value="True" />
        </Style>

        <Style x:Key="MainWindow.ContentSurface"
               TargetType="{x:Type Grid}">
            <Setter Property="Background" Value="{DynamicResource Brush.Layer.Canvas}" />
            <Setter Property="FlowDirection" Value="{DynamicResource App.FlowDirection}" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="ClipToBounds" Value="True" />
        </Style>

        <Style x:Key="MainWindow.BodySurface"
               TargetType="{x:Type Grid}">
            <Setter Property="Margin" Value="{DynamicResource Inset.8.All}" />
            <Setter Property="FlowDirection" Value="{DynamicResource App.FlowDirection}" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="ClipToBounds" Value="True" />
        </Style>

        <Style x:Key="MainWindow.ActionRailHost"
               TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{DynamicResource Brush.Layer.Card}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
            <Setter Property="BorderThickness" Value="{DynamicResource Inset.1.All}" />
            <Setter Property="CornerRadius" Value="{DynamicResource Radius.Control}" />
            <Setter Property="Padding" Value="{DynamicResource Inset.None}" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="ClipToBounds" Value="True" />
        </Style>

        <Style x:Key="MainWindow.QueueHost"
               TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{DynamicResource Brush.Layer.Card}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
            <Setter Property="BorderThickness" Value="{DynamicResource Inset.1.All}" />
            <Setter Property="CornerRadius" Value="{DynamicResource Radius.Control}" />
            <Setter Property="Padding" Value="{DynamicResource Inset.None}" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="ClipToBounds" Value="True" />
        </Style>
    </Window.Resources>

    <Border Style="{StaticResource MainWindow.RootSurface}">
        <Grid Style="{StaticResource MainWindow.ContentSurface}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <mainViews:TrayNotifyIconView x:Name="TrayNotifyIconHost"
                                          Grid.Row="0"
                                          Width="0"
                                          Height="0"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Top"
                                          IsHitTestVisible="False"
                                          Focusable="False"
                                          Panel.ZIndex="0"
                                          d:IsHidden="True"
                                          TrayMouseDoubleClicked="TrayHost_MouseDoubleClicked"
                                          ShowRequested="TrayHost_ShowRequested"
                                          ExitRequested="TrayHost_ExitRequested" />

            <mainViews:MainHeaderView x:Name="MainHeader"
                                      Grid.Row="0"
                                      Panel.ZIndex="20"
                                      MinimizeRequested="MainHeader_MinimizeRequested"
                                      MaximizeRestoreRequested="MainHeader_MaximizeRestoreRequested"
                                      CloseRequested="MainHeader_CloseRequested" />

            <Grid Grid.Row="1"
                  Panel.ZIndex="10"
                  Style="{StaticResource MainWindow.BodySurface}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="{DynamicResource Layout.ActionPanel.GridWidth}"
                                      MinWidth="264"
                                      MaxWidth="304" />
                    <ColumnDefinition Width="{DynamicResource Grid.Space.8}" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource MainWindow.ActionRailHost}">
                    <mainViews:ActionRailView x:Name="ActionRail"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Stretch"
                                              OperationModeChanged="OperationModeRadio_Click" />
                </Border>

                <Border Grid.Column="2"
                        Style="{StaticResource MainWindow.QueueHost}">
                    <mainViews:QueueWorkspaceView x:Name="QueueWorkspace"
                                                  HorizontalAlignment="Stretch"
                                                  VerticalAlignment="Stretch"
                                                  OperationModeKey="Convert"
                                                  WorkspaceFilesDropped="OnWorkspaceFilesDropped"
                                                  WorkspacePreviewDragOver="WorkspaceCardRoot_PreviewDragOver"
                                                  WorkspacePreviewDragLeave="WorkspaceCardRoot_PreviewDragLeave"
                                                  WorkspacePreviewDrop="WorkspaceCardRoot_PreviewDrop"
                                                  TasksLoadingRow="TasksDataGrid_LoadingRow"
                                                  TasksUnloadingRow="TasksDataGrid_UnloadingRow"
                                                  TasksScrollChanged="TasksDataGrid_ScrollChanged"
                                                  TasksPreviewMouseRightButtonDown="TasksDataGrid_PreviewMouseRightButtonDown"
                                                  TasksMouseDoubleClick="TasksDataGrid_MouseDoubleClick"
                                                  TasksSelectionChanged="TasksDataGrid_SelectionChanged"
                                                  QueueContextMenuOpened="QueueContextMenu_Opened" />
                </Border>
            </Grid>

            <mainViews:FooterStatusStripView x:Name="FooterStatusStrip"
                                             Grid.Row="2"
                                             Panel.ZIndex="20" />
        </Grid>
    </Border>
</Window>