<Window x:Class="HakamiqChdTool.App.Views.StorageAdvisorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="{DynamicResource LocStorageAdvisor_Title}"
        Width="860"
        MinWidth="780"
        SizeToContent="Height"
        MaxHeight="760"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        ShowInTaskbar="False"
        AllowsTransparency="False"
        Background="{DynamicResource Brush.Layer.Canvas}"
        Foreground="{DynamicResource Brush.Text.Primary}"
        FlowDirection="{DynamicResource App.FlowDirection}"
        Language="{DynamicResource App.XmlLanguage}"
        FontFamily="{DynamicResource FontFamily.Text}"
        Icon="pack://application:,,,/Resources/HakamiqLogo.ico"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Style/AdvancedOptionsWindowStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Thickness x:Key="Inset.0.14.0.6">0,14,0,6</Thickness>
            <Thickness x:Key="Inset.0.8.0.6">0,8,0,6</Thickness>

            <Style x:Key="StorageAdvisor.RootFrame"
                   TargetType="{x:Type Border}">
                <Setter Property="Background" Value="{DynamicResource Brush.Layer.Surface}" />
                <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
                <Setter Property="BorderThickness" Value="{DynamicResource Inset.1.All}" />
                <Setter Property="CornerRadius" Value="{DynamicResource Radius.Card}" />
                <Setter Property="TextElement.Foreground" Value="{DynamicResource Brush.Text.Primary}" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
                <Setter Property="UseLayoutRounding" Value="True" />
                <Setter Property="ClipToBounds" Value="True" />
            </Style>

            <Style x:Key="StorageAdvisor.HeaderFooter"
                   TargetType="{x:Type Border}">
                <Setter Property="Background" Value="{DynamicResource Brush.Layer.Card}" />
                <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
                <Setter Property="Padding" Value="{DynamicResource Inset.14.10}" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
                <Setter Property="UseLayoutRounding" Value="True" />
            </Style>

            <Style x:Key="StorageAdvisor.ContentHost"
                   TargetType="{x:Type Border}">
                <Setter Property="Background" Value="{DynamicResource Brush.Layer.Surface}" />
                <Setter Property="Padding" Value="{DynamicResource Inset.16.All}" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
                <Setter Property="UseLayoutRounding" Value="True" />
            </Style>

            <Style x:Key="StorageAdvisor.Card"
                   TargetType="{x:Type Border}">
                <Setter Property="Background" Value="{DynamicResource Brush.Layer.Card}" />
                <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
                <Setter Property="BorderThickness" Value="{DynamicResource Inset.1.All}" />
                <Setter Property="CornerRadius" Value="{DynamicResource Radius.Card}" />
                <Setter Property="Padding" Value="{DynamicResource Inset.12.All}" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
                <Setter Property="UseLayoutRounding" Value="True" />
            </Style>

            <Style x:Key="StorageAdvisor.GeneralText"
                   TargetType="{x:Type TextBlock}">
                <Setter Property="FontFamily" Value="{DynamicResource FontFamily.Text}" />
                <Setter Property="FlowDirection" Value="{DynamicResource App.FlowDirection}" />
                <Setter Property="Language" Value="{DynamicResource App.XmlLanguage}" />
                <Setter Property="TextAlignment" Value="{DynamicResource AdvancedOptions.SettingsTextAlignment}" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="TextWrapping" Value="Wrap" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
            </Style>

            <Style x:Key="StorageAdvisor.TitleText"
                   TargetType="{x:Type TextBlock}"
                   BasedOn="{StaticResource StorageAdvisor.GeneralText}">
                <Setter Property="FontSize" Value="{DynamicResource FontSize.SectionTitle}" />
                <Setter Property="FontWeight" Value="{DynamicResource FontWeight.SemiBold}" />
                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
                <Setter Property="TextWrapping" Value="NoWrap" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            </Style>

            <Style x:Key="StorageAdvisor.SectionTitleText"
                   TargetType="{x:Type TextBlock}"
                   BasedOn="{StaticResource StorageAdvisor.GeneralText}">
                <Setter Property="FontSize" Value="{DynamicResource FontSize.BodyStrong}" />
                <Setter Property="FontWeight" Value="{DynamicResource FontWeight.SemiBold}" />
                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
                <Setter Property="TextWrapping" Value="NoWrap" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            </Style>

            <Style x:Key="StorageAdvisor.BodyText"
                   TargetType="{x:Type TextBlock}"
                   BasedOn="{StaticResource StorageAdvisor.GeneralText}">
                <Setter Property="FontSize" Value="{DynamicResource FontSize.BodySmall}" />
                <Setter Property="FontWeight" Value="{DynamicResource FontWeight.Regular}" />
                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
                <Setter Property="LineHeight" Value="{DynamicResource Font.LineHeight.Body}" />
                <Setter Property="LineStackingStrategy" Value="BlockLineHeight" />
            </Style>

            <Style x:Key="StorageAdvisor.LabelText"
                   TargetType="{x:Type TextBlock}"
                   BasedOn="{StaticResource StorageAdvisor.GeneralText}">
                <Setter Property="FontSize" Value="{DynamicResource FontSize.CaptionSmall}" />
                <Setter Property="FontWeight" Value="{DynamicResource FontWeight.SemiBold}" />
                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
                <Setter Property="TextWrapping" Value="NoWrap" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            </Style>

            <Style x:Key="StorageAdvisor.TechnicalText"
                   TargetType="{x:Type TextBlock}">
                <Setter Property="FlowDirection" Value="LeftToRight" />
                <Setter Property="Language" Value="en-US" />
                <Setter Property="FontFamily" Value="{DynamicResource FontFamily.Mono}" />
                <Setter Property="FontSize" Value="{DynamicResource FontSize.CaptionSmall}" />
                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
                <Setter Property="TextAlignment" Value="Left" />
                <Setter Property="TextWrapping" Value="NoWrap" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
            </Style>

            <Style x:Key="StorageAdvisor.CompactPrimaryButton"
                   TargetType="{x:Type Button}"
                   BasedOn="{StaticResource PrimaryButtonStyle}">
                <Setter Property="MinWidth" Value="156" />
                <Setter Property="MaxWidth" Value="220" />
                <Setter Property="Padding" Value="{DynamicResource Inset.10.5}" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
            </Style>

            <Style x:Key="StorageAdvisor.CompactSecondaryButton"
                   TargetType="{x:Type Button}"
                   BasedOn="{StaticResource SecondaryButtonStyle}">
                <Setter Property="MinWidth" Value="{DynamicResource Space.112}" />
                <Setter Property="MaxWidth" Value="180" />
                <Setter Property="Padding" Value="{DynamicResource Inset.10.5}" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="{DynamicResource Space.0}"
                            CornerRadius="{DynamicResource Radius.Dialog}"
                            GlassFrameThickness="{DynamicResource Inset.None}"
                            ResizeBorderThickness="{DynamicResource Inset.None}"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Border Style="{StaticResource StorageAdvisor.RootFrame}">
        <Grid ClipToBounds="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Style="{StaticResource StorageAdvisor.HeaderFooter}"
                    BorderThickness="{DynamicResource Inset.0.0.0.1}"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid FlowDirection="{DynamicResource App.FlowDirection}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="{DynamicResource Grid.Space.10}" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="{DynamicResource Grid.Space.10}" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Width="{DynamicResource Space.4}"
                            Height="{DynamicResource Space.24}"
                            Background="{DynamicResource Brush.Accent}"
                            CornerRadius="{DynamicResource Radius.Control}"
                            VerticalAlignment="Top"
                            SnapsToDevicePixels="True" />

                    <StackPanel Grid.Column="2"
                                FlowDirection="{DynamicResource App.FlowDirection}">
                        <TextBlock Text="{DynamicResource LocStorageAdvisor_Title}"
                                   Style="{StaticResource StorageAdvisor.TitleText}" />
                        <TextBlock Margin="{DynamicResource Inset.0.2.0.0}"
                                   Text="{DynamicResource LocStorageAdvisor_Subtitle}"
                                   Style="{StaticResource StorageAdvisor.BodyText}"
                                   TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>

                    <Button Grid.Column="4"
                            Width="{DynamicResource Space.32}"
                            Height="{DynamicResource Space.32}"
                            MinWidth="{DynamicResource Space.32}"
                            Padding="{DynamicResource Inset.None}"
                            VerticalAlignment="Center"
                            Style="{StaticResource HeaderIconButtonStyle}"
                            ToolTip="{DynamicResource LocCommon_Close}"
                            Click="CloseButton_Click"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Viewbox Width="{DynamicResource Space.12}"
                                 Height="{DynamicResource Space.12}"
                                 FlowDirection="LeftToRight"
                                 Stretch="Uniform">
                            <Path Data="{StaticResource Icon.Close}"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  Stretch="Uniform" />
                        </Viewbox>
                    </Button>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Style="{StaticResource StorageAdvisor.ContentHost}">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Focusable="False"
                              CanContentScroll="True"
                              MaxHeight="560">
                    <StackPanel FlowDirection="{DynamicResource App.FlowDirection}">

                        <Border Style="{StaticResource StorageAdvisor.Card}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource LocStorageAdvisor_SummaryTitle}"
                                           Style="{StaticResource StorageAdvisor.SectionTitleText}" />
                                <TextBlock Margin="{DynamicResource Inset.0.6.0.0}"
                                           Text="{DynamicResource LocStorageAdvisor_PremiumSummary}"
                                           Style="{StaticResource StorageAdvisor.BodyText}" />
                                <TextBlock Margin="{DynamicResource Inset.0.6.0.0}"
                                           Text="{DynamicResource LocStorageAdvisor_SafetyNote}"
                                           Style="{StaticResource StorageAdvisor.BodyText}" />
                            </StackPanel>
                        </Border>

                        <TextBlock Margin="{DynamicResource Inset.0.14.0.6}"
                                   Text="{DynamicResource LocStorageAdvisor_DeviceKindLabel}"
                                   Style="{StaticResource StorageAdvisor.SectionTitleText}" />

                        <ItemsControl ItemsSource="{Binding Paths}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="{DynamicResource Inset.0.0.0.8}"
                                            Style="{StaticResource StorageAdvisor.Card}">
                                        <Grid FlowDirection="{DynamicResource App.FlowDirection}">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="{DynamicResource Grid.Space.8}" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="{DynamicResource Grid.Space.12}" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Row="0"
                                                       Grid.Column="0"
                                                       Text="{Binding RoleLabel}"
                                                       Style="{StaticResource StorageAdvisor.SectionTitleText}" />

                                            <Border Grid.Row="0"
                                                    Grid.Column="2"
                                                    Padding="{DynamicResource Inset.10.5}"
                                                    Background="{DynamicResource Brush.Accent.Subtle}"
                                                    BorderBrush="{DynamicResource Brush.Accent.SelectedBorder}"
                                                    BorderThickness="{DynamicResource Inset.1.All}"
                                                    CornerRadius="{DynamicResource Radius.Pill}">
                                                <TextBlock Text="{Binding DeviceKindText}"
                                                           Style="{StaticResource StorageAdvisor.LabelText}"
                                                           Foreground="{DynamicResource Brush.Accent.Text}"
                                                           TextAlignment="Center" />
                                            </Border>

                                            <StackPanel Grid.Row="2"
                                                        Grid.ColumnSpan="3">
                                                <TextBlock Text="{DynamicResource LocStorageAdvisor_TechnicalPathLabel}"
                                                           Style="{StaticResource StorageAdvisor.LabelText}" />
                                                <TextBlock Margin="{DynamicResource Inset.0.5.0.0}"
                                                           Text="{Binding TechnicalPath}"
                                                           ToolTip="{Binding TechnicalPath}"
                                                           Style="{StaticResource StorageAdvisor.TechnicalText}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Margin="{DynamicResource Inset.0.8.0.6}"
                                   Text="{DynamicResource LocStorageAdvisor_WarningsTitle}"
                                   Style="{StaticResource StorageAdvisor.SectionTitleText}" />

                        <ItemsControl ItemsSource="{Binding Messages}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="{DynamicResource Inset.0.0.0.8}"
                                            Style="{StaticResource StorageAdvisor.Card}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding SeverityText}"
                                                       Style="{StaticResource StorageAdvisor.LabelText}" />
                                            <TextBlock Margin="{DynamicResource Inset.0.4.0.0}"
                                                       Text="{Binding MessageText}"
                                                       Style="{StaticResource StorageAdvisor.BodyText}" />
                                            <TextBlock Margin="{DynamicResource Inset.0.6.0.0}"
                                                       Text="{Binding TechnicalDetail}"
                                                       ToolTip="{Binding TechnicalDetail}"
                                                       Style="{StaticResource StorageAdvisor.TechnicalText}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Row="2"
                    Style="{StaticResource StorageAdvisor.HeaderFooter}"
                    BorderThickness="{DynamicResource Inset.0.1.0.0}">
                <Grid FlowDirection="{DynamicResource App.FlowDirection}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="{DynamicResource Grid.Space.8}" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="{DynamicResource Grid.Space.8}" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <CheckBox Grid.Column="0"
                              VerticalAlignment="Center"
                              Content="{DynamicResource LocStorageAdvisor_DoNotShowAgain}"
                              IsChecked="{Binding DoNotShowAgain, Mode=TwoWay}"
                              shell:WindowChrome.IsHitTestVisibleInChrome="True" />

                    <Button Grid.Column="2"
                            Content="{DynamicResource LocStorageAdvisor_Cancel}"
                            Click="CancelButton_Click"
                            Style="{StaticResource StorageAdvisor.CompactSecondaryButton}" />

                    <Button Grid.Column="4"
                            Content="{DynamicResource LocStorageAdvisor_OpenAdvancedOptions}"
                            Click="OpenAdvancedOptionsButton_Click"
                            Style="{StaticResource StorageAdvisor.CompactSecondaryButton}" />

                    <Button Grid.Column="6"
                            Content="{DynamicResource LocStorageAdvisor_ContinueRecommended}"
                            Click="ContinueRecommendedButton_Click"
                            Style="{StaticResource StorageAdvisor.CompactPrimaryButton}" />
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
