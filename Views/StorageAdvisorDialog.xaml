<Window x:Class="HakamiqChdTool.App.Views.StorageAdvisorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="{DynamicResource LocStorageAdvisor_Title}"
        Width="640"
        MinWidth="600"
        MaxHeight="540"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        ShowInTaskbar="False"
        AllowsTransparency="False"
        Background="{DynamicResource Brush.Layer.Canvas}"
        Foreground="{DynamicResource Brush.Text.Primary}"
        FlowDirection="{DynamicResource App.FlowDirection}"
        Language="{DynamicResource App.XmlLanguage}"
        FontFamily="{DynamicResource FontFamily.Text}"
        Icon="pack://application:,,,/Resources/HakamiqLogo.ico"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Resources/Style/OptionsWindowStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="StorageAdvisor.RootFrame"
                   TargetType="{x:Type Border}">
                <Setter Property="Background" Value="{DynamicResource Brush.Layer.Card}" />
                <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
                <Setter Property="BorderThickness" Value="{DynamicResource Inset.1.All}" />
                <Setter Property="CornerRadius" Value="{DynamicResource Radius.Card.Large}" />
                <Setter Property="TextElement.Foreground" Value="{DynamicResource Brush.Text.Primary}" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
                <Setter Property="UseLayoutRounding" Value="True" />
                <Setter Property="ClipToBounds" Value="True" />
            </Style>

            <Style x:Key="StorageAdvisor.HeaderFooter"
                   TargetType="{x:Type Border}">
                <Setter Property="Background" Value="{DynamicResource Brush.Layer.Card}" />
                <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
                <Setter Property="Padding" Value="18,14" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
                <Setter Property="UseLayoutRounding" Value="True" />
            </Style>

            <Style x:Key="StorageAdvisor.ContentHost"
                   TargetType="{x:Type Border}">
                <Setter Property="Background" Value="{DynamicResource Brush.Layer.Surface}" />
                <Setter Property="Padding" Value="18" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
                <Setter Property="UseLayoutRounding" Value="True" />
            </Style>

            <Style x:Key="StorageAdvisor.MessageCard"
                   TargetType="{x:Type Border}">
                <Setter Property="Background" Value="{DynamicResource Brush.Layer.Card}" />
                <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
                <Setter Property="BorderThickness" Value="{DynamicResource Inset.1.All}" />
                <Setter Property="CornerRadius" Value="{DynamicResource Radius.Card}" />
                <Setter Property="Padding" Value="16,14" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
                <Setter Property="UseLayoutRounding" Value="True" />
            </Style>

            <Style x:Key="StorageAdvisor.DetailRow"
                   TargetType="{x:Type Border}">
                <Setter Property="Background" Value="{DynamicResource Brush.Layer.Card}" />
                <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
                <Setter Property="BorderThickness" Value="{DynamicResource Inset.1.All}" />
                <Setter Property="CornerRadius" Value="{DynamicResource Radius.Control}" />
                <Setter Property="Padding" Value="10,8" />
                <Setter Property="Margin" Value="0,0,0,8" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
                <Setter Property="UseLayoutRounding" Value="True" />
            </Style>

            <Style x:Key="StorageAdvisor.GeneralText"
                   TargetType="{x:Type TextBlock}">
                <Setter Property="FontFamily" Value="{DynamicResource FontFamily.Text}" />
                <Setter Property="FlowDirection" Value="{DynamicResource App.FlowDirection}" />
                <Setter Property="Language" Value="{DynamicResource App.XmlLanguage}" />
                <Setter Property="TextAlignment" Value="{DynamicResource Options.SettingsTextAlignment}" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="TextWrapping" Value="Wrap" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
            </Style>

            <Style x:Key="StorageAdvisor.TitleText"
                   TargetType="{x:Type TextBlock}"
                   BasedOn="{StaticResource StorageAdvisor.GeneralText}">
                <Setter Property="FontSize" Value="{DynamicResource FontSize.BodyStrong}" />
                <Setter Property="FontWeight" Value="{DynamicResource FontWeight.SemiBold}" />
                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
                <Setter Property="TextWrapping" Value="NoWrap" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            </Style>

            <Style x:Key="StorageAdvisor.BodyText"
                   TargetType="{x:Type TextBlock}"
                   BasedOn="{StaticResource StorageAdvisor.GeneralText}">
                <Setter Property="FontSize" Value="{DynamicResource FontSize.BodySmall}" />
                <Setter Property="FontWeight" Value="{DynamicResource FontWeight.Regular}" />
                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
                <Setter Property="LineHeight" Value="{DynamicResource Font.LineHeight.Body}" />
                <Setter Property="LineStackingStrategy" Value="BlockLineHeight" />
                <Setter Property="TextWrapping" Value="Wrap" />
                <Setter Property="TextTrimming" Value="None" />
            </Style>

            <Style x:Key="StorageAdvisor.RecommendationText"
                   TargetType="{x:Type TextBlock}"
                   BasedOn="{StaticResource StorageAdvisor.GeneralText}">
                <Setter Property="FontSize" Value="{DynamicResource FontSize.BodySmall}" />
                <Setter Property="FontWeight" Value="{DynamicResource FontWeight.SemiBold}" />
                <Setter Property="Foreground" Value="{DynamicResource Brush.Accent.Text}" />
                <Setter Property="LineHeight" Value="{DynamicResource Font.LineHeight.Body}" />
                <Setter Property="LineStackingStrategy" Value="BlockLineHeight" />
                <Setter Property="TextWrapping" Value="Wrap" />
                <Setter Property="TextTrimming" Value="None" />
            </Style>

            <Style x:Key="StorageAdvisor.LabelText"
                   TargetType="{x:Type TextBlock}"
                   BasedOn="{StaticResource StorageAdvisor.GeneralText}">
                <Setter Property="FontSize" Value="{DynamicResource FontSize.CaptionSmall}" />
                <Setter Property="FontWeight" Value="{DynamicResource FontWeight.SemiBold}" />
                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
                <Setter Property="TextWrapping" Value="NoWrap" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            </Style>

            <Style x:Key="StorageAdvisor.TechnicalText"
                   TargetType="{x:Type TextBlock}">
                <Setter Property="FlowDirection" Value="{DynamicResource TechnicalText.FlowDirection}" />
                <Setter Property="Language" Value="{DynamicResource TechnicalText.Language}" />
                <Setter Property="FontFamily" Value="{DynamicResource FontFamily.Mono}" />
                <Setter Property="FontSize" Value="{DynamicResource FontSize.CaptionSmall}" />
                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
                <Setter Property="TextAlignment" Value="{DynamicResource TechnicalText.TextAlignment}" />
                <Setter Property="TextWrapping" Value="NoWrap" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
            </Style>

            <Style x:Key="StorageAdvisor.FooterCheckBox"
                   TargetType="{x:Type CheckBox}">
                <Setter Property="FlowDirection" Value="{DynamicResource App.FlowDirection}" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
            </Style>

            <Style x:Key="StorageAdvisor.CompactPrimaryButton"
                   TargetType="{x:Type Button}"
                   BasedOn="{StaticResource PrimaryButtonStyle}">
                <Setter Property="MinWidth" Value="124" />
                <Setter Property="Padding" Value="14,6" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
            </Style>

            <Style x:Key="StorageAdvisor.CompactSecondaryButton"
                   TargetType="{x:Type Button}"
                   BasedOn="{StaticResource SecondaryButtonStyle}">
                <Setter Property="MinWidth" Value="124" />
                <Setter Property="Padding" Value="14,6" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="{DynamicResource Space.40}"
                            CornerRadius="{DynamicResource Radius.Dialog}"
                            GlassFrameThickness="{DynamicResource Inset.None}"
                            ResizeBorderThickness="{DynamicResource Inset.None}"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Border Style="{StaticResource StorageAdvisor.RootFrame}">
        <Grid ClipToBounds="True"
              FlowDirection="{DynamicResource App.FlowDirection}"
              Language="{DynamicResource App.XmlLanguage}"
              SnapsToDevicePixels="True">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Style="{StaticResource StorageAdvisor.HeaderFooter}"
                    BorderThickness="{DynamicResource Inset.0.0.0.1}"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">

                <Grid FlowDirection="{DynamicResource App.FlowDirection}"
                      Language="{DynamicResource App.XmlLanguage}"
                      SnapsToDevicePixels="True">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="{DynamicResource Grid.Space.10}" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{DynamicResource LocStorageAdvisor_Title}"
                               Style="{StaticResource StorageAdvisor.TitleText}"
                               VerticalAlignment="Center" />

                    <Button x:Name="CloseButton"
                            Grid.Column="2"
                            Width="{DynamicResource Space.32}"
                            Height="{DynamicResource Space.32}"
                            MinWidth="{DynamicResource Space.32}"
                            Padding="{DynamicResource Inset.None}"
                            VerticalAlignment="Center"
                            Style="{StaticResource HeaderIconButtonStyle}"
                            ToolTip="{DynamicResource LocCommon_Close}"
                            AutomationProperties.Name="{DynamicResource LocCommon_Close}"
                            Click="CloseButton_Click"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">

                        <Viewbox Width="{DynamicResource Space.12}"
                                 Height="{DynamicResource Space.12}"
                                 FlowDirection="LeftToRight"
                                 Stretch="Uniform">
                            <Path Data="{StaticResource Icon.Close}"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  Stretch="Uniform"
                                  SnapsToDevicePixels="True" />
                        </Viewbox>
                    </Button>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Style="{StaticResource StorageAdvisor.ContentHost}">

                <ScrollViewer MaxHeight="280"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Focusable="False"
                              CanContentScroll="False"
                              PanningMode="VerticalOnly"
                              Background="{DynamicResource Brush.Transparent}"
                              SnapsToDevicePixels="True">

                    <StackPanel FlowDirection="{DynamicResource App.FlowDirection}"
                                Language="{DynamicResource App.XmlLanguage}">

                        <Border Style="{StaticResource StorageAdvisor.MessageCard}">
                            <StackPanel FlowDirection="{DynamicResource App.FlowDirection}"
                                        Language="{DynamicResource App.XmlLanguage}">

                                <TextBlock Text="{DynamicResource LocStorageAdvisor_UserSummaryText}"
                                           Style="{StaticResource StorageAdvisor.BodyText}" />

                                <TextBlock Margin="{DynamicResource Inset.0.8.0.0}"
                                           Text="{DynamicResource LocStorageAdvisor_UserRecommendationText}"
                                           Style="{StaticResource StorageAdvisor.RecommendationText}" />
                            </StackPanel>
                        </Border>

                        <Expander Margin="{DynamicResource Inset.0.10.0.0}"
                                  IsExpanded="False"
                                  FlowDirection="{DynamicResource App.FlowDirection}"
                                  Language="{DynamicResource App.XmlLanguage}">
                            <Expander.Header>
                                <TextBlock Text="{DynamicResource LocStorageAdvisor_ShowDetails}"
                                           Style="{StaticResource StorageAdvisor.LabelText}" />
                            </Expander.Header>

                            <StackPanel Margin="{DynamicResource Inset.0.8.0.0}"
                                        FlowDirection="{DynamicResource App.FlowDirection}"
                                        Language="{DynamicResource App.XmlLanguage}">

                                <ItemsControl ItemsSource="{Binding Paths}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource StorageAdvisor.DetailRow}">
                                                <Grid FlowDirection="{DynamicResource App.FlowDirection}">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="{DynamicResource Grid.Space.4}" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>

                                                    <TextBlock Grid.Row="0"
                                                               Text="{Binding RoleLabel}"
                                                               Style="{StaticResource StorageAdvisor.LabelText}" />

                                                    <Grid Grid.Row="2">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="{DynamicResource Grid.Space.4}" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>

                                                        <TextBlock Grid.Column="0"
                                                                   Text="{Binding DeviceKindText}"
                                                                   Style="{StaticResource StorageAdvisor.BodyText}"
                                                                   TextWrapping="NoWrap"
                                                                   TextTrimming="CharacterEllipsis" />

                                                        <TextBlock Grid.Column="2"
                                                                   Text="{Binding TechnicalPath}"
                                                                   ToolTip="{Binding TechnicalPath}"
                                                                   Style="{StaticResource StorageAdvisor.TechnicalText}" />
                                                    </Grid>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <ItemsControl ItemsSource="{Binding Messages}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource StorageAdvisor.DetailRow}">
                                                <StackPanel FlowDirection="{DynamicResource App.FlowDirection}">
                                                    <TextBlock Text="{Binding SeverityText}"
                                                               Style="{StaticResource StorageAdvisor.LabelText}" />

                                                    <TextBlock Margin="{DynamicResource Inset.0.4.0.0}"
                                                               Text="{Binding MessageText}"
                                                               Style="{StaticResource StorageAdvisor.BodyText}" />

                                                    <TextBlock Margin="{DynamicResource Inset.0.4.0.0}"
                                                               Text="{Binding TechnicalDetail}"
                                                               ToolTip="{Binding TechnicalDetail}"
                                                               Style="{StaticResource StorageAdvisor.TechnicalText}" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Row="2"
                    Style="{StaticResource StorageAdvisor.HeaderFooter}"
                    BorderThickness="{DynamicResource Inset.0.1.0.0}">

                <Grid FlowDirection="{DynamicResource App.FlowDirection}"
                      Language="{DynamicResource App.XmlLanguage}"
                      SnapsToDevicePixels="True">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <CheckBox Grid.Row="0"
                              Content="{DynamicResource LocStorageAdvisor_DoNotShowAgain}"
                              IsChecked="{Binding DoNotShowAgain, Mode=TwoWay}"
                              Style="{StaticResource StorageAdvisor.FooterCheckBox}" HorizontalAlignment="Right" />

                    <Grid Grid.Row="2"
                          FlowDirection="{DynamicResource App.FlowDirection}"
                          Language="{DynamicResource App.XmlLanguage}"
                          SnapsToDevicePixels="True">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="{DynamicResource Grid.Space.8}" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="{DynamicResource Grid.Space.8}" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="1"
                                Content="{DynamicResource LocStorageAdvisor_Cancel}"
                                ToolTip="{DynamicResource LocStorageAdvisor_Cancel}"
                                AutomationProperties.Name="{DynamicResource LocStorageAdvisor_Cancel}"
                                IsCancel="True"
                                Click="CancelButton_Click"
                                Style="{StaticResource StorageAdvisor.CompactSecondaryButton}" />

                        <Button Grid.Column="3"
                                Content="{DynamicResource LocStorageAdvisor_UseRecommended}"
                                ToolTip="{DynamicResource LocStorageAdvisor_UseRecommended}"
                                AutomationProperties.Name="{DynamicResource LocStorageAdvisor_UseRecommended}"
                                Click="OpenOptionsButton_Click"
                                MinWidth="196"
                                Style="{StaticResource StorageAdvisor.CompactSecondaryButton}" />

                        <Button Grid.Column="5"
                                Content="{DynamicResource LocStorageAdvisor_Continue}"
                                ToolTip="{DynamicResource LocStorageAdvisor_Continue}"
                                AutomationProperties.Name="{DynamicResource LocStorageAdvisor_Continue}"
                                Click="ContinueRecommendedButton_Click"
                                Style="{StaticResource StorageAdvisor.CompactPrimaryButton}" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
