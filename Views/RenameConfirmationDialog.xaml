<Window x:Class="HakamiqChdTool.App.Views.RenameConfirmationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding Title, Mode=OneWay}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="False"
        ShowInTaskbar="False"
        FlowDirection="{DynamicResource App.FlowDirection}"
        Language="{DynamicResource App.XmlLanguage}"
        Icon="pack://application:,,,/Resources/HakamiqLogo.ico"
        Width="{DynamicResource Window.Rename.Width}"
        MinWidth="{DynamicResource Window.Rename.MinWidth}"
        MaxWidth="{DynamicResource Window.Rename.MaxWidth}"
        MaxHeight="{DynamicResource Window.Rename.MaxHeight}"
        SizeToContent="Height"
        Background="{DynamicResource Brush.Layer.Canvas}"
        Foreground="{DynamicResource Brush.Text.Primary}"
        FontFamily="{DynamicResource FontFamily.Text}"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        d:DesignWidth="560"
        d:DesignHeight="230">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Resources/Style/AdvancedOptionsWindowStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="RenameDialog.RootFrame"
                   TargetType="{x:Type Border}">
                <Setter Property="Background" Value="{DynamicResource Brush.Layer.Card}" />
                <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
                <Setter Property="BorderThickness" Value="{DynamicResource Inset.1.All}" />
                <Setter Property="CornerRadius" Value="{DynamicResource Radius.Large}" />
                <Setter Property="TextElement.Foreground" Value="{DynamicResource Brush.Text.Primary}" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
                <Setter Property="UseLayoutRounding" Value="True" />
            </Style>

            <Style x:Key="RenameDialog.CaptionBar"
                   TargetType="{x:Type Border}">
                <Setter Property="MinHeight" Value="44" />
                <Setter Property="Background" Value="{DynamicResource Brush.Layer.Card}" />
                <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
                <Setter Property="BorderThickness" Value="{DynamicResource Inset.0.0.0.1}" />
                <Setter Property="Padding" Value="{DynamicResource Inset.12.0}" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
                <Setter Property="UseLayoutRounding" Value="True" />
            </Style>

            <Style x:Key="RenameDialog.ContentHost"
                   TargetType="{x:Type Border}">
                <Setter Property="Background" Value="{DynamicResource Brush.Layer.Surface}" />
                <Setter Property="Padding" Value="{DynamicResource Inset.12.All}" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
                <Setter Property="UseLayoutRounding" Value="True" />
            </Style>

            <Style x:Key="RenameDialog.Footer"
                   TargetType="{x:Type Border}">
                <Setter Property="Background" Value="{DynamicResource Brush.Layer.Card}" />
                <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
                <Setter Property="BorderThickness" Value="{DynamicResource Inset.0.1.0.0}" />
                <Setter Property="Padding" Value="{DynamicResource Inset.12.8}" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
                <Setter Property="UseLayoutRounding" Value="True" />
            </Style>

            <Style x:Key="RenameDialog.SectionAccent"
                   TargetType="{x:Type Border}">
                <Setter Property="Width" Value="{DynamicResource Space.4}" />
                <Setter Property="Height" Value="{DynamicResource Space.24}" />
                <Setter Property="Background" Value="{DynamicResource Brush.Accent}" />
                <Setter Property="CornerRadius" Value="{DynamicResource Radius.Control}" />
                <Setter Property="VerticalAlignment" Value="Top" />
                <Setter Property="Margin" Value="{DynamicResource Inset.0.2.0.0}" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
            </Style>

            <Style x:Key="RenameDialog.GeneralText"
                   TargetType="{x:Type TextBlock}">
                <Setter Property="FontFamily" Value="{DynamicResource FontFamily.Text}" />
                <Setter Property="FlowDirection" Value="{DynamicResource App.FlowDirection}" />
                <Setter Property="Language" Value="{DynamicResource App.XmlLanguage}" />
                <Setter Property="TextAlignment" Value="{DynamicResource AdvancedOptions.SettingsTextAlignment}" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="TextWrapping" Value="Wrap" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
            </Style>

            <Style x:Key="RenameDialog.CaptionText"
                   TargetType="{x:Type TextBlock}"
                   BasedOn="{StaticResource RenameDialog.GeneralText}">
                <Setter Property="FontSize" Value="{DynamicResource FontSize.BodySmall}" />
                <Setter Property="FontWeight" Value="{DynamicResource FontWeight.SemiBold}" />
                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="TextWrapping" Value="NoWrap" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            </Style>

            <Style x:Key="RenameDialog.TitleText"
                   TargetType="{x:Type TextBlock}"
                   BasedOn="{StaticResource RenameDialog.GeneralText}">
                <Setter Property="FontSize" Value="{DynamicResource FontSize.BodyStrong}" />
                <Setter Property="FontWeight" Value="{DynamicResource FontWeight.SemiBold}" />
                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
                <Setter Property="TextWrapping" Value="NoWrap" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            </Style>

            <Style x:Key="RenameDialog.BodyText"
                   TargetType="{x:Type TextBlock}"
                   BasedOn="{StaticResource RenameDialog.GeneralText}">
                <Setter Property="FontSize" Value="{DynamicResource FontSize.BodySmall}" />
                <Setter Property="FontWeight" Value="{DynamicResource FontWeight.Regular}" />
                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
                <Setter Property="LineHeight" Value="{DynamicResource Font.LineHeight.Body}" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            </Style>

            <Style x:Key="RenameDialog.FileNameSurface"
                   TargetType="{x:Type Border}">
                <Setter Property="Background" Value="{DynamicResource Brush.Control.Fill.Rest}" />
                <Setter Property="BorderBrush" Value="{DynamicResource Brush.Transparent}" />
                <Setter Property="BorderThickness" Value="{DynamicResource Inset.None}" />
                <Setter Property="CornerRadius" Value="{DynamicResource Radius.Control}" />
                <Setter Property="Padding" Value="{DynamicResource Inset.10.8}" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
                <Setter Property="UseLayoutRounding" Value="True" />
            </Style>

            <Style x:Key="RenameDialog.TechnicalFileNameText"
                   TargetType="{x:Type TextBlock}">
                <Setter Property="FontFamily" Value="{DynamicResource FontFamily.Mono}" />
                <Setter Property="FontSize" Value="{DynamicResource FontSize.CaptionSmall}" />
                <Setter Property="FontWeight" Value="{DynamicResource FontWeight.SemiBold}" />
                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="FlowDirection" Value="LeftToRight" />
                <Setter Property="Language" Value="en-US" />
                <Setter Property="TextAlignment" Value="Left" />
                <Setter Property="TextWrapping" Value="NoWrap" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="44"
                            CornerRadius="{DynamicResource Radius.Large}"
                            GlassFrameThickness="{DynamicResource Inset.None}"
                            ResizeBorderThickness="{DynamicResource Inset.None}"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Border Style="{StaticResource RenameDialog.RootFrame}">
        <Grid ClipToBounds="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Style="{StaticResource RenameDialog.CaptionBar}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="{DynamicResource Grid.Space.10}" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{Binding Title, Mode=OneWay}"
                               d:Text="تأكيد إعادة التسمية"
                               Style="{StaticResource RenameDialog.CaptionText}" />

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                FlowDirection="{DynamicResource App.CaptionButtonsFlowDirection}"
                                VerticalAlignment="Center"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button Width="{DynamicResource Space.32}"
                                Height="{DynamicResource Space.32}"
                                MinWidth="{DynamicResource Space.32}"
                                Padding="{DynamicResource Inset.None}"
                                VerticalAlignment="Center"
                                Command="{Binding CancelCommand}"
                                Style="{StaticResource HeaderIconButtonStyle}"
                                ToolTip="{DynamicResource LocCommon_Close}">
                            <Viewbox Width="{DynamicResource Space.12}"
                                     Height="{DynamicResource Space.12}"
                                     FlowDirection="LeftToRight"
                                     Stretch="Uniform">
                                <Path Data="{StaticResource Icon.Close}"
                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      Stretch="Uniform" />
                            </Viewbox>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Style="{StaticResource RenameDialog.ContentHost}">
                <ScrollViewer MaxHeight="{DynamicResource Window.Rename.ContentMaxHeight}"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              CanContentScroll="False"
                              PanningMode="VerticalOnly"
                              Focusable="False">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="{DynamicResource Grid.Space.10}" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="{DynamicResource Grid.Space.8}" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0"
                              HorizontalAlignment="Stretch">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="{DynamicResource Grid.Space.10}" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Style="{StaticResource RenameDialog.SectionAccent}" />

                            <TextBlock Grid.Column="2"
                                       Text="{Binding Heading, Mode=OneWay}"
                                       d:Text="تأكيد إعادة التسمية"
                                       Style="{StaticResource RenameDialog.TitleText}" />
                        </Grid>

                        <Border Grid.Row="2"
                                Style="{StaticResource RenameDialog.FileNameSurface}">
                            <TextBlock Text="{Binding FileName, Mode=OneWay}"
                                       d:Text="Final Fantasy X (USA).chd"
                                       Style="{StaticResource RenameDialog.TechnicalFileNameText}">
                                <TextBlock.ToolTip>
                                    <TextBlock Text="{Binding FileName, Mode=OneWay}"
                                               d:Text="Final Fantasy X (USA).chd"
                                               FlowDirection="LeftToRight"
                                               Language="en-US"
                                               TextAlignment="Left"
                                               TextWrapping="NoWrap" />
                                </TextBlock.ToolTip>
                            </TextBlock>
                        </Border>

                        <TextBlock Grid.Row="4"
                                   Text="{Binding Question, Mode=OneWay}"
                                   d:Text="هل تريد تطبيق الاسم المقترح على هذا الملف؟"
                                   Style="{StaticResource RenameDialog.BodyText}" />
                    </Grid>
                </ScrollViewer>
            </Border>

            <Border Grid.Row="2"
                    Style="{StaticResource RenameDialog.Footer}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="1"
                          VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="{DynamicResource Grid.Space.8}" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Content="{Binding ConfirmText, Mode=OneWay}"
                                d:Content="تأكيد"
                                Command="{Binding ConfirmCommand}"
                                IsDefault="True"
                                MinWidth="{DynamicResource Control.MinWidth}"
                                FlowDirection="{DynamicResource App.FlowDirection}"
                                Style="{StaticResource PrimaryButtonStyle}" />

                        <Button Grid.Column="2"
                                Content="{Binding CancelText, Mode=OneWay}"
                                d:Content="إلغاء"
                                Command="{Binding CancelCommand}"
                                IsCancel="True"
                                MinWidth="{DynamicResource Control.MinWidth}"
                                FlowDirection="{DynamicResource App.FlowDirection}"
                                Style="{StaticResource SecondaryButtonStyle}" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>