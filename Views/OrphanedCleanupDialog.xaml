<Window x:Class="HakamiqChdTool.App.Views.OrphanedCleanupDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="{DynamicResource LocOrphanedCleanup_PromptTitle}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="False"
        ShowInTaskbar="False"
        FlowDirection="{DynamicResource App.FlowDirection}"
        Language="{DynamicResource App.XmlLanguage}"
        Icon="pack://application:,,,/Resources/HakamiqLogo.ico"
        Width="640"
        MinWidth="600"
        SizeToContent="Height"
        Background="{DynamicResource Brush.Layer.Canvas}"
        Foreground="{DynamicResource Brush.Text.Primary}"
        FontFamily="{DynamicResource FontFamily.Text}"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Style/AdvancedOptionsWindowStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="OrphanedCleanupDialog.RootFrame"
                   TargetType="{x:Type Border}">
                <Setter Property="Background" Value="{DynamicResource Brush.Layer.Card}" />
                <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
                <Setter Property="BorderThickness" Value="{DynamicResource Inset.1.All}" />
                <Setter Property="CornerRadius" Value="{DynamicResource Radius.Large}" />
                <Setter Property="TextElement.Foreground" Value="{DynamicResource Brush.Text.Primary}" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
                <Setter Property="UseLayoutRounding" Value="True" />
            </Style>

            <Style x:Key="OrphanedCleanupDialog.HeaderFooter"
                   TargetType="{x:Type Border}">
                <Setter Property="Background" Value="{DynamicResource Brush.Layer.Card}" />
                <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
                <Setter Property="Padding" Value="{DynamicResource Inset.14.10}" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
                <Setter Property="UseLayoutRounding" Value="True" />
            </Style>

            <Style x:Key="OrphanedCleanupDialog.ContentHost"
                   TargetType="{x:Type Border}">
                <Setter Property="Background" Value="{DynamicResource Brush.Layer.Surface}" />
                <Setter Property="Padding" Value="{DynamicResource Inset.14.All}" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
                <Setter Property="UseLayoutRounding" Value="True" />
            </Style>

            <Style x:Key="OrphanedCleanupDialog.Card"
                   TargetType="{x:Type Border}">
                <Setter Property="Background" Value="{DynamicResource Brush.Layer.Card}" />
                <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
                <Setter Property="BorderThickness" Value="{DynamicResource Inset.1.All}" />
                <Setter Property="CornerRadius" Value="{DynamicResource Radius.Card}" />
                <Setter Property="Padding" Value="{DynamicResource Inset.14.All}" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
                <Setter Property="UseLayoutRounding" Value="True" />
            </Style>

            <Style x:Key="OrphanedCleanupDialog.WarningCard"
                   TargetType="{x:Type Border}">
                <Setter Property="Background" Value="{DynamicResource WarningSoftBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource WarningBorderBrush}" />
                <Setter Property="BorderThickness" Value="{DynamicResource Inset.1.All}" />
                <Setter Property="CornerRadius" Value="{DynamicResource Radius.Card}" />
                <Setter Property="Padding" Value="{DynamicResource Inset.14.All}" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
                <Setter Property="UseLayoutRounding" Value="True" />
            </Style>

            <Style x:Key="OrphanedCleanupDialog.SectionAccent"
                   TargetType="{x:Type Border}">
                <Setter Property="Width" Value="{DynamicResource Space.4}" />
                <Setter Property="Height" Value="{DynamicResource Space.24}" />
                <Setter Property="Background" Value="{DynamicResource Brush.Accent}" />
                <Setter Property="CornerRadius" Value="{DynamicResource Radius.Control}" />
                <Setter Property="VerticalAlignment" Value="Top" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
            </Style>

            <Style x:Key="OrphanedCleanupDialog.GeneralText"
                   TargetType="{x:Type TextBlock}">
                <Setter Property="FontFamily" Value="{DynamicResource FontFamily.Text}" />
                <Setter Property="FlowDirection" Value="{DynamicResource App.FlowDirection}" />
                <Setter Property="Language" Value="{DynamicResource App.XmlLanguage}" />
                <Setter Property="TextAlignment" Value="{DynamicResource AdvancedOptions.SettingsTextAlignment}" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="TextWrapping" Value="Wrap" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
            </Style>

            <Style x:Key="OrphanedCleanupDialog.TitleText"
                   TargetType="{x:Type TextBlock}"
                   BasedOn="{StaticResource OrphanedCleanupDialog.GeneralText}">
                <Setter Property="FontSize" Value="{DynamicResource FontSize.SectionTitle}" />
                <Setter Property="FontWeight" Value="{DynamicResource FontWeight.SemiBold}" />
                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
                <Setter Property="TextWrapping" Value="NoWrap" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            </Style>

            <Style x:Key="OrphanedCleanupDialog.SectionTitleText"
                   TargetType="{x:Type TextBlock}"
                   BasedOn="{StaticResource OrphanedCleanupDialog.GeneralText}">
                <Setter Property="FontSize" Value="{DynamicResource FontSize.BodyStrong}" />
                <Setter Property="FontWeight" Value="{DynamicResource FontWeight.SemiBold}" />
                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
                <Setter Property="TextWrapping" Value="NoWrap" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            </Style>

            <Style x:Key="OrphanedCleanupDialog.BodyText"
                   TargetType="{x:Type TextBlock}"
                   BasedOn="{StaticResource OrphanedCleanupDialog.GeneralText}">
                <Setter Property="FontSize" Value="{DynamicResource FontSize.BodySmall}" />
                <Setter Property="FontWeight" Value="{DynamicResource FontWeight.Regular}" />
                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
                <Setter Property="LineHeight" Value="{DynamicResource Font.LineHeight.Body}" />
            </Style>

            <Style x:Key="OrphanedCleanupDialog.MetricLabelText"
                   TargetType="{x:Type TextBlock}"
                   BasedOn="{StaticResource OrphanedCleanupDialog.GeneralText}">
                <Setter Property="FontSize" Value="{DynamicResource FontSize.CaptionSmall}" />
                <Setter Property="FontWeight" Value="{DynamicResource FontWeight.SemiBold}" />
                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
                <Setter Property="TextWrapping" Value="NoWrap" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            </Style>

            <Style x:Key="OrphanedCleanupDialog.MetricValueText"
                   TargetType="{x:Type TextBlock}"
                   BasedOn="{StaticResource OrphanedCleanupDialog.GeneralText}">
                <Setter Property="FontSize" Value="{DynamicResource FontSize.BodyStrong}" />
                <Setter Property="FontWeight" Value="{DynamicResource FontWeight.SemiBold}" />
                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
                <Setter Property="TextWrapping" Value="NoWrap" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            </Style>

            <Style x:Key="OrphanedCleanupDialog.TechnicalText"
                   TargetType="{x:Type TextBlock}">
                <Setter Property="FontFamily" Value="{DynamicResource FontFamily.Mono}" />
                <Setter Property="FontSize" Value="{DynamicResource FontSize.CaptionSmall}" />
                <Setter Property="FontWeight" Value="{DynamicResource FontWeight.Regular}" />
                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
                <Setter Property="FlowDirection" Value="LeftToRight" />
                <Setter Property="Language" Value="en-US" />
                <Setter Property="TextAlignment" Value="Left" />
                <Setter Property="TextWrapping" Value="Wrap" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="{DynamicResource Space.0}"
                            CornerRadius="{DynamicResource Radius.Dialog}"
                            GlassFrameThickness="{DynamicResource Inset.None}"
                            ResizeBorderThickness="{DynamicResource Inset.None}"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Border Style="{StaticResource OrphanedCleanupDialog.RootFrame}">
        <Grid ClipToBounds="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Style="{StaticResource OrphanedCleanupDialog.HeaderFooter}"
                    BorderThickness="{DynamicResource Inset.0.0.0.1}"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid FlowDirection="{DynamicResource App.FlowDirection}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="{DynamicResource Grid.Space.10}" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="{DynamicResource Grid.Space.10}" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Style="{StaticResource OrphanedCleanupDialog.SectionAccent}" />

                    <StackPanel Grid.Column="2"
                                FlowDirection="{DynamicResource App.FlowDirection}">
                        <TextBlock Text="{DynamicResource LocOrphanedCleanup_PromptTitle}"
                                   Style="{StaticResource OrphanedCleanupDialog.TitleText}" />
                        <TextBlock Margin="{DynamicResource Inset.0.4.0.0}"
                                   Text="{DynamicResource LocOrphanedCleanup_DialogDescription}"
                                   Style="{StaticResource OrphanedCleanupDialog.BodyText}"
                                   TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>

                    <Button Grid.Column="4"
                            Width="{DynamicResource Space.32}"
                            Height="{DynamicResource Space.32}"
                            MinWidth="{DynamicResource Space.32}"
                            Padding="{DynamicResource Inset.None}"
                            VerticalAlignment="Center"
                            Style="{StaticResource HeaderIconButtonStyle}"
                            ToolTip="{DynamicResource LocCommon_Close}"
                            Click="SkipButton_Click">
                        <TextBlock Text="×"
                                   FlowDirection="LeftToRight"
                                   Language="en-US"
                                   TextAlignment="Center"
                                   FontSize="{DynamicResource FontSize.BodyStrong}"
                                   FontWeight="{DynamicResource FontWeight.SemiBold}" />
                    </Button>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Style="{StaticResource OrphanedCleanupDialog.ContentHost}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="{DynamicResource Grid.Space.12}" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="{DynamicResource Grid.Space.12}" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Style="{StaticResource OrphanedCleanupDialog.WarningCard}">
                        <Grid FlowDirection="{DynamicResource App.FlowDirection}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="{DynamicResource Grid.Space.12}" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="⚠"
                                       FontSize="{DynamicResource FontSize.Subtitle}"
                                       Foreground="{DynamicResource Brush.Warning}"
                                       FlowDirection="LeftToRight"
                                       Language="en-US"
                                       VerticalAlignment="Top" />

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{DynamicResource LocOrphanedCleanup_WarningTitle}"
                                           Style="{StaticResource OrphanedCleanupDialog.SectionTitleText}" />
                                <TextBlock Margin="{DynamicResource Inset.0.6.0.0}"
                                           Text="{Binding SummaryText}"
                                           Style="{StaticResource OrphanedCleanupDialog.BodyText}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="2"
                            Style="{StaticResource OrphanedCleanupDialog.Card}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="{DynamicResource Grid.Space.10}" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="{DynamicResource Grid.Space.10}" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="{DynamicResource LocOrphanedCleanup_ScanSummaryTitle}"
                                       Style="{StaticResource OrphanedCleanupDialog.SectionTitleText}" />

                            <Grid Grid.Row="2"
                                  FlowDirection="{DynamicResource App.FlowDirection}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="{DynamicResource Grid.Space.10}" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="{DynamicResource Grid.Space.10}" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Style="{StaticResource OrphanedCleanupDialog.Card}"
                                        Padding="{DynamicResource Inset.12.All}">
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource LocOrphanedCleanup_ItemsLabel}"
                                                   Style="{StaticResource OrphanedCleanupDialog.MetricLabelText}" />
                                        <TextBlock Margin="{DynamicResource Inset.0.4.0.0}"
                                                   Text="{Binding ItemCountText}"
                                                   Style="{StaticResource OrphanedCleanupDialog.MetricValueText}" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2"
                                        Style="{StaticResource OrphanedCleanupDialog.Card}"
                                        Padding="{DynamicResource Inset.12.All}">
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource LocOrphanedCleanup_FilesLabel}"
                                                   Style="{StaticResource OrphanedCleanupDialog.MetricLabelText}" />
                                        <TextBlock Margin="{DynamicResource Inset.0.4.0.0}"
                                                   Text="{Binding FileCountText}"
                                                   Style="{StaticResource OrphanedCleanupDialog.MetricValueText}" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="4"
                                        Style="{StaticResource OrphanedCleanupDialog.Card}"
                                        Padding="{DynamicResource Inset.12.All}">
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource LocOrphanedCleanup_SizeLabel}"
                                                   Style="{StaticResource OrphanedCleanupDialog.MetricLabelText}" />
                                        <TextBlock Margin="{DynamicResource Inset.0.4.0.0}"
                                                   Text="{Binding ReclaimableSizeText}"
                                                   Style="{StaticResource OrphanedCleanupDialog.MetricValueText}" />
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <StackPanel Grid.Row="4">
                                <TextBlock Text="{DynamicResource LocOrphanedCleanup_TempRootLabel}"
                                           Style="{StaticResource OrphanedCleanupDialog.MetricLabelText}" />
                                <TextBlock Margin="{DynamicResource Inset.0.4.0.0}"
                                           Text="{Binding ProcessTempRootText}"
                                           Style="{StaticResource OrphanedCleanupDialog.TechnicalText}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="4"
                            Style="{StaticResource OrphanedCleanupDialog.Card}">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource LocOrphanedCleanup_SafetyTitle}"
                                       Style="{StaticResource OrphanedCleanupDialog.SectionTitleText}" />
                            <TextBlock Margin="{DynamicResource Inset.0.8.0.0}"
                                       Text="{DynamicResource LocOrphanedCleanup_SafetyTempOnly}"
                                       Style="{StaticResource OrphanedCleanupDialog.BodyText}" />
                            <TextBlock Margin="{DynamicResource Inset.0.6.0.0}"
                                       Text="{DynamicResource LocOrphanedCleanup_SafetyNoSourceOutput}"
                                       Style="{StaticResource OrphanedCleanupDialog.BodyText}" />
                            <TextBlock Margin="{DynamicResource Inset.0.6.0.0}"
                                       Text="{DynamicResource LocOrphanedCleanup_SafetyManualConfirm}"
                                       Style="{StaticResource OrphanedCleanupDialog.BodyText}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Style="{StaticResource OrphanedCleanupDialog.HeaderFooter}"
                    BorderThickness="{DynamicResource Inset.0.1.0.0}">
                <Grid FlowDirection="{DynamicResource App.FlowDirection}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="{DynamicResource Grid.Space.10}" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{DynamicResource LocOrphanedCleanup_FooterHint}"
                               Style="{StaticResource OrphanedCleanupDialog.BodyText}"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" />

                    <Button Grid.Column="1"
                            MinWidth="{DynamicResource Space.112}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Content="{DynamicResource LocOrphanedCleanup_LaterButton}"
                            Click="SkipButton_Click" />

                    <Button Grid.Column="3"
                            MinWidth="{DynamicResource Space.112}"
                            Style="{StaticResource DangerButtonStyle}"
                            Content="{DynamicResource LocOrphanedCleanup_CleanNowButton}"
                            Click="CleanButton_Click" />
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
