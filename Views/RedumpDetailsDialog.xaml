<Window x:Class="HakamiqChdTool.App.Views.RedumpDetailsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="{DynamicResource LocRedumpDetails_Title}"
        Width="760"
        MinWidth="700"
        Height="540"
        MinHeight="480"
        MaxHeight="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        WindowStyle="None"
        ShowInTaskbar="False"
        AllowsTransparency="False"
        Background="{DynamicResource Brush.Layer.Canvas}"
        Foreground="{DynamicResource Brush.Text.Primary}"
        FlowDirection="{DynamicResource App.FlowDirection}"
        Language="{DynamicResource App.XmlLanguage}"
        FontFamily="{DynamicResource FontFamily.Text}"
        Icon="pack://application:,,,/Resources/HakamiqLogo.ico"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Resources/Style/OptionsWindowStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Storyboard x:Key="RedumpDetails.ToastShowStoryboard">
                <DoubleAnimation Storyboard.TargetName="CopyFeedbackToast"
                                 Storyboard.TargetProperty="Opacity"
                                 From="0"
                                 To="0"
                                 Duration="0:0:0.01" />

                <DoubleAnimation Storyboard.TargetName="CopyFeedbackToastTranslate"
                                 Storyboard.TargetProperty="Y"
                                 From="0"
                                 To="0"
                                 Duration="0:0:0.01" />
            </Storyboard>

            <Storyboard x:Key="RedumpDetails.ToastHideStoryboard">
                <DoubleAnimation Storyboard.TargetName="CopyFeedbackToast"
                                 Storyboard.TargetProperty="Opacity"
                                 From="0"
                                 To="0"
                                 Duration="0:0:0.01" />

                <DoubleAnimation Storyboard.TargetName="CopyFeedbackToastTranslate"
                                 Storyboard.TargetProperty="Y"
                                 From="0"
                                 To="0"
                                 Duration="0:0:0.01" />
            </Storyboard>

            <Style x:Key="RedumpDetails.RootFrame"
                   TargetType="{x:Type Border}">
                <Setter Property="Background" Value="{DynamicResource Brush.Layer.Card}" />
                <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
                <Setter Property="BorderThickness" Value="{DynamicResource Inset.1.All}" />
                <Setter Property="CornerRadius" Value="{DynamicResource Radius.Card.Large}" />
                <Setter Property="TextElement.Foreground" Value="{DynamicResource Brush.Text.Primary}" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
                <Setter Property="UseLayoutRounding" Value="True" />
                <Setter Property="ClipToBounds" Value="True" />
            </Style>

            <Style x:Key="RedumpDetails.HeaderFooter"
                   TargetType="{x:Type Border}">
                <Setter Property="Background" Value="{DynamicResource Brush.Layer.Card}" />
                <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
                <Setter Property="Padding" Value="14,10" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
                <Setter Property="UseLayoutRounding" Value="True" />
            </Style>

            <Style x:Key="RedumpDetails.ContentHost"
                   TargetType="{x:Type Border}">
                <Setter Property="Background" Value="{DynamicResource Brush.Layer.Surface}" />
                <Setter Property="Padding" Value="14" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
                <Setter Property="UseLayoutRounding" Value="True" />
            </Style>

            <Style x:Key="RedumpDetails.DecisionSurface"
                   TargetType="{x:Type Border}">
                <Setter Property="Background" Value="{DynamicResource Brush.Layer.Card}" />
                <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
                <Setter Property="BorderThickness" Value="{DynamicResource Inset.1.All}" />
                <Setter Property="CornerRadius" Value="{DynamicResource Radius.Card.Large}" />
                <Setter Property="Padding" Value="12" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="VerticalAlignment" Value="Top" />
                <Setter Property="TextElement.Foreground" Value="{DynamicResource Brush.Text.Primary}" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
                <Setter Property="UseLayoutRounding" Value="True" />
                <Setter Property="ClipToBounds" Value="True" />
            </Style>

            <Style x:Key="RedumpDetails.InfoTile"
                   TargetType="{x:Type Border}">
                <Setter Property="Background" Value="{DynamicResource Brush.Layer.Card}" />
                <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
                <Setter Property="BorderThickness" Value="{DynamicResource Inset.1.All}" />
                <Setter Property="CornerRadius" Value="{DynamicResource Radius.Control}" />
                <Setter Property="Padding" Value="10,8" />
                <Setter Property="MinHeight" Value="58" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
                <Setter Property="UseLayoutRounding" Value="True" />
            </Style>

            <Style x:Key="RedumpDetails.TechnicalSurface"
                   TargetType="{x:Type Border}">
                <Setter Property="FlowDirection" Value="{DynamicResource TechnicalText.FlowDirection}" />
                <Setter Property="Language" Value="{DynamicResource TechnicalText.Language}" />
                <Setter Property="Padding" Value="10,8" />
                <Setter Property="Background" Value="{DynamicResource Brush.Layer.Surface}" />
                <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
                <Setter Property="BorderThickness" Value="{DynamicResource Inset.1.All}" />
                <Setter Property="CornerRadius" Value="{DynamicResource Radius.Control}" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="MinHeight" Value="36" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
                <Setter Property="UseLayoutRounding" Value="True" />
                <Setter Property="ClipToBounds" Value="True" />
            </Style>

            <Style x:Key="RedumpDetails.GeneralText"
                   TargetType="{x:Type TextBlock}">
                <Setter Property="FontFamily" Value="{DynamicResource FontFamily.Text}" />
                <Setter Property="FlowDirection" Value="{DynamicResource App.FlowDirection}" />
                <Setter Property="Language" Value="{DynamicResource App.XmlLanguage}" />
                <Setter Property="TextAlignment" Value="{DynamicResource Options.SettingsTextAlignment}" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="TextWrapping" Value="Wrap" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
            </Style>

            <Style x:Key="RedumpDetails.TitleText"
                   TargetType="{x:Type TextBlock}"
                   BasedOn="{StaticResource RedumpDetails.GeneralText}">
                <Setter Property="FontSize" Value="{DynamicResource FontSize.BodyStrong}" />
                <Setter Property="FontWeight" Value="{DynamicResource FontWeight.SemiBold}" />
                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
                <Setter Property="TextWrapping" Value="NoWrap" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            </Style>

            <Style x:Key="RedumpDetails.SectionTitleText"
                   TargetType="{x:Type TextBlock}"
                   BasedOn="{StaticResource RedumpDetails.GeneralText}">
                <Setter Property="FontSize" Value="{DynamicResource FontSize.BodyStrong}" />
                <Setter Property="FontWeight" Value="{DynamicResource FontWeight.SemiBold}" />
                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
                <Setter Property="TextWrapping" Value="NoWrap" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            </Style>

            <Style x:Key="RedumpDetails.LabelText"
                   TargetType="{x:Type TextBlock}"
                   BasedOn="{StaticResource RedumpDetails.GeneralText}">
                <Setter Property="FontSize" Value="{DynamicResource FontSize.CaptionSmall}" />
                <Setter Property="FontWeight" Value="{DynamicResource FontWeight.SemiBold}" />
                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
                <Setter Property="TextWrapping" Value="NoWrap" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            </Style>

            <Style x:Key="RedumpDetails.BodyText"
                   TargetType="{x:Type TextBlock}"
                   BasedOn="{StaticResource RedumpDetails.GeneralText}">
                <Setter Property="FontSize" Value="{DynamicResource FontSize.Caption}" />
                <Setter Property="FontWeight" Value="{DynamicResource FontWeight.Regular}" />
                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
                <Setter Property="LineHeight" Value="{DynamicResource Font.LineHeight.Body}" />
                <Setter Property="LineStackingStrategy" Value="BlockLineHeight" />
                <Setter Property="TextWrapping" Value="Wrap" />
                <Setter Property="TextTrimming" Value="None" />
            </Style>

            <Style x:Key="RedumpDetails.TechnicalText"
                   TargetType="{x:Type TextBlock}">
                <Setter Property="FlowDirection" Value="{DynamicResource TechnicalText.FlowDirection}" />
                <Setter Property="Language" Value="{DynamicResource TechnicalText.Language}" />
                <Setter Property="FontFamily" Value="{DynamicResource FontFamily.Mono}" />
                <Setter Property="FontSize" Value="{DynamicResource FontSize.CaptionSmall}" />
                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
                <Setter Property="TextAlignment" Value="{DynamicResource TechnicalText.TextAlignment}" />
                <Setter Property="TextWrapping" Value="NoWrap" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
            </Style>

            <Style x:Key="RedumpDetails.MultiLineTechnicalText"
                   TargetType="{x:Type TextBlock}"
                   BasedOn="{StaticResource RedumpDetails.TechnicalText}">
                <Setter Property="TextWrapping" Value="Wrap" />
                <Setter Property="TextTrimming" Value="None" />
                <Setter Property="VerticalAlignment" Value="Top" />
            </Style>

            <Style x:Key="RedumpDetails.StatusBadge"
                   TargetType="{x:Type Border}">
                <Setter Property="MinWidth" Value="0" />
                <Setter Property="Padding" Value="10,5" />
                <Setter Property="Background" Value="{DynamicResource Brush.Layer.Surface}" />
                <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
                <Setter Property="BorderThickness" Value="{DynamicResource Inset.1.All}" />
                <Setter Property="CornerRadius" Value="{DynamicResource Radius.Pill}" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="SnapsToDevicePixels" Value="True" />

                <Style.Triggers>
                    <DataTrigger Binding="{Binding Status}" Value="{x:Null}">
                        <Setter Property="Visibility" Value="Collapsed" />
                    </DataTrigger>

                    <DataTrigger Binding="{Binding Status}" Value="">
                        <Setter Property="Visibility" Value="Collapsed" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="RedumpDetails.StatusBadgeText"
                   TargetType="{x:Type TextBlock}"
                   BasedOn="{StaticResource RedumpDetails.GeneralText}">
                <Setter Property="FontSize" Value="{DynamicResource FontSize.CaptionSmall}" />
                <Setter Property="FontWeight" Value="{DynamicResource FontWeight.SemiBold}" />
                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
                <Setter Property="TextAlignment" Value="Center" />
                <Setter Property="TextWrapping" Value="NoWrap" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            </Style>

            <Style x:Key="RedumpDetails.CompactPrimaryButton"
                   TargetType="{x:Type Button}"
                   BasedOn="{StaticResource PrimaryButtonStyle}">
                <Setter Property="MinWidth" Value="{DynamicResource Space.112}" />
                <Setter Property="MaxWidth" Value="156" />
                <Setter Property="Padding" Value="10,5" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
            </Style>

            <Style x:Key="RedumpDetails.CompactSecondaryButton"
                   TargetType="{x:Type Button}"
                   BasedOn="{StaticResource SecondaryButtonStyle}">
                <Setter Property="MinWidth" Value="{DynamicResource Space.112}" />
                <Setter Property="MaxWidth" Value="156" />
                <Setter Property="Padding" Value="10,5" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
            </Style>

            <Style x:Key="RedumpDetails.FooterFeedbackText"
                   TargetType="{x:Type TextBlock}"
                   BasedOn="{StaticResource RedumpDetails.GeneralText}">
                <Setter Property="FontSize" Value="{DynamicResource FontSize.CaptionSmall}" />
                <Setter Property="FontWeight" Value="{DynamicResource FontWeight.SemiBold}" />
                <Setter Property="Foreground" Value="{DynamicResource Brush.Success}" />
                <Setter Property="TextWrapping" Value="NoWrap" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                <Setter Property="VerticalAlignment" Value="Center" />

                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsCopyFeedbackError}" Value="True">
                        <Setter Property="Foreground" Value="{DynamicResource Brush.Error}" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="{DynamicResource Space.40}"
                            CornerRadius="{DynamicResource Radius.Dialog}"
                            GlassFrameThickness="{DynamicResource Inset.None}"
                            ResizeBorderThickness="{DynamicResource Window.ResizeBorderThickness}"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Border Style="{StaticResource RedumpDetails.RootFrame}">
        <Grid ClipToBounds="True"
              FlowDirection="{DynamicResource App.FlowDirection}"
              Language="{DynamicResource App.XmlLanguage}"
              SnapsToDevicePixels="True">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Style="{StaticResource RedumpDetails.HeaderFooter}"
                    BorderThickness="{DynamicResource Inset.0.0.0.1}"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">

                <Grid FlowDirection="{DynamicResource App.FlowDirection}"
                      Language="{DynamicResource App.XmlLanguage}"
                      SnapsToDevicePixels="True">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="{DynamicResource Grid.Space.10}" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="{DynamicResource Grid.Space.10}" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Width="{DynamicResource Space.4}"
                            Height="{DynamicResource Space.22}"
                            Background="{DynamicResource Brush.Accent}"
                            CornerRadius="{DynamicResource Radius.Control}"
                            VerticalAlignment="Top"
                            SnapsToDevicePixels="True" />

                    <StackPanel Grid.Column="2"
                                FlowDirection="{DynamicResource App.FlowDirection}"
                                Language="{DynamicResource App.XmlLanguage}"
                                VerticalAlignment="Center">

                        <TextBlock Text="{DynamicResource LocRedumpDetails_Title}"
                                   ToolTip="{DynamicResource LocRedumpDetails_Title}"
                                   Style="{StaticResource RedumpDetails.TitleText}" />

                        <TextBlock Margin="{DynamicResource Inset.0.2.0.0}"
                                   Text="{DynamicResource LocRedumpDetails_Subtitle}"
                                   ToolTip="{DynamicResource LocRedumpDetails_Subtitle}"
                                   Style="{StaticResource RedumpDetails.BodyText}"
                                   TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>

                    <Button Grid.Column="4"
                            Width="{DynamicResource Space.32}"
                            Height="{DynamicResource Space.32}"
                            MinWidth="{DynamicResource Space.32}"
                            Padding="{DynamicResource Inset.None}"
                            VerticalAlignment="Center"
                            Style="{StaticResource HeaderIconButtonStyle}"
                            ToolTip="{DynamicResource LocCommon_Close}"
                            AutomationProperties.Name="{DynamicResource LocCommon_Close}"
                            Command="{Binding CloseCommand}"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">

                        <Viewbox Width="{DynamicResource Space.12}"
                                 Height="{DynamicResource Space.12}"
                                 FlowDirection="LeftToRight"
                                 Stretch="Uniform">

                            <Path Data="{StaticResource Icon.Close}"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  Stretch="Uniform"
                                  SnapsToDevicePixels="True" />
                        </Viewbox>
                    </Button>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Style="{StaticResource RedumpDetails.ContentHost}">

                <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto"
                              CanContentScroll="False"
                              PanningMode="VerticalOnly"
                              Focusable="False"
                              Background="{DynamicResource Brush.Transparent}"
                              SnapsToDevicePixels="True">

                    <StackPanel FlowDirection="{DynamicResource App.FlowDirection}"
                                Language="{DynamicResource App.XmlLanguage}">

                        <Grid FlowDirection="{DynamicResource App.FlowDirection}"
                              Language="{DynamicResource App.XmlLanguage}"
                              SnapsToDevicePixels="True">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="{DynamicResource Grid.Space.12}" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0"
                                        MinWidth="0"
                                        FlowDirection="{DynamicResource App.FlowDirection}"
                                        Language="{DynamicResource App.XmlLanguage}">

                                <TextBlock Text="{Binding DisplayTitle, Mode=OneWay}"
                                           ToolTip="{Binding DisplayTitle, Mode=OneWay}"
                                           Style="{StaticResource RedumpDetails.TitleText}" />

                                <TextBlock Margin="{DynamicResource Inset.0.6.0.0}"
                                           Text="{Binding StatusNote, Mode=OneWay}"
                                           ToolTip="{Binding StatusNote, Mode=OneWay}"
                                           Style="{StaticResource RedumpDetails.BodyText}" />
                            </StackPanel>

                            <Border Grid.Column="2"
                                    Style="{StaticResource RedumpDetails.StatusBadge}">
                                <TextBlock Text="{Binding Status, Mode=OneWay}"
                                           ToolTip="{Binding Status, Mode=OneWay}"
                                           Style="{StaticResource RedumpDetails.StatusBadgeText}" />
                            </Border>
                        </Grid>

                        <Grid Margin="{DynamicResource Inset.0.12.0.0}"
                              FlowDirection="{DynamicResource App.FlowDirection}"
                              Language="{DynamicResource App.XmlLanguage}"
                              SnapsToDevicePixels="True">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="{DynamicResource Grid.Space.8}" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="{DynamicResource Grid.Space.8}" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="{DynamicResource Grid.Space.8}" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Style="{StaticResource RedumpDetails.InfoTile}">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource LocRedumpDetails_SystemLabel}"
                                               ToolTip="{DynamicResource LocRedumpDetails_SystemLabel}"
                                               Style="{StaticResource RedumpDetails.LabelText}" />

                                    <TextBlock Margin="{DynamicResource Inset.0.5.0.0}"
                                               Text="{Binding SystemName, Mode=OneWay}"
                                               ToolTip="{Binding SystemName, Mode=OneWay}"
                                               Style="{StaticResource RedumpDetails.TechnicalText}" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2"
                                    Style="{StaticResource RedumpDetails.InfoTile}">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource LocRedumpDetails_ConsoleTypeLabel}"
                                               ToolTip="{DynamicResource LocRedumpDetails_ConsoleTypeLabel}"
                                               Style="{StaticResource RedumpDetails.LabelText}" />

                                    <TextBlock Margin="{DynamicResource Inset.0.5.0.0}"
                                               Text="{Binding ConsoleTypeName, Mode=OneWay}"
                                               ToolTip="{Binding ConsoleTypeName, Mode=OneWay}"
                                               Style="{StaticResource RedumpDetails.TechnicalText}" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="4"
                                    Style="{StaticResource RedumpDetails.InfoTile}">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource LocRedumpDetails_ManufacturerLabel}"
                                               ToolTip="{DynamicResource LocRedumpDetails_ManufacturerLabel}"
                                               Style="{StaticResource RedumpDetails.LabelText}" />

                                    <TextBlock Margin="{DynamicResource Inset.0.5.0.0}"
                                               Text="{Binding ManufacturerName, Mode=OneWay}"
                                               ToolTip="{Binding ManufacturerName, Mode=OneWay}"
                                               Style="{StaticResource RedumpDetails.TechnicalText}" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="6"
                                    Style="{StaticResource RedumpDetails.InfoTile}">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource LocRedumpDetails_SizeLabel}"
                                               ToolTip="{DynamicResource LocRedumpDetails_SizeLabel}"
                                               Style="{StaticResource RedumpDetails.LabelText}" />

                                    <TextBlock Margin="{DynamicResource Inset.0.5.0.0}"
                                               Text="{Binding SizeDisplay, Mode=OneWay}"
                                               ToolTip="{Binding SizeDisplay, Mode=OneWay}"
                                               Style="{StaticResource RedumpDetails.TechnicalText}" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Margin="{DynamicResource Inset.0.12.0.0}"
                                Style="{StaticResource RedumpDetails.DecisionSurface}">

                            <Grid FlowDirection="{DynamicResource App.FlowDirection}"
                                  Language="{DynamicResource App.XmlLanguage}"
                                  SnapsToDevicePixels="True">

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="{DynamicResource Grid.Space.8}" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0"
                                      FlowDirection="{DynamicResource App.FlowDirection}"
                                      Language="{DynamicResource App.XmlLanguage}"
                                      SnapsToDevicePixels="True">

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="{DynamicResource Grid.Space.8}" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0"
                                                FlowDirection="{DynamicResource App.FlowDirection}"
                                                Language="{DynamicResource App.XmlLanguage}">

                                        <TextBlock Text="{DynamicResource LocRedumpDetails_SuggestedNameTitle}"
                                                   ToolTip="{DynamicResource LocRedumpDetails_SuggestedNameTitle}"
                                                   Style="{StaticResource RedumpDetails.SectionTitleText}" />

                                        <TextBlock Margin="{DynamicResource Inset.0.2.0.0}"
                                                   Text="{DynamicResource LocRedumpDetails_SuggestedNameDescription}"
                                                   ToolTip="{DynamicResource LocRedumpDetails_SuggestedNameDescription}"
                                                   Style="{StaticResource RedumpDetails.BodyText}" />
                                    </StackPanel>

                                    <Button Grid.Column="2"
                                            Content="{DynamicResource LocUi_Redump_CopyName}"
                                            ToolTip="{DynamicResource LocUi_Redump_CopyName}"
                                            AutomationProperties.Name="{DynamicResource LocUi_Redump_CopyName}"
                                            Command="{Binding CopyNameCommand}"
                                            Style="{StaticResource RedumpDetails.CompactSecondaryButton}" />
                                </Grid>

                                <Border Grid.Row="2"
                                        Style="{StaticResource RedumpDetails.TechnicalSurface}">
                                    <TextBlock Text="{Binding SuggestedName, Mode=OneWay}"
                                               ToolTip="{Binding SuggestedName, Mode=OneWay}"
                                               FontSize="{DynamicResource FontSize.BodySmall}"
                                               Style="{StaticResource RedumpDetails.TechnicalText}" />
                                </Border>
                            </Grid>
                        </Border>

                        <Expander Margin="{DynamicResource Inset.0.12.0.0}"
                                  FlowDirection="{DynamicResource App.FlowDirection}"
                                  Language="{DynamicResource App.XmlLanguage}">

                            <Expander.Header>
                                <TextBlock Text="{DynamicResource LocRedumpDetails_HashesTitle}"
                                           ToolTip="{DynamicResource LocRedumpDetails_HashesTitle}"
                                           Style="{StaticResource RedumpDetails.SectionTitleText}" />
                            </Expander.Header>

                            <StackPanel Margin="{DynamicResource Inset.0.10.0.0}"
                                        FlowDirection="{DynamicResource App.FlowDirection}"
                                        Language="{DynamicResource App.XmlLanguage}">

                                <Grid FlowDirection="{DynamicResource App.FlowDirection}"
                                      Language="{DynamicResource App.XmlLanguage}"
                                      SnapsToDevicePixels="True">

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="{DynamicResource Grid.Space.8}" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="{DynamicResource LocRedumpDetails_HashesDescription}"
                                               ToolTip="{DynamicResource LocRedumpDetails_HashesDescription}"
                                               Style="{StaticResource RedumpDetails.BodyText}" />

                                    <Button Grid.Column="2"
                                            Content="{DynamicResource LocUi_Redump_CopyHash}"
                                            ToolTip="{DynamicResource LocUi_Redump_CopyHash}"
                                            AutomationProperties.Name="{DynamicResource LocUi_Redump_CopyHash}"
                                            Command="{Binding CopyHashesCommand}"
                                            Style="{StaticResource RedumpDetails.CompactSecondaryButton}" />
                                </Grid>

                                <Border Margin="{DynamicResource Inset.0.8.0.0}"
                                        Style="{StaticResource RedumpDetails.TechnicalSurface}">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  Focusable="False"
                                                  CanContentScroll="True"
                                                  MaxHeight="112">
                                        <TextBlock Text="{Binding HashesSummary, Mode=OneWay}"
                                                   ToolTip="{Binding HashesSummary, Mode=OneWay}"
                                                   Style="{StaticResource RedumpDetails.MultiLineTechnicalText}" />
                                    </ScrollViewer>
                                </Border>

                                <Grid Margin="{DynamicResource Inset.0.12.0.0}"
                                      FlowDirection="{DynamicResource App.FlowDirection}"
                                      Language="{DynamicResource App.XmlLanguage}"
                                      SnapsToDevicePixels="True">

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="{DynamicResource Grid.Space.12}" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0"
                                                FlowDirection="{DynamicResource App.FlowDirection}"
                                                Language="{DynamicResource App.XmlLanguage}">

                                        <TextBlock Text="{DynamicResource LocRedumpDetails_FilesTitle}"
                                                   ToolTip="{DynamicResource LocRedumpDetails_FilesTitle}"
                                                   Style="{StaticResource RedumpDetails.SectionTitleText}" />

                                        <Border Margin="{DynamicResource Inset.0.6.0.0}"
                                                Style="{StaticResource RedumpDetails.TechnicalSurface}">
                                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                          HorizontalScrollBarVisibility="Disabled"
                                                          Focusable="False"
                                                          CanContentScroll="True"
                                                          MaxHeight="88">
                                                <TextBlock Text="{Binding FilesSummary, Mode=OneWay}"
                                                           ToolTip="{Binding FilesSummary, Mode=OneWay}"
                                                           Style="{StaticResource RedumpDetails.MultiLineTechnicalText}" />
                                            </ScrollViewer>
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2"
                                                FlowDirection="{DynamicResource App.FlowDirection}"
                                                Language="{DynamicResource App.XmlLanguage}">

                                        <TextBlock Text="{DynamicResource LocRedumpDetails_NotesTitle}"
                                                   ToolTip="{DynamicResource LocRedumpDetails_NotesTitle}"
                                                   Style="{StaticResource RedumpDetails.SectionTitleText}" />

                                        <Border Margin="{DynamicResource Inset.0.6.0.0}"
                                                Style="{StaticResource RedumpDetails.TechnicalSurface}">
                                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                          HorizontalScrollBarVisibility="Disabled"
                                                          Focusable="False"
                                                          CanContentScroll="True"
                                                          MaxHeight="88">
                                                <TextBlock Text="{Binding NotesText, Mode=OneWay}"
                                                           ToolTip="{Binding NotesText, Mode=OneWay}"
                                                           Style="{StaticResource RedumpDetails.BodyText}" />
                                            </ScrollViewer>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Row="2"
                    Style="{StaticResource RedumpDetails.HeaderFooter}"
                    BorderThickness="{DynamicResource Inset.0.1.0.0}">

                <Grid FlowDirection="{DynamicResource App.FlowDirection}"
                      Language="{DynamicResource App.XmlLanguage}"
                      SnapsToDevicePixels="True">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="{DynamicResource Grid.Space.12}" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="{DynamicResource Grid.Space.12}" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Content="{DynamicResource LocCommon_Close}"
                            ToolTip="{DynamicResource LocCommon_Close}"
                            AutomationProperties.Name="{DynamicResource LocCommon_Close}"
                            Command="{Binding CloseCommand}"
                            Style="{StaticResource RedumpDetails.CompactSecondaryButton}" />

                    <TextBlock Grid.Column="2"
                               Text="{Binding CopyFeedbackText, Mode=OneWay}"
                               ToolTip="{Binding CopyFeedbackText, Mode=OneWay}"
                               Visibility="{Binding IsCopyFeedbackVisible, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}"
                               Style="{StaticResource RedumpDetails.FooterFeedbackText}" />

                    <Button Grid.Column="4"
                            Content="{DynamicResource LocRedumpDetails_ApplyName}"
                            ToolTip="{DynamicResource LocRedumpDetails_ApplyName}"
                            AutomationProperties.Name="{DynamicResource LocRedumpDetails_ApplyName}"
                            IsEnabled="{Binding CanApplyName, Mode=OneWay}"
                            Command="{Binding ApplyNameCommand}"
                            Style="{StaticResource RedumpDetails.CompactPrimaryButton}" />
                </Grid>
            </Border>

            <Border x:Name="CopyFeedbackToast"
                    Grid.RowSpan="3"
                    Width="0"
                    Height="0"
                    Visibility="Collapsed"
                    Opacity="0"
                    IsHitTestVisible="False">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="CopyFeedbackToastTranslate"
                                        Y="0" />
                </Border.RenderTransform>
            </Border>
        </Grid>
    </Border>
</Window>